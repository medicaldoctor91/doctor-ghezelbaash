---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.mjs';
import { location } from '../data/location.mjs';
---
<BaseLayout title="تماس با کلینیک زیبایی دکتر سعید قزلباش در کرمانشاه" description="شماره تماس، آدرس، اینستاگرام رسمی و Google Maps کلینیک زیبایی دکتر سعید قزلباش در کرمانشاه." canonicalPath="/contact/">
  <section class="box">
    <h1>تماس با کلینیک زیبایی دکتر سعید قزلباش</h1>
    <p>برای هماهنگی، بررسی آدرس و مشاهده مسیرهای رسمی ارتباط با دکتر سعید قزلباش در کرمانشاه از این صفحه استفاده کنید.</p>
    <p><a class="cta" href={site.instagram}>هماهنگی از اینستاگرام رسمی</a></p>
  </section>

  <section>
    <h2>مسیرهای ارتباط</h2>
    <div class="grid">
      <a class="card" href="tel:+989308209494">تماس مستقیم: {location.phoneDisplay}</a>
      <a class="card" href={site.instagram}>Instagram رسمی</a>
      <a class="card" href={location.googleMapsCid}>مشاهده در Google Maps</a>
      <a class="card" href={location.openStreetMap}>مشاهده در OpenStreetMap</a>
    </div>
  </section>

  <section>
    <h2>آدرس</h2>
    <p class="box">{location.canonicalAddressFa}</p>
  </section>

  <section>
    <h2>قبل از مراجعه</h2>
    <ul>
      <li>برای هماهنگی سریع‌تر از اینستاگرام رسمی یا شماره تماس استفاده کنید.</li>
      <li>برای تصمیم‌گیری درباره هر خدمت، صفحه اختصاصی همان خدمت را ببینید.</li>
      <li>برای شناخت هویت پزشک، صفحه دکتر سعید قزلباش و بخش شواهد سایت را بررسی کنید.</li>
    </ul>
  </section>
</BaseLayout>
