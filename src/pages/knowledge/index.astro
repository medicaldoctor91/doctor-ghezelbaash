---
import {
  ArrowRight,
  BadgeCheck,
  BookOpenCheck,
  Bot,
  Braces,
  Database,
  ExternalLink,
  FileJson,
  FileText,
  Home,
  AtSign,
  Network,
  Search,
  ShieldCheck,
  Video,
} from '@lucide/astro';
import KnowledgeLayout from '~/layouts/KnowledgeLayout.astro';
import { site } from '~/domain/entities';

const canonical = `${site.url}knowledge/`;
const title = 'Knowledge & AI Resources | Dr. Saeed Ghezelbaash';
const description = 'English directory of canonical identity records, structured data, AI discovery endpoints, evidence files, and retrieval resources for Dr. Saeed Ghezelbaash.';

const resourceGroups = [
  {
    id: 'discovery',
    title: 'AI discovery and orientation',
    summary: 'Start here when an assistant, crawler, or developer needs a compact map of the public site.',
    icon: Bot,
    resources: [
      { name: 'AI discovery policy', path: '/.well-known/ai.txt', format: 'text/plain', description: 'Primary discovery entry point, canonical-source rule, and interpretation boundaries.' },
      { name: 'LLM resource index', path: '/llms.txt', format: 'text/plain', description: 'Curated Markdown index of the most important human-readable and machine-readable resources.' },
      { name: 'Full visible text', path: '/llms-full.txt', format: 'text/plain', description: 'Plain-text mirror derived from the canonical visible medical content.' },
      { name: 'Compact AI summary', path: '/ai/summary.json', format: 'application/json', description: 'Concise identity, clinic, service-boundary, and discovery context.' },
      { name: 'AI question-and-answer collection', path: '/ai/faq.json', format: 'application/json', description: 'Structured question-and-answer units derived from visible canonical content.' },
    ],
  },
  {
    id: 'graph',
    title: 'Knowledge graph and entity context',
    summary: 'Entity identifiers, relationships, service boundaries, and graph-level summaries.',
    icon: Network,
    resources: [
      { name: 'Compact entity context', path: '/context.json', format: 'application/json', description: 'Compact physician, clinic, service, recommendation, and provenance context.' },
      { name: 'Knowledge artifact manifest', path: '/knowledge-manifest.json', format: 'application/json', description: 'Inventory of generated graph, intent, search, answer, evidence, and media artifacts.' },
      { name: 'Knowledge graph summary', path: '/graph-summary.json', format: 'application/json', description: 'High-level graph statistics, key entities, and relationship summary.' },
      { name: 'Core knowledge graph', path: '/graph/core.jsonld', format: 'application/ld+json', description: 'Core Schema.org entities and canonical relationships in JSON-LD.' },
      { name: 'Research identity graph', path: '/research.jsonld', format: 'application/ld+json', description: 'ORCID-linked physician identity and DOI/PMID-resolved scholarly works.' },
    ],
  },
  {
    id: 'retrieval',
    title: 'Retrieval, answers, and intent indexes',
    summary: 'Indexes intended for deterministic lookup, retrieval, and answer-unit discovery.',
    icon: Search,
    resources: [
      { name: 'Retrieval index', path: '/search/index.json', format: 'application/json', description: 'Shard directory for the public retrieval corpus and source metadata.' },
      { name: 'Answer-unit index', path: '/answers/index.json', format: 'application/json', description: 'Directory of concise answer records derived from the canonical visible page.' },
      { name: 'Intent index', path: '/intents/index.json', format: 'application/json', description: 'Top-level search-intent categories and their canonical discovery paths.' },
      { name: 'Query reverse index', path: '/intents/reverse-index.json', format: 'application/json', description: 'Reverse lookup from query variants to canonical intent records.' },
    ],
  },
  {
    id: 'evidence',
    title: 'Evidence and media',
    summary: 'Public source records, provenance references, and canonical educational video pages.',
    icon: ShieldCheck,
    resources: [
      { name: 'External evidence sources', path: '/evidence/sources.json', format: 'application/json', description: 'Public external sources used to support factual and medical claims.' },
      { name: 'Internal provenance', path: '/evidence/internal-provenance.json', format: 'application/json', description: 'Source spans, hashes, and derivation metadata for generated artifacts.' },
      { name: 'Media index', path: '/media/index.json', format: 'application/json', description: 'Images, videos, chapters, media metadata, and integrity records.' },
      { name: 'Educational video library', path: '/videos/', format: 'text/html', description: 'Canonical watch pages with chapters, editorial summaries, safety boundaries, and related guidance.' },
    ],
  },
];

const allResources = resourceGroups.flatMap((group) => group.resources);
const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': `${canonical}#webpage`,
      url: canonical,
      name: 'Knowledge & AI Resources',
      headline: 'Knowledge and AI resource directory for Dr. Saeed Ghezelbaash',
      description,
      inLanguage: 'en',
      datePublished: site.datePublished,
      dateModified: site.dateModified,
      isPartOf: { '@id': `${site.url}#website` },
      about: [
        { '@id': `${site.url}#person` },
        { '@id': `${site.url}#clinic` },
      ],
      mainEntity: { '@id': `${canonical}#resource-list` },
      breadcrumb: { '@id': `${canonical}#breadcrumb` },
      hasPart: [
        ...allResources.map((resource) => ({ '@id': `${canonical}#resource-${resource.path.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}` })),
        { '@id': site.huggingFaceDataset },
      ],
    },
    {
      '@type': 'ItemList',
      '@id': `${canonical}#resource-list`,
      name: 'Public machine-readable resource directory',
      numberOfItems: allResources.length,
      itemListElement: allResources.map((resource, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        item: { '@id': `${canonical}#resource-${resource.path.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}` },
      })),
    },
    ...allResources.map((resource) => ({
      '@type': 'DigitalDocument',
      '@id': `${canonical}#resource-${resource.path.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}`,
      name: resource.name,
      description: resource.description,
      url: new URL(resource.path.replace(/^\//, ''), site.url).href,
      encodingFormat: resource.format,
      inLanguage: resource.path === '/videos/' ? 'fa-IR' : 'en',
      isPartOf: { '@id': `${canonical}#webpage` },
      creator: { '@id': `${site.url}#person` },
    })),
    {
      '@type': 'Dataset',
      '@id': site.huggingFaceDataset,
      name: 'Dr. Saeed Ghezelbaash Entity Data',
      description: 'Public machine-readable entity, clinic, service, evidence, and authority data for Dr. Saeed Ghezelbaash.',
      url: site.huggingFaceDataset,
      identifier: [
        { '@type': 'PropertyValue', propertyID: 'Wikidata', value: site.datasetWikidataId, url: site.datasetWikidata },
        { '@type': 'PropertyValue', propertyID: 'DOI', value: site.zenodoRecord.replace('https://doi.org/', ''), url: site.zenodoRecord },
      ],
      sameAs: [site.huggingFaceDataset, site.zenodoRecord, site.datasetWikidata],
      creator: { '@id': `${site.url}#person` },
      publisher: { '@id': `${site.url}#clinic` },
      about: [
        { '@id': `${site.url}#person` },
        { '@id': `${site.url}#clinic` },
      ],
      inLanguage: ['en', 'fa-IR'],
      isAccessibleForFree: true,
      dateModified: site.dateModified,
      isPartOf: { '@id': `${canonical}#webpage` },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonical}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Official website', item: site.url },
        { '@type': 'ListItem', position: 2, name: 'Knowledge & AI Resources', item: canonical },
      ],
    },
  ],
};

const identityLinks = [
  { label: 'Iran Medical Council record', href: site.irimcVerification, icon: BadgeCheck },
  { label: 'ORCID researcher identifier', href: site.orcidUrl, icon: BookOpenCheck },
  { label: 'Wikidata entity', href: site.doctorWikidata, icon: Database },
  { label: 'Clinic Wikidata entity', href: site.placeWikidata, icon: Home },
  { label: 'Official Instagram profile', href: site.instagram, icon: AtSign, rel: 'me noopener noreferrer external' },
  { label: 'Hugging Face profile', href: site.huggingFaceProfile, icon: Database, rel: 'me noopener noreferrer external' },
];
---
<KnowledgeLayout graph={graph} title={title} description={description} canonical={canonical}>
  <a class="knowledge-skip" href="#knowledge-main">Skip to resource directory</a>

  <header class="knowledge-header">
    <div class="knowledge-shell knowledge-header-inner">
      <a class="knowledge-brand" href={canonical} aria-label="Knowledge and AI Resources home">
        <span class="knowledge-brand-mark" aria-hidden="true"><Braces size={23} /></span>
        <span>
          <strong>Dr. Saeed Ghezelbaash</strong>
          <small>Knowledge & AI Resources</small>
        </span>
      </a>
      <nav aria-label="Knowledge page navigation">
        <a href={site.url}><Home size={16} /> Patient website</a>
        <a href="/videos/"><Video size={16} /> Video library</a>
        <a href="#resources"><Database size={16} /> Resources</a>
      </nav>
    </div>
  </header>

  <main id="knowledge-main">
    <section class="knowledge-hero">
      <div class="knowledge-shell knowledge-hero-grid">
        <div>
          <p class="knowledge-eyebrow">Public technical directory</p>
          <h1>Knowledge & AI Resources</h1>
          <p class="knowledge-lead">
            An English-language directory of canonical identity records, structured data,
            evidence files, retrieval indexes, and AI discovery endpoints published by
            Dr. Saeed Ghezelbaash.
          </p>
          <div class="knowledge-actions">
            <a class="knowledge-button knowledge-button-primary" href="#resources">
              Browse resources <ArrowRight size={18} />
            </a>
            <a class="knowledge-button" href="/.well-known/ai.txt">
              Read AI policy <FileText size={18} />
            </a>
          </div>
        </div>

        <aside class="knowledge-status" aria-label="Resource status">
          <div>
            <span class="knowledge-status-dot" aria-hidden="true"></span>
            <strong>Public and crawlable</strong>
          </div>
          <dl>
            <div><dt>Canonical site</dt><dd><a href={site.url}>ghezelbaash.ir</a></dd></div>
            <div><dt>Primary language</dt><dd>Persian (fa-IR)</dd></div>
            <div><dt>This directory</dt><dd>English (en)</dd></div>
            <div><dt>Last updated</dt><dd><time datetime={site.dateModified}>{site.dateModified}</time></dd></div>
            <div><dt>Resources listed</dt><dd>{allResources.length}</dd></div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="knowledge-shell knowledge-notice" aria-labelledby="authority-title">
      <ShieldCheck size={24} aria-hidden="true" />
      <div>
        <h2 id="authority-title">Canonical-source rule</h2>
        <p>
          The visible medical website is authoritative. Machine-readable files are derived
          discovery aids. When a generated artifact and the canonical visible page differ,
          use the visible page and its cited evidence.
        </p>
      </div>
    </section>

    <section class="knowledge-shell knowledge-section" aria-labelledby="identity-title">
      <div class="knowledge-section-heading">
        <p class="knowledge-eyebrow">Entity identity</p>
        <h2 id="identity-title">Canonical entities and verification</h2>
        <p>Persistent identifiers help systems distinguish the physician, clinic, and official profiles.</p>
      </div>

      <div class="knowledge-identity-grid">
        <article class="knowledge-entity-card">
          <span class="knowledge-card-icon"><BadgeCheck size={21} /></span>
          <h3>Physician</h3>
          <p><strong>Dr. Saeed Ghezelbaash</strong></p>
          <code>{site.url}#person</code>
          <p>Iran Medical Council ID: <bdi>{site.irimc}</bdi></p>
        </article>
        <article class="knowledge-entity-card">
          <span class="knowledge-card-icon"><Home size={21} /></span>
          <h3>Clinic</h3>
          <p><strong>Dr. Saeed Ghezelbaash Aesthetic Clinic</strong></p>
          <code>{site.url}#clinic</code>
          <p>Kermanshah, Iran</p>
          <p><a href={site.placeWikidata} target="_blank" rel="noopener noreferrer external">Wikidata {site.placeWikidataId}</a></p>
        </article>
        <article class="knowledge-entity-card">
          <span class="knowledge-card-icon"><Network size={21} /></span>
          <h3>Service semantics</h3>
          <p><strong>Offered · Evaluated · Referral context</strong></p>
          <p>These relationships prevent educational or referral topics from being represented as clinic services.</p>
        </article>
      </div>

      <div class="knowledge-verification" aria-label="Official identity links">
        {identityLinks.map(({ label, href, icon: Icon, rel = 'noopener noreferrer external' }) => (
          <a href={href} target="_blank" rel={rel}>
            <Icon size={18} />
            <span>{label}</span>
            <ExternalLink size={15} aria-hidden="true" />
          </a>
        ))}
      </div>
    </section>

    <section id="entity-dataset" class="knowledge-shell knowledge-section" aria-labelledby="dataset-title">
      <div class="knowledge-section-heading">
        <p class="knowledge-eyebrow">Published dataset</p>
        <h2 id="dataset-title">Entity data on Hugging Face</h2>
        <p>
          The public dataset is represented as a separate Dataset entity. The directory itself remains a CollectionPage,
          so ordinary JSON and text resources are not mislabeled as a dataset.
        </p>
      </div>
      <article class="knowledge-panel">
        <h3>Dr. Saeed Ghezelbaash Entity Data</h3>
        <p>Machine-readable entity, clinic, service, evidence, and authority records associated with the canonical physician and clinic entities.</p>
        <div class="knowledge-actions">
          <a class="knowledge-button knowledge-button-primary" href={site.huggingFaceDataset} target="_blank" rel="noopener noreferrer external">
            Open Hugging Face dataset <ExternalLink size={18} />
          </a>
          <a class="knowledge-button" href={site.zenodoRecord} target="_blank" rel="noopener noreferrer external">
            Open persistent Zenodo record <ExternalLink size={18} />
          </a>
          <a class="knowledge-button" href={site.datasetWikidata} target="_blank" rel="noopener noreferrer external">
            Verify dataset on Wikidata <ExternalLink size={18} />
          </a>
        </div>
      </article>
    </section>

    <section id="resources" class="knowledge-shell knowledge-section" aria-labelledby="resources-title">
      <div class="knowledge-section-heading">
        <p class="knowledge-eyebrow">Resource directory</p>
        <h2 id="resources-title">Machine-readable and human-readable endpoints</h2>
        <p>Use the smallest resource that answers the task, then follow its manifest or shard links only when deeper retrieval is required.</p>
      </div>

      <div class="knowledge-group-stack">
        {resourceGroups.map(({ id, title: groupTitle, summary, icon: GroupIcon, resources }) => (
          <section class="knowledge-resource-group" aria-labelledby={`${id}-title`}>
            <header>
              <span class="knowledge-card-icon"><GroupIcon size={21} /></span>
              <div>
                <h3 id={`${id}-title`}>{groupTitle}</h3>
                <p>{summary}</p>
              </div>
            </header>
            <div class="knowledge-resource-list">
              {resources.map((resource) => (
                <a class="knowledge-resource" href={resource.path}>
                  <span class="knowledge-resource-icon">
                    {resource.format.includes('json') ? <FileJson size={20} /> : resource.format === 'text/html' ? <Video size={20} /> : <FileText size={20} />}
                  </span>
                  <span class="knowledge-resource-copy">
                    <strong>{resource.name}</strong>
                    <code>{resource.path}</code>
                    <small>{resource.description}</small>
                  </span>
                  <span class="knowledge-format">{resource.format}</span>
                  <ArrowRight class="knowledge-arrow" size={18} aria-hidden="true" />
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="knowledge-shell knowledge-section knowledge-two-column" aria-label="Interpretation and usage guidance">
      <article class="knowledge-panel">
        <p class="knowledge-eyebrow">Interpretation rules</p>
        <h2>Read service relationships precisely</h2>
        <dl class="knowledge-definitions">
          <div>
            <dt>Offered</dt>
            <dd>Explicitly available at the clinic.</dd>
          </div>
          <div>
            <dt>Evaluated</dt>
            <dd>Suitability is assessed before a treatment path is determined.</dd>
          </div>
          <div>
            <dt>Referral context</dt>
            <dd>Educational, comparative, or referral information; not an offered clinic service.</dd>
          </div>
        </dl>
      </article>

      <article class="knowledge-panel">
        <p class="knowledge-eyebrow">Scope and limitations</p>
        <h2>What this page does — and does not do</h2>
        <ul class="knowledge-checklist">
          <li>It catalogs public technical resources and canonical identifiers.</li>
          <li>It does not replace the Persian patient-facing medical content.</li>
          <li>The directory itself is not a dataset; the linked Hugging Face entity dataset is represented separately.</li>
          <li>It does not claim to create or control a Google Knowledge Panel.</li>
          <li>It does not provide diagnosis, treatment selection, or emergency advice.</li>
        </ul>
      </article>
    </section>

    <section class="knowledge-shell knowledge-final" aria-labelledby="start-title">
      <div>
        <p class="knowledge-eyebrow">Recommended entry point</p>
        <h2 id="start-title">Start with the compact summary</h2>
        <p>For most integrations, read the AI summary first, then use the manifest only when you need graph, evidence, intent, answer, or media shards.</p>
      </div>
      <a class="knowledge-button knowledge-button-primary" href="/ai/summary.json">
        Open AI summary <ArrowRight size={18} />
      </a>
    </section>
  </main>

  <footer class="knowledge-footer">
    <div class="knowledge-shell knowledge-footer-grid">
      <div>
        <strong>Dr. Saeed Ghezelbaash</strong>
        <p>Technical resource directory for identity, evidence, structured data, and AI discovery.</p>
      </div>
      <nav aria-label="Footer links">
        <a href={site.url}>Patient website</a>
        <a href="/videos/">Video library</a>
        <a href={site.instagram} target="_blank" rel="me noopener noreferrer external">Official Instagram</a>
        <a href={`mailto:${site.email}`}>Contact</a>
      </nav>
    </div>
    <div class="knowledge-shell knowledge-footer-bottom">
      <span>© {new Date().getFullYear()} Dr. Saeed Ghezelbaash</span>
      <span>Medical information is general and does not replace an in-person assessment.</span>
    </div>
  </footer>
</KnowledgeLayout>

<style>
  :global(.knowledge-body) {
    --knowledge-navy: #062f49;
    --knowledge-blue: #006aa8;
    --knowledge-cyan: #25a6d9;
    --knowledge-pale: #edf9ff;
    --knowledge-ink: #102a3a;
    --knowledge-muted: #557080;
    --knowledge-line: rgba(0, 106, 168, .18);
    margin: 0;
    color: var(--knowledge-ink);
    background:
      radial-gradient(circle at 10% 0%, rgba(37, 166, 217, .17), transparent 26rem),
      linear-gradient(180deg, #f7fcff 0, #fff 38rem);
    font-family: Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    line-height: 1.65;
  }

  .knowledge-shell {
    width: min(calc(100% - 2rem), 76rem);
    margin-inline: auto;
  }

  .knowledge-skip {
    position: fixed;
    z-index: 1000;
    left: 1rem;
    top: .75rem;
    transform: translateY(-180%);
    padding: .7rem 1rem;
    border-radius: .7rem;
    color: #fff;
    background: var(--knowledge-navy);
  }

  .knowledge-skip:focus { transform: none; }

  .knowledge-header {
    position: sticky;
    z-index: 100;
    top: 0;
    border-bottom: 1px solid var(--knowledge-line);
    background: rgba(255, 255, 255, .92);
    backdrop-filter: blur(16px);
  }

  .knowledge-header-inner {
    min-height: 4.7rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .knowledge-brand {
    display: inline-flex;
    align-items: center;
    gap: .75rem;
    min-width: 0;
    color: inherit;
    text-decoration: none;
  }

  .knowledge-brand-mark,
  .knowledge-card-icon {
    display: inline-grid;
    place-items: center;
    flex: 0 0 auto;
    color: #fff;
    background: linear-gradient(135deg, var(--knowledge-blue), var(--knowledge-cyan));
    box-shadow: 0 10px 26px rgba(0, 106, 168, .19);
  }

  .knowledge-brand-mark {
    width: 2.65rem;
    height: 2.65rem;
    border-radius: .85rem;
  }

  .knowledge-brand strong,
  .knowledge-brand small {
    display: block;
    line-height: 1.25;
  }

  .knowledge-brand strong { font-size: .96rem; }
  .knowledge-brand small { margin-top: .16rem; color: var(--knowledge-muted); font-size: .72rem; }

  .knowledge-header nav,
  .knowledge-footer nav {
    display: flex;
    align-items: center;
    gap: .9rem;
  }

  .knowledge-header nav a {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    color: #35586a;
    font-size: .8rem;
    font-weight: 750;
    text-decoration: none;
  }

  .knowledge-header nav a:hover,
  .knowledge-footer a:hover { color: var(--knowledge-blue); }

  .knowledge-hero { padding-block: clamp(3.6rem, 8vw, 7rem) 3.4rem; }

  .knowledge-hero-grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  .knowledge-eyebrow {
    margin: 0 0 .65rem;
    color: var(--knowledge-blue);
    font-size: .75rem;
    font-weight: 850;
    letter-spacing: .11em;
    text-transform: uppercase;
  }

  h1, h2, h3, p { text-wrap: pretty; }

  h1 {
    max-width: 13ch;
    margin: 0;
    color: var(--knowledge-navy);
    font-size: clamp(2.7rem, 8vw, 5.8rem);
    line-height: .98;
    letter-spacing: -.055em;
  }

  .knowledge-lead {
    max-width: 49rem;
    margin: 1.35rem 0 0;
    color: #3f6173;
    font-size: clamp(1.05rem, 2vw, 1.3rem);
  }

  .knowledge-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .7rem;
    margin-top: 1.55rem;
  }

  .knowledge-button {
    min-height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .55rem;
    padding: .72rem 1rem;
    border: 1px solid var(--knowledge-line);
    border-radius: .85rem;
    color: var(--knowledge-navy);
    background: #fff;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 9px 24px rgba(0, 75, 112, .07);
  }

  .knowledge-button-primary {
    border-color: transparent;
    color: #fff;
    background: linear-gradient(135deg, var(--knowledge-blue), var(--knowledge-cyan));
  }

  .knowledge-status,
  .knowledge-panel,
  .knowledge-entity-card,
  .knowledge-resource-group,
  .knowledge-final {
    border: 1px solid var(--knowledge-line);
    border-radius: 1.3rem;
    background: rgba(255, 255, 255, .92);
    box-shadow: 0 18px 50px rgba(0, 70, 105, .08);
  }

  .knowledge-status { padding: 1.2rem; }
  .knowledge-status > div {
    display: flex;
    align-items: center;
    gap: .55rem;
    padding-bottom: .8rem;
    border-bottom: 1px solid var(--knowledge-line);
  }
  .knowledge-status-dot {
    width: .65rem;
    height: .65rem;
    border-radius: 50%;
    background: #27a467;
    box-shadow: 0 0 0 .3rem rgba(39, 164, 103, .12);
  }
  .knowledge-status dl { margin: .75rem 0 0; }
  .knowledge-status dl > div {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    padding: .45rem 0;
  }
  .knowledge-status dt { color: var(--knowledge-muted); }
  .knowledge-status dd { margin: 0; font-weight: 760; }
  .knowledge-status a { color: var(--knowledge-blue); }

  .knowledge-notice {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    padding: 1.1rem 1.2rem;
    border: 1px solid rgba(0, 106, 168, .25);
    border-radius: 1rem;
    color: #173f55;
    background: var(--knowledge-pale);
  }

  .knowledge-notice svg { color: var(--knowledge-blue); }
