---
import Layout from '~/layouts/PageLayout.astro';
import { getUiCopy } from '~/utils/uiCopy';

const uiCopy = await getUiCopy<{
  notFound: {
    title: string;
    code: string;
    heading: string;
    description: string;
    actions: Array<{ text: string; href: string }>;
  };
}>();
const notFound = uiCopy.notFound;

const metadata = {
  title: notFound.title,
  noCanonical: true,
  robots: 'noindex, follow',
  openGraph: { type: 'website' },
};
---

<Layout metadata={metadata} pagefindBody={false}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-24 text-center">
    <p class="text-primary font-bold mb-3">{notFound.code}</p>
    <h1 class="text-4xl font-bold mb-4">{notFound.heading}</h1>
    <p class="text-muted mb-8">{notFound.description}</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      {
        notFound.actions.map((action, index) => (
          <a class={index === 0 ? 'btn-primary' : 'btn'} href={action.href}>
            {action.text}
          </a>
        ))
      }
    </div>
  </section>
</Layout>
