---
import { ArrowRight, Home, MapPin, Phone } from '@lucide/astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { site } from '~/domain/entities';
import BrandLogo from '../components/home/BrandLogo.astro';

const pageUrl = `${site.url}404`;
const graph = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  url: pageUrl,
  name: `صفحه پیدا نشد | ${site.name}`,
  description: 'نشانی درخواست‌شده در وب‌سایت تک‌صفحه‌ای دکتر سعید قزلباش وجود ندارد.',
  inLanguage: site.language,
  isPartOf: { '@id': `${site.url}#website` },
  about: { '@id': `${site.url}#mohammad-saeed-ghezelbash` },
};

const recoveryLinks = [
  { href: '/#best-aesthetic-doctor-kermanshah', label: 'معیار انتخاب دکتر زیبایی در کرمانشاه' },
  { href: '/#aesthetic-services-kermanshah', label: 'موضوعات و روش‌های زیبایی' },
  { href: '/#aesthetic-treatment-selection', label: 'انتخاب درمان براساس مشکل واقعی' },
  { href: '/#clinic-information-kermanshah', label: 'اطلاعات و موقعیت کلینیک' },
  { href: '/#sources-contact-and-appointment', label: 'تماس و رزرو مشاوره' },
];
---

<SiteLayout
  graph={graph}
  title={`صفحه پیدا نشد | ${site.name}`}
  description="نشانی درخواست‌شده در وب‌سایت تک‌صفحه‌ای دکتر سعید قزلباش وجود ندارد."
  canonical={null}
  robots="noindex,follow"
  preloadHero={false}
>
  <header class="error-header shell">
    <a href="/" aria-label="بازگشت به صفحه اصلی دکتر سعید قزلباش">
      <BrandLogo compact priority />
      <span><strong>{site.name}</strong><small>پزشکی زیبایی در کرمانشاه</small></span>
    </a>
  </header>

  <main id="main-content" class="error-page shell">
    <div class="error-page__panel">
      <p class="eyebrow">خطای ۴۰۴</p>
      <h1>این نشانی به جایی نمی‌رسد؛ مسیر درست همین‌جاست</h1>
      <p>صفحه حذف‌شده یا آدرس اشتباه نباید شما را وسط راه رها کند. تمام محتوای اصلی، راهنماهای پزشکی، اطلاعات کلینیک و مسیر تماس در Homepage رسمی قرار دارند.</p>

      <div class="error-actions">
        <a class="button button--primary" href="/"><Home size={19} aria-hidden="true" /> صفحه اصلی</a>
        <a class="button button--ghost" href={`tel:${site.phone}`}><Phone size={19} aria-hidden="true" /> تماس با کلینیک</a>
      </div>

      <nav class="error-recovery" aria-label="مسیرهای پیشنهادی برای ادامه">
        <strong>مستقیم به بخش موردنیاز بروید</strong>
        <ul>
          {recoveryLinks.map((link) => <li><a href={link.href}>{link.label}<ArrowRight size={17} aria-hidden="true" /></a></li>)}
        </ul>
      </nav>

      <address>
        <MapPin size={18} aria-hidden="true" />
        <a href={site.maps} target="_blank" rel="noopener noreferrer external">{site.clinicName}، {site.address}</a>
      </address>
    </div>
  </main>

  <style>
    .error-header{padding-block:1rem}.error-header>a{width:fit-content;display:flex;gap:.7rem;align-items:center;color:var(--blue-950);text-decoration:none}.error-header strong,.error-header small{display:block}.error-header small{color:var(--muted);font-size:.72rem}.error-page{min-height:calc(100svh - 5rem);padding-block:1rem 3rem}.error-page__panel{width:min(100%,48rem);padding:clamp(1.2rem,5vw,3rem);border:1px solid var(--line);border-radius:clamp(1.2rem,4vw,2rem);background:radial-gradient(circle at 100% 0%,rgba(167,226,255,.35),transparent 18rem),#fff;box-shadow:var(--shadow-lg);text-align:start}.error-page h1{max-width:15ch;margin:0;color:var(--blue-950);font-size:clamp(2rem,8vw,4rem);line-height:1.35}.error-page__panel>p:not(.eyebrow){max-width:42rem;color:#36596b}.error-actions{justify-content:flex-start}.error-recovery{margin-top:2rem;padding-top:1.2rem;border-top:1px solid var(--line)}.error-recovery>strong{color:var(--blue-950)}.error-recovery ul{display:grid;gap:.45rem;margin:.8rem 0 0;padding:0;list-style:none}.error-recovery a{min-height:2.75rem;display:flex;gap:.5rem;align-items:center;justify-content:space-between;padding:.55rem .75rem;border-radius:.7rem;color:var(--blue-800);background:var(--blue-050);font-weight:750;text-decoration:none}.error-recovery a:hover{background:var(--blue-100)}address{display:flex;gap:.45rem;align-items:flex-start;margin-top:1.2rem;color:#36596b;font-style:normal}address svg{flex:0 0 auto;margin-top:.3rem}address a{color:var(--blue-700)}@media(min-width:40rem){.error-recovery ul{grid-template-columns:repeat(2,minmax(0,1fr))}}
  </style>
</SiteLayout>
