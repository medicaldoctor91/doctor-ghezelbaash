---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'صفحه پیدا نشد',
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-24 text-center">
    <p class="text-primary font-bold mb-3">۴۰۴</p>
    <h1 class="text-4xl font-bold mb-4">صفحه موردنظر پیدا نشد</h1>
    <p class="text-muted mb-8">برای ادامه می‌توانید به صفحه اصلی یا درباره کلینیک برگردید.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a class="btn-primary" href="/">خانه</a>
      <a class="btn" href="/dr-saeed-ghezelbash-aesthetic-clinic/">درباره کلینیک</a>
    </div>
  </section>
</Layout>
