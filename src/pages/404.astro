---
import SiteLayout from '../layouts/SiteLayout.astro';
import { site } from '~/domain/entities';
import '../styles/visual-refresh.css';
const canonical = `${site.url}404`;
const graph = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonical}#webpage`,
  url: canonical,
  name: `صفحه پیدا نشد | ${site.name}`,
  description: 'نشانی درخواست‌شده در وب‌سایت تک‌صفحه‌ای دکتر سعید قزلباش وجود ندارد.',
  inLanguage: site.language,
  isPartOf: { '@id': `${site.url}#website` },
};
---
<SiteLayout
  graph={graph}
  title={`صفحه پیدا نشد | ${site.name}`}
  description="نشانی درخواست‌شده در وب‌سایت تک‌صفحه‌ای دکتر سعید قزلباش وجود ندارد."
  canonical={canonical}
  robots="noindex,follow"
>
  <main class="error-page container">
    <p class="eyebrow">خطای ۴۰۴</p>
    <h1>این نشانی در لندینگ تک‌صفحه‌ای وجود ندارد</h1>
    <p>همهٔ مطالب اصلی در صفحهٔ نخست و از طریق فهرست موضوعی در دسترس‌اند.</p>
    <div class="error-actions">
      <a class="heal-button heal-button-primary" href="/">بازگشت به صفحهٔ اصلی</a>
      <a class="heal-button" href="/#content-table">بازکردن فهرست کامل</a>
    </div>
  </main>
</SiteLayout>
