---
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import SiteLayout from '../layouts/SiteLayout.astro';
import HomeHeader from '../components/home/HomeHeader.astro';
import Hero from '../components/home/Hero.astro';
import Services from '../components/home/Services.astro';
import GuideLibrary from '../components/home/GuideLibrary.astro';
import BestDoctorAnswers from '../components/home/BestDoctorAnswers.astro';
import ContactSection from '../components/home/ContactSection.astro';
import HomeFooter from '../components/home/HomeFooter.astro';
import { getHeadings, rawContent } from '../content/landing.md';
import { stabilizeHeadings } from '../domain/anchor-utils';
import { serviceAliasesForHeading } from '../domain/url-architecture.mjs';
import { buildGooglePageGraph } from '../compilers/google-page-graph';
import {
  rehypeAccessibleTables,
  rehypeExternalLinks,
  rehypeHeadingAnchors,
} from '../lib/markdown-plugins.mjs';

const raw = rawContent();
const headings = stabilizeHeadings(getHeadings());
const graph = buildGooglePageGraph(headings, raw);

const h2Matches = [...raw.matchAll(/^##\s+(.+)$/gm)];
const h2Headings = headings.filter((heading) => heading.depth === 2);
const processor = await createMarkdownProcessor({
  gfm: true,
  smartypants: false,
  syntaxHighlight: false,
  rehypePlugins: [rehypeExternalLinks, rehypeHeadingAnchors, rehypeAccessibleTables],
});

const articleSections = await Promise.all(h2Matches.map(async (match, index) => {
  const start = (match.index ?? 0) + match[0].length;
  const end = h2Matches[index + 1]?.index ?? raw.length;
  const markdown = raw.slice(start, end).trim();
  const heading = h2Headings[index];
  const id = heading?.slug ?? `article-${index + 1}`;
  return {
    id,
    title: match[1].trim(),
    html: markdown ? (await processor.render(markdown)).code : '',
    aliases: serviceAliasesForHeading(id),
  };
}));
---

<SiteLayout graph={graph} ogType="website">
  <a class="skip-link" href="#main-content">رفتن به محتوای اصلی</a>
  <div id="top"></div>
  <span id="website" class="anchor-alias" aria-hidden="true"></span>
  <span id="webpage" class="anchor-alias" aria-hidden="true"></span>
  <span id="article" class="anchor-alias" aria-hidden="true"></span>
  <HomeHeader />
  <main id="main-content">
    <Hero />
    <Services />
    <GuideLibrary sections={articleSections} />
    <BestDoctorAnswers />
    <ContactSection />
  </main>
  <HomeFooter />
</SiteLayout>
