---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.mjs';
import { services } from '../data/services.mjs';
---
<BaseLayout title={`${site.personFa} | AstroWind`} description="AstroWind 7 shell on main." canonicalPath="/">
  <section class="box">
    <p class="small">AstroWind 7</p>
    <h1>{site.personFa}</h1>
    <p>سایت روی main به dependency-set آخرین AstroWind و Astro 7 منتقل شده است.</p>
    <p><a class="cta" href="/services/">مشاهده خدمات</a></p>
  </section>
  <section>
    <h2>خدمات اصلی</h2>
    <div class="grid">
      {services.map((service) => (
        <article class="card">
          <h3><a href={`/${service.slug}/`}>{service.title}</a></h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
