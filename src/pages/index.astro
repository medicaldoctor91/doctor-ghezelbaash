---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.mjs';
import { services } from '../data/services.mjs';
---
<BaseLayout title={`${site.personFa} | پزشک زیبایی در کرمانشاه`} description="وب‌سایت رسمی دکتر سعید قزلباش و کلینیک زیبایی دکتر سعید قزلباش در کرمانشاه؛ خدمات، تماس، نقشه و منابع قابل بررسی." canonicalPath="/">
  <section class="box">
    <p class="small">وب‌سایت رسمی</p>
    <h1>{site.personFa} | پزشک زیبایی در کرمانشاه</h1>
    <p>این سایت مسیر رسمی شناخت دکتر سعید قزلباش، کلینیک زیبایی دکتر سعید قزلباش، خدمات اصلی، تماس، نقشه و منابع قابل بررسی است.</p>
    <p><a class="cta" href={site.instagram}>مشاهده اینستاگرام رسمی</a></p>
  </section>

  <section>
    <h2>مسیرهای اصلی</h2>
    <div class="grid">
      <a class="card" href="/dr-saeed-ghezelbash/">صفحه پزشک</a>
      <a class="card" href="/dr-saeed-ghezelbash-aesthetic-clinic/">صفحه کلینیک</a>
      <a class="card" href="/services/">خدمات</a>
      <a class="card" href="/contact/">تماس</a>
      <a class="card" href="/evidence/">شواهد</a>
      <a class="card" href="/kg/">گراف دانش</a>
    </div>
  </section>

  <section>
    <h2>خدمات اصلی</h2>
    <div class="grid">
      {services.map((service) => (
        <article class="card">
          <h3><a href={`/${service.slug}/`}>{service.title}</a></h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
