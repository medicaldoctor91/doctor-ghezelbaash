---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.mjs';
import { services } from '../data/services.mjs';
---
<BaseLayout title={`${site.personFa} | کرمانشاه`} description="وب‌سایت رسمی دکتر سعید قزلباش." canonicalPath="/">
  <section class="box">
    <p class="small">AstroWind + Astro 7</p>
    <h1>{site.personFa}</h1>
    <p>سایت روی main به AstroWind و Astro 7 منتقل شد.</p>
    <p><a class="cta" href="/services/">خدمات</a> <a class="cta-secondary" href="/about/">درباره</a></p>
  </section>
  <section>
    <h2>خدمات</h2>
    <div class="grid">
      {services.map((service) => (
        <article class="card">
          <h3><a href={`/${service.slug}/`}>{service.title}</a></h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
