---
import { getEntry } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import BreadcrumbTrail from '~/components/common/BreadcrumbTrail.astro';

const searchEntry = await getEntry('searchData', 'config');
if (!searchEntry) throw new Error('Missing src/content/search/config.json content collection entry.');

const { metadata, breadcrumbs, quickQueries, copy } = searchEntry.data;
---

<Layout metadata={metadata} pagefindBody={false}>
  <BreadcrumbTrail items={breadcrumbs} />

  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div
      class="rounded-2xl border border-primary/20 bg-primary/5 p-6 md:p-8 shadow-sm dark:bg-slate-900 dark:border-primary/30"
    >
      <p class="text-sm font-bold text-primary mb-3">{copy.eyebrow}</p>
      <h1 class="text-4xl font-bold tracking-tight mb-4">{copy.title}</h1>
      <p class="text-muted leading-8 mb-6">{copy.description}</p>

      <div class="mt-4 flex flex-wrap gap-2" aria-label={copy.quickQueriesLabel}>
        {
          quickQueries.map((query) => (
            <a
              class="rounded-full border border-primary/20 bg-white px-3 py-1.5 text-sm font-medium hover:border-primary hover:text-primary dark:bg-slate-950"
              href={`/search/?q=${encodeURIComponent(query)}`}
            >
              {query}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12">
    <div
      class="rounded-2xl border border-gray-200 bg-white p-6 md:p-8 shadow-sm dark:bg-slate-900 dark:border-slate-800"
    >
      <div class="mb-5 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 class="text-2xl font-bold tracking-tight">{copy.resultsTitle}</h2>
          <p class="mt-2 text-sm text-muted">{copy.initialStatus}</p>
        </div>
        <p class="text-xs text-muted">{copy.sourceLabel}</p>
      </div>

      <div id="pagefind-search" dir="rtl"></div>

      <noscript>
        <p
          class="rounded-xl border border-gray-200 bg-gray-50 p-4 text-sm leading-7 dark:border-slate-800 dark:bg-slate-800"
        >
          {copy.noscript}
        </p>
      </noscript>
    </div>
  </section>

  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (!window.PagefindUI) return;

      new window.PagefindUI({
        element: '#pagefind-search',
        showImages: false,
        showSubResults: true,
        excerptLength: 24,
        translations: {
          placeholder: 'عبارت جست‌وجو را وارد کنید',
          zero_results: 'نتیجه‌ای پیدا نشد.',
          many_results: '[COUNT] نتیجه برای [SEARCH_TERM]',
          one_result: 'یک نتیجه برای [SEARCH_TERM]',
          searching: 'در حال جست‌وجو...',
        },
      });

      const query = new URLSearchParams(window.location.search).get('q');
      if (!query) return;

      const input = document.querySelector('#pagefind-search input');
      if (!(input instanceof HTMLInputElement)) return;

      input.value = query;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    });
  </script>
</Layout>
