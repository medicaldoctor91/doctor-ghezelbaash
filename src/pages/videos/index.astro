---
import SiteLayout from '~/layouts/SiteLayout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import ConversionDock from '~/components/ConversionDock.astro';
import { site } from '~/domain/entities';
import '~/styles/visual-refresh.css';
// @ts-expect-error Canonical ESM media catalogue.
import { videos } from '~/domain/media.mjs';

const canonical = `${site.url}videos/`;
const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': `${canonical}#webpage`,
      url: canonical,
      name: 'مرکز ویدئوهای آموزشی دکتر سعید قزلباش',
      description: 'مجموعه ویدئوهای آموزشی و بالینی درباره تصمیم‌گیری در پزشکی زیبایی، مرز روش‌ها، ایمنی و ارزیابی کاندیداتوری.',
      inLanguage: site.language,
      datePublished: site.datePublished,
      dateModified: site.dateModified,
      isPartOf: { '@id': `${site.url}#website` },
      about: [{ '@id': `${site.url}#person` }, { '@id': `${site.url}#clinic` }],
      breadcrumb: { '@id': `${canonical}#breadcrumb` },
      mainEntity: { '@id': `${canonical}#videos` },
    },
    {
      '@type': 'ItemList',
      '@id': `${canonical}#videos`,
      name: 'فهرست ویدئوهای آموزشی و بالینی',
      numberOfItems: videos.length,
      itemListElement: videos.map((video: any, index: number) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: `${site.url}videos/${video.id}/`,
        name: video.title,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonical}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'راهنمای اصلی پزشکی زیبایی', item: site.url },
        { '@type': 'ListItem', position: 2, name: 'ویدئوها', item: canonical },
      ],
    },
  ],
};
---
<SiteLayout
  graph={graph}
  title="ویدئوهای آموزشی پزشکی زیبایی | دکتر سعید قزلباش"
  description="مجموعه ویدئوهای آموزشی دکتر سعید قزلباش درباره بوتاکس، فیلر، لیفت نخ، اسکار، لک و مرز تصمیم‌های زیبایی."
  canonical={canonical}
>
  <a class="skip-link" href="#video-library">رفتن به فهرست ویدئوها</a>
  <Header navigation={[{ label: 'راهنمای اصلی', href: site.url }]} />
  <main id="video-library" class="watch-page">
    <div class="container watch-card video-library">
      <nav aria-label="مسیر صفحه" class="watch-breadcrumb">
        <a href={site.url}>خانه</a>
        <span aria-hidden="true">←</span>
        <span aria-current="page">ویدئوها</span>
      </nav>

      <header class="watch-header">
        <p class="eyebrow">مرکز ویدئوهای آموزشی و بالینی</p>
        <h1>ویدئوهای دکتر سعید قزلباش درباره تصمیم‌گیری در پزشکی زیبایی</h1>
        <p class="watch-lead">این مجموعه، نمونه‌کار را از آموزش جدا نمی‌کند: هر ویدئو به توضیح موضوع، مرز روش، نکات ایمنی، فصل‌بندی دقیق و صفحه راهنمای مرتبط متصل است.</p>
        <ul class="watch-meta" aria-label="مشخصات مجموعه">
          <li>{videos.length} ویدئو</li>
          <li>فصل‌بندی براساس مدت واقعی فایل</li>
          <li>بازبینی پزشکی</li>
          <li>لینک به راهنماهای مرتبط</li>
        </ul>
      </header>

      <section class="video-library-intro" aria-labelledby="how-to-use-title">
        <h2 id="how-to-use-title">چطور از این مجموعه استفاده کنید؟</h2>
        <p>ابتدا موضوع نزدیک به سؤال خود را انتخاب کنید. در هر صفحه، ویدئو، خلاصه تحریریه‌ای، نکات کلیدی، مرز ایمنی و پرسش‌های مرتبط کنار هم قرار گرفته‌اند. محتوای این مجموعه عمومی است و برای انتخاب درمان شخصی باید معاینه انجام شود.</p>
      </section>

      <div class="video-library-grid">
        {videos.map((video: any) => (
          <article class="video-library-card">
            <a href={`/videos/${video.id}/`}>
              <img src={video.thumbnail} alt="" width="270" height="480" loading="lazy" decoding="async" />
              <div>
                <p class="eyebrow">ویدئوی {video.durationSeconds} ثانیه‌ای</p>
                <h2>{video.title}</h2>
                <p>{video.description}</p>
                <ul aria-label="موضوعات">
                  {video.tags.slice(0, 3).map((tag: string) => <li>{tag}</li>)}
                </ul>
                <span class="watch-primary-link">مشاهده ویدئو و توضیحات کامل</span>
              </div>
            </a>
          </article>
        ))}
      </div>

      <aside class="watch-return">
        <strong>برای تصمیم کامل‌تر</strong>
        <span><a href={site.url}>بازگشت به راهنمای جامع پزشکی زیبایی</a></span>
      </aside>
    </div>
  </main>
  <ConversionDock />
  <Footer />
</SiteLayout>
