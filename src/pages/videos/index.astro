---
import Layout from '~/layouts/PageLayout.astro';
import BreadcrumbTrail from '~/components/common/BreadcrumbTrail.astro';
import { groupWatchVideosByPage } from '~/data/videoCatalog';

const groups = groupWatchVideosByPage();
const allVideos = groups.flatMap((group) => group.videos);

const metadata = {
  title: 'ویدئوهای دکتر سعید قزلباش',
  ignoreTitleTemplate: true,
  canonical: 'https://www.ghezelbaash.ir/videos/',
  description:
    'فهرست همه ویدئوهای سایت دکتر سعید قزلباش با صفحه اختصاصی برای هر ویدئو، متن قابل‌خزش، بخش‌بندی زمانی و ارتباط روشن با صفحه مادر.',
  openGraph: {
    type: 'website',
    images: [{ url: '/og/home.jpg', width: 1200, height: 630 }],
  },
};

const itemListGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': 'https://www.ghezelbaash.ir/videos/#webpage',
      url: 'https://www.ghezelbaash.ir/videos/',
      name: 'ویدئوهای دکتر سعید قزلباش',
      description:
        'فهرست متمرکز ویدئوهای سایت دکتر سعید قزلباش با صفحات اختصاصی و قابل‌خزش برای هر ویدئو.',
      inLanguage: 'fa-IR',
      isPartOf: { '@id': 'https://www.ghezelbaash.ir/#website' },
      about: [{ '@id': 'https://www.ghezelbaash.ir/#dr-saeed-ghezelbash' }, { '@id': 'https://www.ghezelbaash.ir/#clinic' }],
      mainEntity: { '@id': 'https://www.ghezelbaash.ir/videos/#itemlist' },
    },
    {
      '@type': 'ItemList',
      '@id': 'https://www.ghezelbaash.ir/videos/#itemlist',
      itemListOrder: 'https://schema.org/ItemListOrderAscending',
      numberOfItems: allVideos.length,
      itemListElement: allVideos.map((video, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: video.watchUrl,
        name: video.title,
      })),
    },
  ],
};

const itemListJson = JSON.stringify(itemListGraph).replace(/</g, '\u003c');
---

<Layout metadata={metadata}>
  <script type="application/ld+json" is:inline set:html={itemListJson} />

  <BreadcrumbTrail items={[{ name: 'خانه', href: '/' }, { name: 'ویدئوها' }]} />

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <p class="text-sm font-bold text-primary">Video hub</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight md:text-5xl">کتابخانه ویدئویی دکتر سعید قزلباش</h1>
      <p class="mt-4 max-w-4xl text-base leading-8 text-muted">
        این هاب برای هر ویدئو یک صفحه مستقل، قابل‌خزش و قابل‌ارجاع می‌دهد تا ویدئو فقط یک المان جانبی داخل مگاپیلارها
        نباشد و خودش هم صفحه، URL، متن، بخش‌بندی و زمینه مشخص داشته باشد.
      </p>

      <dl class="mt-8 grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-gray-200 p-4 dark:border-slate-800">
          <dt class="text-xs font-bold text-primary">تعداد watch page</dt>
          <dd class="mt-2 text-sm font-semibold text-default">{allVideos.length} صفحه مستقل ویدئویی</dd>
        </div>
        <div class="rounded-2xl border border-gray-200 p-4 dark:border-slate-800">
          <dt class="text-xs font-bold text-primary">خوشه‌های موضوعی</dt>
          <dd class="mt-2 text-sm font-semibold text-default">{groups.length} صفحه مادر و ۶ خوشه محتوایی</dd>
        </div>
        <div class="rounded-2xl border border-gray-200 p-4 dark:border-slate-800">
          <dt class="text-xs font-bold text-primary">اتصال entity</dt>
          <dd class="mt-2 text-sm font-semibold text-default">همه ویدئوها به دکتر، کلینیک و صفحه مادر متصل‌اند.</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <div class="space-y-8">
      {groups.map((group) => (
        <section class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-sm font-bold text-primary">Source page</p>
              <h2 class="mt-2 text-2xl font-bold tracking-tight">{group.pageLabel}</h2>
              <p class="mt-2 text-sm leading-7 text-muted">{group.videos.length} watch page از این صفحه مادر تغذیه می‌شود.</p>
            </div>
            <a class="text-sm font-semibold text-primary hover:text-secondary" href={group.pagePath}>
              رفتن به صفحه مادر
            </a>
          </div>

          <div class="mt-6 grid gap-5 lg:grid-cols-2">
            {group.videos.map((video) => (
              <article class="overflow-hidden rounded-2xl border border-gray-200 dark:border-slate-800">
                <a href={video.watchPath} class="block">
                  <img
                    src={video.thumbnailUrl}
                    alt={video.title}
                    loading="lazy"
                    width={video.layoutWidth}
                    height={video.layoutHeight}
                    class="aspect-video w-full object-cover"
                  />
                </a>
                <div class="p-5">
                  <p class="text-xs font-bold text-primary">{video.duration} · {video.sourcePageLabel}</p>
                  <h3 class="mt-2 text-xl font-bold">
                    <a href={video.watchPath} class="hover:text-primary">{video.title}</a>
                  </h3>
                  <p class="mt-3 text-sm leading-7 text-muted">{video.description}</p>
                  <div class="mt-4 flex flex-wrap gap-3">
                    <a href={video.watchPath} class="text-sm font-semibold text-primary hover:text-secondary">
                      ورود به watch page
                    </a>
                    <a href={video.sourceSectionPath} class="text-sm font-semibold text-primary hover:text-secondary">
                      جایگاه در صفحه مادر
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</Layout>
