---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services } from '../data/services.mjs';
---
<BaseLayout title="خدمات | دکتر سعید قزلباش" description="هاب خدمات زیبایی." canonicalPath="/services/">
  <section class="box">
    <p class="small">خدمات</p>
    <h1>خدمات</h1>
    <p>چهار صفحه پیلار نهایی سایت.</p>
    <p><a class="cta" href="/contact/">تماس</a></p>
  </section>
  <section>
    <div class="grid">
      {services.map((service) => (
        <article class="card">
          <h3><a href={`/${service.slug}/`}>{service.title}</a></h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
