---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services } from '../data/services.mjs';
---
<BaseLayout title="Services | Dr. Saeed Ghezelbaash" description="Services hub." canonicalPath="/services/">
  <section class="box">
    <p class="small">Services</p>
    <h1>Services</h1>
    <p>Four final pillar routes.</p>
    <p><a class="cta" href="/contact/">Contact</a></p>
  </section>
  <section>
    <div class="grid">
      {services.map((service) => (
        <article class="card">
          <h3><a href={`/${service.slug}/`}>{service.title}</a></h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
