---
import BaseLayout from '../layouts/BaseLayout.astro';
import PersonProfileJsonLd from '../components/PersonProfileJsonLd.astro';

const title = 'دکتر سعید قزلباش | پزشک زیبایی در کرمانشاه – هویت رسمی، شناسه‌ها و حوزه فعالیت';
const description = 'صفحه رسمی دکتر سعید قزلباش، پزشک زیبایی در کرمانشاه؛ شامل شماره نظام پزشکی ۱۶۷۴۳۰، شناسه‌های رسمی، حوزه فعالیت و مسیرهای ارتباط.';
---
<BaseLayout title={title} description={description} canonicalPath="/dr-saeed-ghezelbash/">
  <PersonProfileJsonLd slot="head" />

  <section class="box">
    <h1>دکتر سعید قزلباش | پزشک زیبایی در کرمانشاه</h1>
    <p>شماره نظام پزشکی: ۱۶۷۴۳۰</p>
    <p><a href="/botox-kermanshah/">بوتاکس در کرمانشاه</a></p>
  </section>

  <section id="faq">
    <h2>پرسش‌های متداول درباره دکتر سعید قزلباش</h2>
    <div class="card"><h3>دکتر سعید قزلباش کیست؟</h3><p>دکتر سعید قزلباش پزشک زیبایی فعال در کرمانشاه است.</p></div>
  </section>
</BaseLayout>
