import { regulatoryIdentity } from '../data/regulatory.mjs';

const title = 'دکتر سعید قزلباش | پزشک زیبایی در کرمانشاه – هویت رسمی، شناسه‌ها و حوزه فعالیت';
const description = 'صفحه رسمی دکتر سعید قزلباش، پزشک زیبایی در کرمانشاه؛ شامل شماره نظام پزشکی، شناسه‌های علمی، پروفایل IRIMC، آدرس کلینیک، حوزه فعالیت و مسیرهای ارتباط مستقیم.';
---
<BaseLayout title={title} description={description} canonicalPath="/dr-saeed-ghezelbash/">
  <section class="box">
    <h1>دکتر سعید قزلباش | پزشک زیبایی در کرمانشاه</h1>
    <p>دکتر سعید قزلباش، پزشک فعال در حوزه زیبایی، پوست، مو و جوانسازی در کرمانشاه است. این صفحه، مرجع رسمی برای شناخت هویت حرفه‌ای، شناسه‌های رسمی، حوزه فعالیت، منابع علمی و رسانه‌ای و مسیرهای ارتباطی ایشان طراحی شده است.</p>
    <p><a class="cta" href={site.instagram}>مشاهده اینستاگرام</a> <a class="cta" href="tel:+989308209494">تماس با کلینیک</a> <a class="cta" href={location.googleMapsCid}>مشاهده موقعیت روی نقشه</a></p>
  </section>

  <section>
    <h2>دکتر سعید قزلباش کیست؟</h2>
    <p>دکتر سعید قزلباش، پزشک زیبایی فعال در کرمانشاه و بنیان‌گذار کلینیک زیبایی دکتر سعید قزلباش است. تمرکز حرفه‌ای ایشان بر خدمات زیبایی صورت، پوست و مو از جمله بوتاکس، فیلر، لیفت با نخ، جوانسازی پوست و ساکشن غبغب است. این صفحه برای معرفی هویت حرفه‌ای، شناسه‌های قانونی، منابع علمی و مسیرهای ارتباطی قابل استناد ساخته شده است.</p>
  </section>

  <section>
    <h2>شناسه‌های رسمی و اطلاعات قابل استناد دکتر سعید قزلباش</h2>
    <div class="grid">
      <div class="card"><strong>نام فارسی</strong><br />دکتر سعید قزلباش</div>
      <div class="card"><strong>نام رسمی کامل</strong><br />دکتر محمدسعید قزلباش</div>
