      <div class="card"><strong>استعلام پروانه</strong><br /><a href={regulatoryIdentity.mojavez.url}>کد رهگیری Mojavez</a></div>
      <div class="card"><strong>ORCID</strong><br /><a href={researchProfile.orcid}>0009-0001-9346-8475</a></div>
      <div class="card"><strong>NCBI</strong><br /><a href={researchProfile.bibliographyUrl}>کتاب‌شناسی عمومی</a></div>
