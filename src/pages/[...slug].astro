---
import { getCollection, getEntry, render } from 'astro:content';
import PageEntityDefinitionBlock from '~/components/common/PageEntityDefinitionBlock.astro';
import PageFreshnessBlock from '~/components/common/PageFreshnessBlock.astro';
import PageVideoTranscriptBlock from '~/components/common/PageVideoTranscriptBlock.astro';
import PageEvidenceBlock from '~/components/common/PageEvidenceBlock.astro';
import Layout from '~/layouts/PageLayout.astro';
import BreadcrumbTrail from '~/components/common/BreadcrumbTrail.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import ContentContactBox from '~/components/common/ContentContactBox.astro';
import PageFaq from '~/components/common/PageFaq.astro';
import GoogleMapsRatingBadge from '~/components/common/GoogleMapsRatingBadge.astro';
import PageMediaBlock from '~/components/common/PageMediaBlock.astro';
import PageTrustBlock from '~/components/common/PageTrustBlock.astro';
import { getContactData, getPageMedia, getPageUiData, resolveContentActions } from '~/utils/contentData';
import { getUiCopy } from '~/utils/uiCopy';

type Props = {
  pagePath: string;
};

export async function getStaticPaths() {
  const entries = await getCollection('pageUi');
  return entries.map((entry) => {
    const pathname = entry.data.path === '/' ? undefined : entry.data.path.replace(/^\//, '').replace(/\/$/, '');
    return {
      params: { slug: pathname },
      props: { pagePath: entry.data.path },
    };
  });
}

const { pagePath } = Astro.props as Props;
const contactData = await getContactData();
const pageUi = await getPageUiData(pagePath);
const uiCopy = await getUiCopy<{ pageContextLabel: string }>();
const pageMedia = await getPageMedia(pagePath);
const entry = await getEntry('pages', pageUi.contentEntry);
if (!entry) throw new Error(`Missing content collection entry for ${pageUi.contentEntry}.`);
const { Content } = await render(entry);

const metadata = {
  title: entry.data.title,
  ignoreTitleTemplate: pageUi.layout === 'home',
  canonical: entry.data.canonical,
  description: entry.data.description,
  openGraph: { images: [{ url: entry.data.ogImagePath, width: 1200, height: 630 }] },
};

const heroActions = resolveContentActions(pageUi.hero.actions, contactData);
const ctaActions = pageUi.cta ? resolveContentActions(pageUi.cta.actions, contactData) : [];
const mediaBlockTitle = pageUi.mediaBlock?.title;
const mediaBlockSubtitle = pageUi.mediaBlock?.subtitle;
---

<Layout metadata={metadata}>
  {pageUi.showBreadcrumbs && pageUi.breadcrumbs && <BreadcrumbTrail items={pageUi.breadcrumbs} />}

  <Hero
    tagline={pageUi.hero.tagline}
    title={pageUi.hero.title}
    subtitle={pageUi.hero.subtitle}
    actions={heroActions}
    image={{ src: pageMedia.heroImage, alt: pageMedia.heroAlt }}
  />

  {
    pageUi.showRating && (
      <section id="google-maps-rating" class="max-w-5xl mx-auto px-4 sm:px-6 pb-4">
        <GoogleMapsRatingBadge />
      </section>
    )
  }

  <PageFreshnessBlock path={pagePath} />

  <PageMediaBlock path={pagePath} title={mediaBlockTitle} subtitle={mediaBlockSubtitle} />

  <PageEntityDefinitionBlock path={pagePath} />

  {
    pageUi.showBreadcrumbs && pageUi.breadcrumbs && (
      <section id="page-context" class="max-w-5xl mx-auto px-4 sm:px-6 pb-8">
        <div class="rounded-2xl border border-gray-200 bg-white p-5 md:p-6 shadow-sm dark:bg-slate-900 dark:border-slate-800">
          <p class="text-muted leading-8">
            {uiCopy.pageContextLabel}{' '}
            {pageUi.breadcrumbs.map((item, index) => (
              <Fragment>
                {index > 0 && <span class="px-1">—</span>}
                {item.href ? (
                  <a class="hover:text-primary" href={item.href}>
                    {item.name}
                  </a>
                ) : (
                  <span class="font-semibold text-default">{item.name}</span>
                )}
              </Fragment>
            ))}
          </p>
        </div>
      </section>
    )
  }

  {
    pageUi.showIntentHub && pageUi.intentHub && (
      <section id="intent-hub" class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
        <div class="rounded-2xl border border-primary/20 bg-primary/5 p-6 md:p-8 shadow-sm dark:bg-slate-900 dark:border-primary/30">
          <h2 class="text-3xl font-bold tracking-tight mb-4">{pageUi.intentHub.title}</h2>
          <p class="text-muted leading-8 mb-6">{pageUi.intentHub.description}</p>
          <div class="grid gap-4 md:grid-cols-2">
            {pageUi.intentHub.links.map((item) => (
              <a
                class="rounded-xl bg-white p-4 shadow-sm hover:bg-gray-50 dark:bg-slate-800 dark:hover:bg-slate-700"
                href={item.href}
              >
                <strong>{item.title}</strong>
                <span class="block text-sm text-muted mt-2">{item.description}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section id="page-main-content" class="max-w-5xl mx-auto px-4 sm:px-6 py-8 lg:py-16">
    <article
      class="prose prose-lg max-w-none dark:prose-invert prose-headings:font-heading prose-headings:font-bold prose-headings:tracking-tight prose-headings:leading-tight prose-headings:scroll-mt-24 prose-h2:mt-12 prose-h2:text-3xl prose-h3:mt-8 prose-h3:text-2xl prose-p:leading-9 prose-li:leading-8 prose-a:text-primary hover:prose-a:text-secondary prose-blockquote:border-primary prose-blockquote:text-muted prose-table:text-right prose-th:text-right prose-td:text-right prose-table:text-sm leading-8"
    >
      <Content />
    </article>
  </section>

  <PageVideoTranscriptBlock path={pagePath} />

  <PageEvidenceBlock path={pagePath} />

  {pageUi.showFaq && <PageFaq path={pagePath} />}

  {pageUi.showTrust && <PageTrustBlock pageTitle={pageUi.pageTrustTitle} />}

  <ContentContactBox title={pageUi.contactBox.title} subtitle={pageUi.contactBox.subtitle} />

  {pageUi.cta && <CallToAction title={pageUi.cta.title} subtitle={pageUi.cta.subtitle} actions={ctaActions} />}
</Layout>
