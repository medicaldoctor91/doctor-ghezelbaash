---
import { getUiCopy } from '~/utils/uiCopy';

const uiCopy = await getUiCopy<{ faviconTitle: string }>();
---

<link rel="icon" type="image/svg+xml" href="/logo.svg" title={uiCopy.faviconTitle} />
<link rel="alternate icon" type="image/png" sizes="192x192" href="/assets/brand/doctor-ghezelbaash-logo-192.png" />
<link rel="apple-touch-icon" sizes="192x192" href="/assets/brand/doctor-ghezelbaash-logo-192.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#e86d17" />
