---
import { BadgeCheck, Bot, Braces, Database, ExternalLink, FileJson, Network, Search, ShieldCheck } from '@lucide/astro';
import { site } from '~/domain/entities';

const resources = [
  { name: 'Canonical Knowledge Graph', path: '/knowledge-graph.jsonld', format: 'JSON-LD', description: 'گراف کامل و self-contained انتیتی پزشک، کلینیک، خدمات، شواهد، پژوهش و رسانه.' },
  { name: 'Compact AI context', path: '/context.json', format: 'JSON', description: 'نمای فشردهٔ انتیتی، پوشش خدمات و مسیرهای discovery.' },
  { name: 'AI summary', path: '/ai/summary.json', format: 'JSON', description: 'خلاصهٔ هویت و قواعد تفسیر برای مصرف کم‌هزینه.' },
  { name: 'AI FAQ', path: '/ai/faq.json', format: 'JSON', description: 'پرسش‌وپاسخ‌های مشتق از محتوای visible همین صفحه.' },
  { name: 'LLM index', path: '/llms.txt', format: 'TEXT', description: 'نقطهٔ شروع متنی برای crawler و agent.' },
  { name: 'Full visible text', path: '/llms-full.txt', format: 'TEXT', description: 'آینهٔ متنی محتوای canonical صفحه.' },
];

const retrieval = [
  { name: 'Retrieval index', path: '/search/index.json', description: 'فهرست shardهای corpus برای بازیابی deterministic؛ خارج از semantic graph.' },
  { name: 'Answer units', path: '/answers/index.json', description: 'واحدهای پاسخ با source span و hash.' },
  { name: 'Intent index', path: '/intents/index.json', description: 'کنترل search intent و reverse lookup.' },
  { name: 'Evidence sources', path: '/evidence/sources.json', description: 'منابع بیرونی و دامنهٔ پشتیبانی هر claim.' },
  { name: 'Internal provenance', path: '/evidence/internal-provenance.json', description: 'ردیابی مشتق‌سازی، span و digest محتوای داخلی.' },
  { name: 'Media integrity', path: '/media/index.json', description: 'فهرست تصاویر و ویدئوها با metadata و SHA-256.' },
];

const identityLinks = [
  { label: `IRIMC ${site.irimc}`, href: site.irimcVerification },
  { label: `ORCID ${site.orcid}`, href: site.orcidUrl },
  { label: `Physician Wikidata ${site.doctorWikidataId}`, href: site.doctorWikidata },
  { label: `Clinic Wikidata ${site.placeWikidataId}`, href: site.placeWikidata },
  { label: `Physician Google KG ${site.doctorGoogleKnowledgeGraphId}`, href: site.doctorGoogleKnowledgeGraphUrl },
  { label: `Clinic Google Local KG ${site.clinicGoogleLocalKnowledgeGraphId}`, href: site.clinicGoogleLocalKnowledgeGraphUrl },
];
---
<section id="knowledge-resources" class="knowledge-resources authority-panel" aria-labelledby="knowledge-resources-title" lang="fa-IR">
  <header class="panel-heading knowledge-heading">
    <span class="eyebrow"><Braces size={18} />Knowledge &amp; AI</span>
    <h2 id="knowledge-resources-title">گراف دانش، شناسه‌های انتیتی و منابع Retrieval</h2>
    <p>یک semantic graph کامل برای فهم رابطه‌ها؛ یک retrieval corpus جدا برای جست‌وجو. فایل manifest و graph shard حذف شده‌اند تا هیچ منبعی روایت رقیب دربارهٔ گراف نسازد.</p>
  </header>

  <div id="knowledge-identity" class="knowledge-identity-grid">
    <article>
      <BadgeCheck size={22} />
      <h3>انتیتی محوری: پزشک</h3>
      <code>{site.url}#person</code>
      <p>{site.legalName} تنها <bdi dir="ltr">mainEntity</bdi> صفحه است. کلینیک از طریق <bdi dir="ltr">worksFor</bdi> و <bdi dir="ltr">workLocation</bdi> به پزشک متصل می‌شود.</p>
    </article>
    <article>
      <Network size={22} />
      <h3>انتیتی مستقل: کلینیک</h3>
      <code>{site.url}#clinic</code>
      <p>کلینیک نقش <bdi dir="ltr">provider / publisher / workLocation</bdi> دارد؛ شناسهٔ Google Local آن وارد شناسه‌های Person نمی‌شود.</p>
    </article>
    <article>
      <Database size={22} />
      <h3>Canonical graph</h3>
      <code>/knowledge-graph.jsonld</code>
      <p>فایل واحد، self-describing و self-contained؛ Schema صفحه projection فشردهٔ همین مدل و با همان <bdi dir="ltr">@id</bdi>هاست.</p>
    </article>
  </div>

  <nav class="knowledge-verification-links" aria-label="شناسه‌های رسمی و بیرونی">
    {identityLinks.map((item) => (
      <a href={item.href} target="_blank" rel="noopener noreferrer external">
        <span>{item.label}</span><ExternalLink size={15} aria-hidden="true" />
      </a>
    ))}
  </nav>

  <div class="knowledge-resource-columns">
    <section aria-labelledby="semantic-resources-title">
      <header><FileJson size={21} /><div><h3 id="semantic-resources-title">Semantic و discovery</h3><p>هویت، رابطه‌ها و نمایش‌های فشرده.</p></div></header>
      <div class="knowledge-resource-list">
        {resources.map((resource) => (
          <a href={resource.path}>
            <span><strong>{resource.name}</strong><code>{resource.path}</code><small>{resource.description}</small></span>
            <bdi dir="ltr">{resource.format}</bdi>
          </a>
        ))}
      </div>
    </section>

    <section id="knowledge-retrieval" aria-labelledby="retrieval-resources-title">
      <header><Search size={21} /><div><h3 id="retrieval-resources-title">Retrieval و evidence</h3><p>دارایی‌های حجیم برای lookup؛ نه shard گراف.</p></div></header>
      <div class="knowledge-resource-list">
        {retrieval.map((resource) => (
          <a href={resource.path}>
            <span><strong>{resource.name}</strong><code>{resource.path}</code><small>{resource.description}</small></span>
            <bdi dir="ltr">JSON</bdi>
          </a>
        ))}
      </div>
    </section>
  </div>

  <div class="knowledge-rule-grid">
    <article><ShieldCheck size={21} /><div><h3>قاعدهٔ منبع</h3><p>محتوای visible همین صفحه منبع اصلی است؛ graph و retrieval از آن مشتق می‌شوند.</p></div></article>
    <article><Bot size={21} /><div><h3>قاعدهٔ تفسیر خدمت</h3><p><bdi dir="ltr">offered</bdi>، <bdi dir="ltr">evaluated</bdi> و <bdi dir="ltr">referral-context</bdi> سه رابطهٔ متفاوت‌اند و قابل ادغام نیستند.</p></div></article>
  </div>

  <div class="knowledge-dataset">
    <Database size={22} />
    <div><h3>Published entity dataset</h3><p>نسخهٔ منتشرشدهٔ داده با شناسهٔ پایدار مستقل از فایل graph سایت.</p></div>
    <a href={site.huggingFaceDataset} target="_blank" rel="noopener noreferrer external">Hugging Face <ExternalLink size={15} /></a>
    <a href={site.zenodoRecord} target="_blank" rel="noopener noreferrer external">Zenodo <ExternalLink size={15} /></a>
    <a href={site.datasetWikidata} target="_blank" rel="noopener noreferrer external">Wikidata {site.datasetWikidataId} <ExternalLink size={15} /></a>
  </div>
</section>
