---
const {
  eyebrow,
  title,
  lead,
  body = [],
  actions = [],
  facts = [],
  variant = 'default'
} = Astro.props;
---
<section class={`hero-panel hero-panel--${variant}`}>
  <div class="hero-copy">
    {eyebrow && <p class="small hero-eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {lead && <p class="lead">{lead}</p>}
    {body.map((paragraph) => <p>{paragraph}</p>)}
    {actions.length > 0 && (
      <p class="hero-actions">
        {actions.map((action, index) => (
          <>
            <a class={action.primary ? 'cta' : 'cta-secondary'} href={action.href}>{action.label}</a>
            {index < actions.length - 1 && ' '}
          </>
        ))}
      </p>
    )}
  </div>
  {facts.length > 0 && (
    <aside class="hero-aside card">
      <h2>اطلاعات سریع</h2>
      <div class="fact-list">
        {facts.map((item) => (
          <div class="fact-item"><strong>{item.label}</strong><br />{item.value}</div>
        ))}
      </div>
    </aside>
  )}
</section>
