---
interface Props {
  name?: string;
  class?: string;
  title?: string;
}

const { name = 'brand-mark', class: className = 'h-5 w-5', title } = Astro.props;
const normalizedName = name.replace(/^tabler:/, '');
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  role={title ? 'img' : undefined}
  aria-label={title}
  aria-hidden={title ? undefined : 'true'}
>
  {title && <title>{title}</title>}
  {
    normalizedName === 'chevron-down' ? (
      <path d="m6 9 6 6 6-6" />
    ) : normalizedName === 'rss' ? (
      <>
        <path d="M4 11a9 9 0 0 1 9 9" />
        <path d="M4 4a16 16 0 0 1 16 16" />
        <circle cx="5" cy="19" r="1" fill="currentColor" stroke="none" />
      </>
    ) : normalizedName === 'sun' ? (
      <>
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2" />
        <path d="M12 20v2" />
        <path d="m4.93 4.93 1.41 1.41" />
        <path d="m17.66 17.66 1.41 1.41" />
        <path d="M2 12h2" />
        <path d="M20 12h2" />
        <path d="m6.34 17.66-1.41 1.41" />
        <path d="m19.07 4.93-1.41 1.41" />
      </>
    ) : normalizedName === 'moon' ? (
      <path d="M20.99 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 20.99 12.79z" />
    ) : normalizedName === 'brand-instagram' ? (
      <>
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="3.5" />
        <circle cx="17.5" cy="6.5" r=".7" fill="currentColor" stroke="none" />
      </>
    ) : normalizedName === 'map-pin' ? (
      <>
        <path d="M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 1 1 16 0Z" />
        <circle cx="12" cy="10" r="3" />
      </>
    ) : (
      <>
        <circle cx="12" cy="8" r="4" fill="currentColor" stroke="none" opacity="0.96" />
        <path d="M5 21c1.9-4.2 4.2-6.2 7-6.2s5.1 2 7 6.2" />
      </>
    )
  }
</svg>
