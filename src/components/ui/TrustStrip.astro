---
const { items = [] } = Astro.props;
---
{items.length > 0 && (
  <section class="trust-strip" aria-label="سیگنال‌های اعتماد">
    {items.map((item) => (
      <div class="trust-item">
        <span class="trust-kicker">{item.kicker}</span>
        <strong>{item.value}</strong>
      </div>
    ))}
  </section>
)}
