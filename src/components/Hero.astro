---
import { clinic } from '../data/clinic';
import { doctor } from '../data/doctor';
import { googleMapsEvidence } from '../data/evidence';
import type { AssetManifest } from '../utils/graph';
interface Props { assets: AssetManifest; }
const { assets } = Astro.props;
const hero = assets.images['doctor-portrait'];
const source = hero?.webp ?? hero?.fallback ?? hero?.avif;
const heroSizes = '(max-width: 62rem) 100vw, 48vw';
const srcset = (variants: Array<{ src: string; width: number }> | undefined) =>
  variants?.map((variant) => `${variant.src} ${variant.width}w`).join(', ');
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <div class="hero__ambient hero__ambient--one" aria-hidden="true"></div>
  <div class="hero__ambient hero__ambient--two" aria-hidden="true"></div>

  <div class="hero__copy">
    <div class="hero__kicker">
      <span class="hero__kicker-line" aria-hidden="true"></span>
      صفحه رسمی دکتر سعید قزلباش
    </div>
    <h1 id="hero-title">
      زیبایی وقتی دقیق است که
      <span>از تشخیص شروع شود.</span>
    </h1>
    <div class="hero__lead content-slot"><slot /></div>

    <div class="hero__actions">
      <a class="button button--primary" href={`tel:${clinic.telephone}`}>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.2 3.5 10 7.7 8.5 9.2c.8 1.8 2.3 3.3 4.1 4.1l1.5-1.5 4.3 2.8-.8 3.6c-.2.8-.9 1.3-1.7 1.3A13.5 13.5 0 0 1 4.5 8.1c0-.8.5-1.5 1.3-1.7l1.4-2.9Z" /></svg>
        تماس با کلینیک
      </a>
      <a class="button button--ghost" href={clinic.mapsUrl} rel="noopener noreferrer">
        مشاهده مسیر
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7" /></svg>
      </a>
    </div>

    <div class="hero__proof" aria-label="اطلاعات اعتبارسنجی">
      <div><strong>۱۶۷۴۳۰</strong><span>شماره نظام پزشکی</span></div>
      <div><strong>{googleMapsEvidence.ratingDisplay}</strong><span>امتیاز Google Maps</span></div>
      <div><strong>{googleMapsEvidence.reviewCountDisplay}</strong><span>ارزیابی ثبت‌شده</span></div>
    </div>
  </div>

  <div class="hero__visual">
    <div class="hero__frame">
      {source ? (
        <picture id="image-doctor-portrait">
          {hero.avif && <source srcset={srcset(hero.avifSrcset) ?? hero.avif} sizes={heroSizes} type="image/avif" />}
          {hero.webp && <source srcset={srcset(hero.webpSrcset) ?? hero.webp} sizes={heroSizes} type="image/webp" />}
          <img src={hero.fallback ?? source} srcset={srcset(hero.fallbackSrcset)} sizes={heroSizes} alt={hero.alt ?? doctor.publicName} width={hero.width} height={hero.height} loading="eager" decoding="async" fetchpriority="high" />
        </picture>
      ) : (
        <div class="hero__image-placeholder" role="img" aria-label={doctor.publicName}>دکتر سعید قزلباش</div>
      )}
      <div class="hero__image-shade" aria-hidden="true"></div>
      <div class="hero__signature">
        <small>پزشک مسئول</small>
        <strong>{doctor.publicName}</strong>
        <span>کرمانشاه</span>
      </div>
    </div>

    <div class="hero__rating-card">
      <span class="rating-stars" aria-label="پنج ستاره">★★★★★</span>
      <strong>امتیاز کامل مراجعه‌کنندگان</strong>
      <small>
        بر پایه {googleMapsEvidence.reviewCountDisplay} ارزیابی در Google Maps · مشاهده در{' '}
        <time datetime={googleMapsEvidence.observedAt}>{googleMapsEvidence.observedAtDisplay}</time>
      </small>
    </div>

    <div class="hero__principle-card">
      <span aria-hidden="true">۰۱</span>
      <p>اول مکانیسم مسئله؛ بعد انتخاب ابزار.</p>
    </div>
  </div>
</section>
