---
import { clinic } from '../data/clinic';
import { doctorContactUrls } from '../data/doctor';
---

<nav class="floating-actions" aria-label="تماس برای رزرو، گفت‌وگوی آنلاین و مسیر کلینیک">
  <a
    class="floating-actions__item floating-actions__booking"
    href={`tel:${clinic.telephone}`}
    aria-label="تماس مستقیم برای رزرو زمان مراجعه"
  >
    <span class="floating-actions__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24"><path d="M7.2 3.5 10 7.7 8.5 9.2c.8 1.8 2.3 3.3 4.1 4.1l1.5-1.5 4.3 2.8-.8 3.6c-.2.8-.9 1.3-1.7 1.3A13.5 13.5 0 0 1 4.5 8.1c0-.8.5-1.5 1.3-1.7l1.4-2.9Z" /></svg>
    </span>
    <span class="floating-actions__copy">
      <strong>تماس برای رزرو</strong>
      <small>تماس مستقیم با کلینیک</small>
    </span>
  </a>

  <a
    class="floating-actions__item floating-actions__chat"
    href={doctorContactUrls.instagramDirect}
    rel="noopener noreferrer external"
    aria-label="گفت‌وگوی آنلاین با دکتر سعید قزلباش در دایرکت اینستاگرام"
  >
    <span class="floating-actions__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24"><rect x="3.5" y="3.5" width="17" height="17" rx="5" /><circle cx="12" cy="12" r="3.5" /><path d="M17.6 6.4h.01" /></svg>
    </span>
    <span class="floating-actions__copy">
      <strong><span class="floating-actions__full-label">گفت‌وگوی آنلاین با دکتر سعید قزلباش</span><span class="floating-actions__short-label">گفت‌وگو با دکتر</span></strong>
      <small>دایرکت اینستاگرام</small>
    </span>
  </a>

  <a
    class="floating-actions__item floating-actions__address"
    href={clinic.mapsUrl}
    rel="noopener noreferrer external"
    aria-label="مشاهده آدرس کلینیک در Google Maps"
  >
    <span class="floating-actions__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24"><path d="M12 21s6-5.3 6-12A6 6 0 1 0 6 9c0 6.7 6 12 6 12Z" /><circle cx="12" cy="9" r="2.35" /></svg>
    </span>
    <span class="floating-actions__copy">
      <strong>آدرس کلینیک</strong>
      <small>مسیریابی با Google Maps</small>
    </span>
  </a>

  <a class="floating-actions__top" href="#top" aria-label="رفتن به ابتدای صفحه" title="ابتدای صفحه">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6.5 13.5 5.5-5 5.5 5M12 8.5V20M6 4h12" /></svg>
    <span>بالا</span>
  </a>
</nav>
