---
import { AtSign, MapPin, Phone, ArrowUp, Mail, Braces, Video } from '@lucide/astro';
import { site } from '~/domain/entities';
const year = new Date().getFullYear();
const modified = new Intl.DateTimeFormat('fa-IR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(`${site.dateModified}T12:00:00+03:30`));
const topHref = Astro.url.pathname === '/' ? '#top' : `${site.url}#top`;
---
<footer class="site-footer">
  <div class="container footer-grid">
    <section aria-label="معرفی پزشک">
      <div class="footer-brand-lockup">
        <span class="footer-brand-mark" aria-hidden="true">
          <img src="/assets/brand/doctor-ghezelbaash-logo-192.png" alt="" width="192" height="192" loading="lazy" decoding="async" />
        </span>
        <strong class="footer-title">{site.legalName}</strong>
      </div>
      <p>دکترای حرفه‌ای پزشکی · شمارهٔ نظام پزشکی {site.irimc}</p>
      <p>پزشکی زیبایی، پوست و مو؛ تشخیص پیش از مداخله و تعیین روشن مرز درمان و ارجاع.</p>
    </section>
    <nav aria-label="ارتباط با کلینیک">
      <strong class="footer-title">ارتباط و مراجعه</strong>
      <a href={`tel:${site.phone}`} class="phone-link"><Phone size={18}/><bdi dir="ltr">{site.phoneDisplay}</bdi></a>
      <a href={`mailto:${site.email}`}><Mail size={18}/><bdi dir="ltr">{site.email}</bdi></a>
      <a href={site.maps} target="_blank" rel="noopener noreferrer external"><MapPin size={18}/>مسیریابی در Google Maps</a>
      <a href={site.instagram} target="_blank" rel="me noopener noreferrer external"><AtSign size={18}/>صفحه رسمی اینستاگرام</a>
    </nav>
    <nav aria-label="پیوندهای کاربردی">
      <strong class="footer-title">پیوندهای کاربردی</strong>
      <a href="/videos/"><Video size={18}/>ویدئوهای آموزشی و نمونه‌ها</a>
      <a href="/knowledge/" lang="en" dir="ltr"><Braces size={18}/>Knowledge & AI resources</a>
      <a href={topHref}><ArrowUp size={18}/>بازگشت به ابتدای صفحه</a>
    </nav>
  </div>
  <div class="container footer-bottom">© {year} دکتر سعید قزلباش · آخرین بازبینی و به‌روزرسانی: {modified}</div>
</footer>

<nav class="mobile-cta" aria-label="اقدام‌های سریع موبایل">
  <a href={`tel:${site.phone}`}>تماس</a>
  <a href={site.maps} target="_blank" rel="noopener noreferrer external">لوکیشن</a>
  <a href={site.instagram} target="_blank" rel="me noopener noreferrer external">اینستاگرام</a>
</nav>
