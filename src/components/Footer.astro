---
import { clinic } from '../data/clinic';
---

<footer id="site-footer" class="site-footer">
  <div class="footer-cta">
    <div><span>تصمیم درست از انتخاب نام روش شروع نمی‌شود.</span><h2>برای ارزیابی دقیق مسئله، مستقیم با کلینیک تماس بگیرید.</h2></div>
    <a class="button button--gold" href={`tel:${clinic.telephone}`}>{clinic.telephoneDisplay}</a>
  </div>
  <div class="footer-grid">
    <div class="footer-brand">
      <span class="brand__seal" aria-hidden="true">ق</span>
      <div><strong>دکتر سعید قزلباش</strong><p>{clinic.name}</p></div>
    </div>
    <div><h3>مراجعه</h3><address>{clinic.address.addressLocality}، {clinic.address.streetAddress}</address><a href={clinic.mapsUrl} rel="noopener noreferrer">مشاهده روی نقشه</a></div>
    <div><h3>دسترسی سریع</h3><a href="#doctor-entity">هویت پزشک</a><a href="#aesthetic-medicine-map">نقشه درمان</a><a href="#faq">پرسش‌های پرتکرار</a></div>
    <div><h3>پرونده تماس</h3><a href="/doctor.vcf">کارت تماس پزشک</a><a href="/clinic.vcf">کارت تماس کلینیک</a><a href="mailto:doctor@ghezelbaash.ir">doctor@ghezelbaash.ir</a></div>
  </div>
  <div class="footer-bottom"><span>© ۲۰۲۶ دکتر سعید قزلباش</span><time datetime="2026-07-16">آخرین انتشار: ۲۵ تیر ۱۴۰۵</time></div>
</footer>
