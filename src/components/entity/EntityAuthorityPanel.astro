---
import { BadgeCheck, Building2, ExternalLink, MapPin, Star, Stethoscope, CalendarClock, FileCheck2, Phone, MessageCircle, Clapperboard } from '@lucide/astro';
import { site } from '~/domain/entities';
// @ts-expect-error Canonical ESM editorial record.
import { editorialReview } from '~/domain/editorial.mjs';
const fa = new Intl.NumberFormat('fa-IR');
const observedAt = new Intl.DateTimeFormat('fa-IR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(`${site.googleBusinessProfile.observedAt}T12:00:00+03:30`));
const reviewDate = new Intl.DateTimeFormat('fa-IR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(`${editorialReview.dateModified}T12:00:00+03:30`));
---
<section id="entity-authority-panel" class="section my-0! py-10 relative z-0 overflow-hidden" aria-labelledby="entity-authority-title">
  <header class="text-center max-w-5xl mx-auto">
    <p class="eyebrow">هویت، مکان و مسئولیت محتوایی</p>
    <h2 id="entity-authority-title">قبل از انتخاب درمان، <span class="bg-linear-to-r from-[#0179B4] to-[#88D8FF] bg-clip-text text-transparent">ببینید چه کسی تصمیم می‌گیرد</span> و این تصمیم کجا قابل‌بررسی است</h2>
    <p>عنوان و تبلیغ کافی نیست. نام ثبت‌شده، محل فعالیت و مسئولیت بازبینی این صفحه باید روشن و قابل پیگیری باشند.</p>
  </header>

  <div class="relative grid gap-10 grid-cols-1 lg:grid-cols-3 mt-10 max-w-6xl mx-auto after:absolute after:-top-5 after:-left-10 after:bg-[url('/img/shape/shape2.svg')] after:bg-no-repeat after:w-35.5 after:h-9.25 after:bg-position-[left_top] after:bg-contain after:-z-10 before:absolute before:-bottom-5 before:-right-10 before:bg-[url('/img/shape/shape2-1.svg')] before:bg-no-repeat before:w-35.5 before:h-9.25 before:bg-position-[right_bottom] before:bg-contain before:-z-10">
    <article class="lg:col-span-2 border-2 border-main-200 rounded-xl p-4 lg:p-10 bg-[linear-gradient(45deg,#F8FDFF,#FFFFFF)] text-black" id="doctor-entity-card">
      <Stethoscope size={44} aria-hidden="true" />
      <p class="entity-kicker">هویت رسمی پزشک</p>
      <h3 class="text-main-200 mt-3">{site.legalName}</h3>
      <dl><div><dt>نام حرفه‌ای</dt><dd>{site.name}</dd></div><div><dt>مدرک</dt><dd>دکترای حرفه‌ای پزشکی</dd></div><div><dt>نظام پزشکی</dt><dd>{fa.format(Number(site.irimc))}</dd></div></dl>
      <p class="rating-disclosure"><BadgeCheck size={17}/> هویت حرفه‌ای و شمارهٔ ثبت در داده‌های ساختاری صفحه مستند شده است.</p>
    </article>

    <article class="border-2 border-main-200 rounded-xl p-4 lg:p-10 bg-[linear-gradient(45deg,#F8FDFF,#FFFFFF)] text-black" id="clinic-entity-card">
      <Building2 size={44} aria-hidden="true" />
      <p class="entity-kicker">کلینیک و اعتبار مکانی</p>
      <h3 class="text-main-200 mt-3">{site.clinicName}</h3>
      <p>{site.address}</p>
      <strong class="rating-value"><Star size={18} fill="currentColor" /> {fa.format(site.googleBusinessProfile.ratingValue)} از {fa.format(site.googleBusinessProfile.bestRating)} بر پایهٔ {fa.format(site.googleBusinessProfile.ratingCount)} نظر</strong>
      <p class="rating-disclosure"><CalendarClock size={16}/> مشاهده‌شده در {observedAt}؛ مقدار جاری را در منبع ببینید.</p>
      <a href={site.maps} target="_blank" rel="noopener noreferrer external" class="hover:text-main-200 hover:underline inline-flex items-center gap-2"><MapPin size={17}/> Google Maps و مسیریابی <ExternalLink size={14}/></a>
    </article>
    <article class="border-2 border-main-200 rounded-xl p-4 lg:p-10 bg-[linear-gradient(45deg,#F8FDFF,#FFFFFF)] text-black">
      <FileCheck2 size={44} aria-hidden="true" />
      <p class="entity-kicker">مسئولیت تحریریه پزشکی</p>
      <h3 class="text-main-200 mt-3">نویسنده و بازبین: {site.name}</h3>
      <p>هویت، دامنهٔ خدمات، مرز ارجاع، عوارض، کاندیداتوری و محتوای بالینی صفحه با مسئولیت مستقیم پزشک بازبینی شده‌اند.</p>
      <p class="rating-disclosure"><CalendarClock size={16}/> آخرین بازبینی: {reviewDate}</p>
    </article>
  </div>

  <div class="flex flex-wrap gap-3 items-center justify-center mt-10" aria-label="مسیرهای اقدام">
    <a href={`tel:${site.phone}`} class="btn bg-[linear-gradient(125deg,var(--color-main-100),var(--color-main-200))] text-white border-0 rounded-xl text-lg py-3 px-6 h-auto shadow-xl hover:shadow-2xl"><Phone size={18}/> تماس مستقیم با کلینیک</a>
    <a href={site.instagramDirect} target="_blank" rel="noopener noreferrer external" class="btn btn-outline border-2 border-main-200 text-main-200 rounded-lg hover:bg-main-200 hover:text-white" title="مشاوره مستقیم با پزشک"><MessageCircle size={18}/> مشاوره مستقیم با پزشک</a>
    <a href={site.instagramReels} target="_blank" rel="noopener noreferrer external" class="btn btn-outline border-2 border-main-200 text-main-200 rounded-lg hover:bg-main-200 hover:text-white"><Clapperboard size={18}/> دیدن نمونه‌کارها</a>
    <a href={site.maps} target="_blank" rel="noopener noreferrer external" class="btn btn-outline border-2 border-main-200 text-main-200 rounded-lg hover:bg-main-200 hover:text-white"><MapPin size={18}/> نظرها و مسیریابی</a>
  </div>
</section>
