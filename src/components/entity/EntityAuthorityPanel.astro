---
import { BadgeCheck, Building2, ExternalLink, MapPin, Star, Stethoscope, CalendarClock, FileCheck2, Phone, MessageCircle, Clapperboard } from '@lucide/astro';
import { site } from '~/domain/entities';
// @ts-expect-error Canonical ESM editorial record.
import { editorialReview } from '~/domain/editorial.mjs';
const fa = new Intl.NumberFormat('fa-IR');
const observedAt = new Intl.DateTimeFormat('fa-IR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(`${site.googleBusinessProfile.observedAt}T12:00:00+03:30`));
const reviewDate = new Intl.DateTimeFormat('fa-IR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(`${editorialReview.dateModified}T12:00:00+03:30`));
---
<section id="entity-authority-panel" class="entity-authority authority-proof" aria-labelledby="entity-authority-title">
  <header class="entity-authority-header">
    <p class="eyebrow">هویت، مکان و مسئولیت محتوایی</p>
    <h2 id="entity-authority-title" class="section-display-title">قبل از انتخاب درمان، ببینید چه کسی تصمیم می‌گیرد و این تصمیم کجا قابل‌بررسی است</h2>
    <p>عنوان و تبلیغ کافی نیست. نام ثبت‌شده، محل فعالیت و مسئولیت بازبینی این صفحه باید روشن و قابل پیگیری باشند.</p>
  </header>

  <div class="authority-proof-grid">
    <article class="authority-proof-card" id="doctor-entity-card">
      <Stethoscope aria-hidden="true" />
      <p class="entity-kicker">هویت رسمی پزشک</p>
      <h3>{site.legalName}</h3>
      <dl><div><dt>نام حرفه‌ای</dt><dd>{site.name}</dd></div><div><dt>مدرک</dt><dd>دکترای حرفه‌ای پزشکی</dd></div><div><dt>نظام پزشکی</dt><dd>{fa.format(Number(site.irimc))}</dd></div></dl>
      <p class="rating-disclosure"><BadgeCheck size={17}/> هویت حرفه‌ای و شمارهٔ ثبت در داده‌های ساختاری صفحه مستند شده است.</p>
    </article>

    <article class="authority-proof-card" id="clinic-entity-card">
      <Building2 aria-hidden="true" />
      <p class="entity-kicker">کلینیک و اعتبار مکانی</p>
      <h3>{site.clinicName}</h3>
      <p>{site.address}</p>
      <strong class="rating-value"><Star size={18} fill="currentColor" /> {fa.format(site.googleBusinessProfile.ratingValue)} از {fa.format(site.googleBusinessProfile.bestRating)} بر پایهٔ {fa.format(site.googleBusinessProfile.ratingCount)} نظر</strong>
      <p class="rating-disclosure"><CalendarClock size={16}/> مشاهده‌شده در {observedAt}؛ مقدار جاری را در منبع ببینید.</p>
      <a href={site.maps} target="_blank" rel="noopener noreferrer external"><MapPin size={17}/> Google Maps و مسیریابی <ExternalLink size={14}/></a>
    </article>
    <article class="authority-proof-card">
      <FileCheck2 aria-hidden="true" />
      <p class="entity-kicker">مسئولیت تحریریه پزشکی</p>
      <h3>نویسنده و بازبین: {site.name}</h3>
      <p>هویت، دامنهٔ خدمات، مرز ارجاع، عوارض، کاندیداتوری و محتوای بالینی صفحه با مسئولیت مستقیم پزشک بازبینی شده‌اند.</p>
      <p class="rating-disclosure"><CalendarClock size={16}/> آخرین بازبینی: {reviewDate}</p>
    </article>
  </div>

  <div class="authority-contact-actions" aria-label="مسیرهای اقدام">
    <a href={`tel:${site.phone}`} class="heal-button heal-button-primary"><Phone size={18}/> تماس مستقیم با کلینیک</a>
    <a href={site.instagramDirect} target="_blank" rel="noopener noreferrer external" class="heal-button" title="مشاوره مستقیم با پزشک"><MessageCircle size={18}/> مشاوره مستقیم با پزشک</a>
    <a href={site.instagramReels} target="_blank" rel="noopener noreferrer external" class="heal-button"><Clapperboard size={18}/> دیدن نمونه‌کارها</a>
    <a href={site.maps} target="_blank" rel="noopener noreferrer external" class="heal-button"><MapPin size={18}/> نظرها و مسیریابی</a>
  </div>
</section>
