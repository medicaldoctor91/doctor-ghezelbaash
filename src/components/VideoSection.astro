---
import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { videos } from '../data/videos';
import type { AssetManifest } from '../utils/graph';

interface Props {
  assets: AssetManifest;
}

const { assets } = Astro.props;
const videoCards = videos.map((video) => {
  const asset = assets.videos[video.id];
  const transcriptPath = resolve(process.cwd(), 'Media', video.transcriptFile);
  const transcript = existsSync(transcriptPath)
    ? readFileSync(transcriptPath, 'utf8')
        .split(/\n{2,}/u)
        .map((paragraph) => paragraph.replace(/^#{1,6}\s+/u, '').trim())
        .filter(Boolean)
    : [];
  return { video, asset, transcript };
});
---

<section id="video-library" class="content-section" aria-labelledby="video-library-title">
  <h2 id="video-library-title">کتابخانه ویدئو</h2>
  <div class="content-slot" data-content-file="18-video-content.md"><slot /></div>
  <div class="video-grid">
    {
      videoCards.map(({ video, asset, transcript }) => (
        <section id={video.id} class="video-card" aria-labelledby={`${video.id}-title`}>
          <h3 id={`${video.id}-title`}>{video.title}</h3>
          {asset?.mp4 && asset.poster && asset.captions ? (
            <video
              controls
              preload="none"
              poster={asset.poster}
              width={video.width}
              height={video.height}
            >
              {asset.webm && <source src={asset.webm} type="video/webm" />}
              <source src={asset.mp4} type="video/mp4" />
              <track
                src={asset.captions}
                kind="captions"
                srclang="fa"
                label="فارسی"
                default
              />
            </video>
          ) : (
            <p class="media-blocker">ورودی ویدئو، poster یا caption کامل نشده است.</p>
          )}
          <div class="video-transcript">
            <h4>متن ویدئو</h4>
            {transcript.length > 0 ? transcript.map((paragraph) => <p>{paragraph}</p>) : <p>TODO_VISIBLE_CONTENT</p>}
          </div>
        </section>
      ))
    }
  </div>
</section>
