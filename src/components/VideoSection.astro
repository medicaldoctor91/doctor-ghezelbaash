---
import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { videos } from '../data/videos';
import type { AssetManifest } from '../utils/graph';
interface Props { assets: AssetManifest; }
const { assets } = Astro.props;
const videoCards = videos.filter((video) => video.available).map((video) => {
  const asset = assets.videos[video.id];
  const transcriptPath = resolve(process.cwd(), 'Media', video.transcriptFile);
  const hasTranscript = existsSync(transcriptPath);
  const textAlternative = hasTranscript
    ? readFileSync(transcriptPath, 'utf8').split(/\n{2,}/u).map((paragraph) => paragraph.replace(/^#{1,6}\s+/u, '').trim()).filter(Boolean)
    : [video.description];
  return { video, asset, hasTranscript, textAlternative };
});
---

<section id="video-library" class="content-section video-library" aria-labelledby="video-library-title">
  <header class="video-library__header">
    <div><span class="section-kicker">آموزش، تکنیک و نمونه‌های منتخب</span><h2 id="video-library-title">کتابخانه ویدئویی</h2></div>
    <div class="content-slot"><slot /></div>
  </header>
  <div class="video-grid">
    {videoCards.map(({ video, asset, hasTranscript, textAlternative }, index) => (
      <section id={video.id} class="video-card" aria-labelledby={`${video.id}-title`}>
        <div class="video-card__media">
          {asset?.mp4 && asset.poster && (
            <video controls playsinline preload="none" poster={asset.poster} width={video.width} height={video.height}>
              {asset.webm && <source src={asset.webm} type="video/webm" />}
              <source src={asset.mp4} type="video/mp4" />
              {asset.captions && <track src={asset.captions} kind="captions" srclang="fa" label="فارسی" default />}
            </video>
          )}
          <span class="video-card__index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
        </div>
        <div class="video-card__body">
          <h3 id={`${video.id}-title`}>{video.title}</h3>
          <p>{video.description}</p>
          <details class="video-transcript">
            <summary>{hasTranscript ? 'متن کامل ویدئو' : 'خلاصهٔ متنی این آموزش'}</summary>
            <div>{textAlternative.map((paragraph) => <p>{paragraph}</p>)}</div>
          </details>
        </div>
      </section>
    ))}
  </div>
</section>
