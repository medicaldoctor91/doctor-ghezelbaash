---
import { buildPageGraph } from '../lib/schema.mjs';

const {
  title,
  description,
  canonicalPath = '/',
  pageType = 'WebPage',
  breadcrumbs,
  extraGraph = []
} = Astro.props;

const graph = buildPageGraph({
  title,
  description,
  canonicalPath,
  pageType,
  breadcrumbs,
  extraGraph
});
---
<script type="application/ld+json" set:html={JSON.stringify(graph)} />
