---
import {
  buildClinicEntity,
  buildFaqSchema,
  buildPageGraph,
  buildPersonEntity,
  buildPhysicianEntity,
  buildServiceItemList,
  buildServiceSchema
} from '../lib/schema.mjs';
import { absoluteUrl } from '../data/site.mjs';
import { getRouteByPath } from '../lib/routes.mjs';

const {
  title,
  description,
  canonicalPath = '/',
  pageType = 'WebPage',
  breadcrumbs,
  extraGraph = []
} = Astro.props;

const route = getRouteByPath(canonicalPath);
const routeGraph = [];

if (canonicalPath === '/') {
  routeGraph.push({
    '@type': 'WebSite',
    '@id': absoluteUrl('/#website'),
    author: { '@id': absoluteUrl('/#dr-saeed-ghezelbash') },
    creator: { '@id': absoluteUrl('/#dr-saeed-ghezelbash') }
  });
}

if (route.kind === 'person') {
  routeGraph.push(buildPersonEntity(), buildPhysicianEntity());
}

if (route.kind === 'clinic') {
  routeGraph.push(buildClinicEntity(), buildPhysicianEntity());
}

if (route.kind === 'services-hub') {
  routeGraph.push(buildServiceItemList({ canonicalPath }));
}

if (route.kind === 'service' && route.service) {
  routeGraph.push(
    buildServiceSchema({ service: route.service, canonicalPath }),
    buildFaqSchema({ canonicalPath, faqItems: route.service.faq || [] })
  );
}

const graph = buildPageGraph({
  title,
  description,
  canonicalPath,
  pageType,
  breadcrumbs,
  extraGraph: [...routeGraph, ...extraGraph]
});
---
<script type="application/ld+json" set:html={JSON.stringify(graph)} />
