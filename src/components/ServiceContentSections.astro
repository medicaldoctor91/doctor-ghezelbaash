---
const { sections = [] } = Astro.props;
---
{sections.map((section) => (
  <section id={section.id} class={section.emphasis ? 'box' : undefined}>
    <h2>{section.title}</h2>
    {section.body?.map((paragraph) => <p>{paragraph}</p>)}
    {section.items?.length > 0 && (
      <div class="grid">
        {section.items.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    )}
    {section.list?.length > 0 && (
      <ul>
        {section.list.map((item) => <li>{item}</li>)}
      </ul>
    )}
  </section>
))}
