---
import type { TocGroup } from '~/lib/content';
interface Props { groups: TocGroup[]; }
const { groups } = Astro.props;
---
<aside id="content-table" class="content-table content-table-single" aria-label="فهرست موضوعی محتوای صفحه">
  <details class="content-table-disclosure" open>
    <summary><strong>نقشهٔ موضوعی صفحه</strong><span>بازکردن یا بستن فهرست</span></summary>
    <nav aria-label="فهرست واحد محتوای صفحه">
      {groups.map((group, index) => (
        <details class="toc-category" open={index < 3}>
          <summary>{group.label}</summary>
          <ol>
            {group.sections.map((section) => (
              <li>
                <a class="toc-section-link" href={`#${section.slug}`}>{section.text}</a>
                {section.children.length > 0 && (
                  <details class="toc-children">
                    <summary>زیرموضوع‌ها</summary>
                    <ol>
                      {section.children.map((child) => (
                        <li>
                          <a href={`#${child.slug}`}>{child.text}</a>
                          {child.children.length > 0 && <details class="toc-children"><summary>پرسش‌ها و جزئیات</summary><ol>{child.children.map((grandchild) => <li><a href={`#${grandchild.slug}`}>{grandchild.text}</a></li>)}</ol></details>}
                        </li>
                      ))}
                    </ol>
                  </details>
                )}
              </li>
            ))}
          </ol>
        </details>
      ))}
      <details class="toc-category toc-knowledge" open>
        <summary>Knowledge &amp; AI</summary>
        <ol>
          <li><a class="toc-section-link" href="#knowledge-resources">گراف دانش و منابع ماشین‌خوان</a></li>
          <li><a href="#knowledge-identity">شناسه‌های انتیتی پزشک و کلینیک</a></li>
          <li><a href="#knowledge-retrieval">Retrieval و شواهد</a></li>
        </ol>
      </details>
      <a class="toc-back-top" href="#top">بازگشت به ابتدای صفحه</a>
    </nav>
  </details>
</aside>
