---
import type { TocGroup } from '../../lib/content';
interface Props { groups: TocGroup[]; }
const { groups } = Astro.props;
---
<nav class="border-2 border-main-200 rounded-xl p-4 lg:p-10 bg-[linear-gradient(45deg,#F8FDFF,#FFFFFF)] text-black" aria-label="مسیرهای اصلی محتوای لندینگ">
  <strong class="block text-main-200 text-center mb-5">از مسئلهٔ خودتان وارد شوید</strong>
  <div class="flex flex-wrap gap-3 items-center justify-center">
    {groups.map((group) => {
      const first = group.sections[0];
      return first && <a class="btn btn-outline border-2 border-main-200 text-main-200 rounded-lg hover:bg-main-200 hover:text-white" href={`#${first.slug}`} data-topic-group={group.id}>{group.shortLabel}</a>;
    })}
  </div>
</nav>
