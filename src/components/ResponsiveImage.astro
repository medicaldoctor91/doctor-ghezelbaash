---
import type { AssetManifest } from '../utils/graph';

interface Props {
  id: string;
  asset?: AssetManifest['images'][string];
  class?: string;
  sizes?: string;
  priority?: boolean;
}

const {
  id,
  asset,
  class: className,
  sizes = '(max-width: 48rem) 100vw, 50vw',
  priority = false,
} = Astro.props;
const source = asset?.fallback ?? asset?.webp ?? asset?.avif;
const srcset = (variants: Array<{ src: string; width: number }> | undefined) =>
  variants?.map((variant) => `${variant.src} ${variant.width}w`).join(', ');
const avifSrcset = srcset(asset?.avifSrcset);
const webpSrcset = srcset(asset?.webpSrcset);
const fallbackSrcset = srcset(asset?.fallbackSrcset);
---

{
  asset && source && (
    <figure id={`image-${id}`} class:list={['responsive-media', className]}>
      <picture>
        {asset.avif && <source srcset={avifSrcset ?? asset.avif} type="image/avif" sizes={sizes} />}
        {asset.webp && <source srcset={webpSrcset ?? asset.webp} type="image/webp" sizes={sizes} />}
        <img
          src={source}
          srcset={fallbackSrcset}
          sizes={sizes}
          alt={asset.alt ?? ''}
          width={asset.width}
          height={asset.height}
          loading={priority ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={priority ? 'high' : 'auto'}
        />
      </picture>
    </figure>
  )
}
