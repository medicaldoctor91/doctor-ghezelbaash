---
import { METADATA, I18N } from '~/site.config';
import type { MetaData, MetaDataImage, MetaDataOpenGraph } from '~/types';
import { getCanonical } from '~/utils/permalinks';
import { adaptOpenGraphImages } from '~/utils/images';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  noCanonical = false,
  robots,
  description,
  openGraph = {},
  twitter = {},
} = Astro.props;

const resolvedTitle = title || METADATA.title.default;
const titleText = ignoreTitleTemplate ? resolvedTitle : METADATA.title.template.replace('%s', resolvedTitle);
const descriptionText = description || METADATA.description;

const mergedOpenGraph: MetaDataOpenGraph = {
  ...METADATA.openGraph,
  ...openGraph,
  url: canonical,
  siteName: openGraph.siteName || METADATA.openGraph.siteName,
  locale: openGraph.locale || I18N.language,
  images: openGraph.images?.length ? openGraph.images : METADATA.openGraph.images,
};

const adaptedOg = await adaptOpenGraphImages(mergedOpenGraph, Astro.site);
const ogImages = (adaptedOg.images || []).filter((image): image is MetaDataImage => Boolean(image?.url));
const primaryImage = ogImages[0];
const twitterCard = twitter.cardType || METADATA.twitter.cardType || (primaryImage ? 'summary_large_image' : 'summary');
---

<title>{titleText}</title>
<meta name="description" content={descriptionText} />
{robots && <meta name="robots" content={robots} />}
{!noCanonical && <link rel="canonical" href={canonical} />}
<meta property="og:type" content={adaptedOg.type || 'website'} />
<meta property="og:title" content={resolvedTitle} />
<meta property="og:description" content={descriptionText} />
{!noCanonical && <meta property="og:url" content={canonical} />}
<meta property="og:site_name" content={adaptedOg.siteName || METADATA.openGraph.siteName} />
<meta property="og:locale" content={adaptedOg.locale || I18N.language} />
{primaryImage && <meta property="og:image" content={primaryImage.url} />}
{primaryImage?.width && <meta property="og:image:width" content={String(primaryImage.width)} />}
{primaryImage?.height && <meta property="og:image:height" content={String(primaryImage.height)} />}

<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={resolvedTitle} />
<meta name="twitter:description" content={descriptionText} />
{twitter.site && <meta name="twitter:site" content={twitter.site} />}
{twitter.handle && <meta name="twitter:creator" content={twitter.handle} />}
{primaryImage && <meta name="twitter:image" content={primaryImage.url} />}
