---
import { getContactData } from '~/utils/contentData';
import { getGoogleMapsRating } from '~/utils/contentData';
import { getUiCopy } from '~/utils/uiCopy';

export interface Props {
  pageTitle?: string;
}

const uiCopy = await getUiCopy<{
  pageTrust: {
    defaultPageTitle: string;
    identityLabel: string;
    identitySuffix: string;
    clinicLabel: string;
    contactLabel: string;
    localTrustLabel: string;
    lastSyncedLabel: string;
  };
}>();

const { pageTitle = uiCopy.pageTrust.defaultPageTitle } = Astro.props;
const contactData = await getContactData();
const googleMapsRating = await getGoogleMapsRating();
---

<section id="page-trust-layer" class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
  <div class="grid gap-4 md:grid-cols-4">
    <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:bg-slate-900 dark:border-slate-800">
      <p class="text-sm text-muted mb-2">{uiCopy.pageTrust.identityLabel}</p>
      <strong class="text-base leading-7">{contactData.doctorName}</strong>
      <span class="mt-2 block text-sm leading-7 text-muted"
        >برای صفحه «{pageTitle}» {uiCopy.pageTrust.identitySuffix}</span
      >
    </div>
    <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:bg-slate-900 dark:border-slate-800">
      <p class="text-sm text-muted mb-2">{uiCopy.pageTrust.clinicLabel}</p>
      <strong class="text-base leading-7">{contactData.clinicName}</strong>
      <span class="mt-2 block text-sm leading-7 text-muted">{contactData.address}</span>
    </div>
    <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:bg-slate-900 dark:border-slate-800">
      <p class="text-sm text-muted mb-2">{uiCopy.pageTrust.contactLabel}</p>
      <strong class="text-base leading-7">{contactData.phoneDisplay}</strong>
      <span class="mt-2 block text-sm leading-7 text-muted">{contactData.openingHours}</span>
    </div>
    <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:bg-slate-900 dark:border-slate-800">
      <p class="text-sm text-muted mb-2">{uiCopy.pageTrust.localTrustLabel}</p>
      <strong class="text-base leading-7">{googleMapsRating.displayText}</strong>
      <span class="mt-2 block text-sm leading-7 text-muted">
        {uiCopy.pageTrust.lastSyncedLabel}: {googleMapsRating.lastSynced}
      </span>
    </div>
  </div>
</section>
