---
import { getVideoTranscriptsForPage } from '~/data/videoTranscripts';

export interface Props {
  path?: string;
}

const { path = Astro.url.pathname } = Astro.props;
const videos = getVideoTranscriptsForPage(path);
---

{
  videos.length > 0 && (
    <section id="video-transcript-layer" class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
      <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <p class="mb-2 text-sm font-bold text-primary">Video transcript / segment layer</p>
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">متن قابل‌خزش ویدئوهای همین صفحه</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          متن‌ها و بخش‌بندی‌های زیر پس از بازبینی محتوایی تأیید شده‌اند و برای فهم سریع‌تر ویدئو، ایندکس‌پذیری بهتر و
          اتصال ویدئو به مسیر تصمیم‌گیری صفحه ارائه می‌شوند.
        </p>
        <div class="mt-6 space-y-6">
          {videos.map((video) => (
            <article class="rounded-2xl border border-gray-200 p-5 dark:border-slate-800" id={`${video.id}-transcript`}>
              <h3 class="text-xl font-bold">{video.title}</h3>
              <p class="mt-3 text-sm leading-7 text-muted">{video.transcript}</p>
              <ol class="mt-4 grid gap-3 md:grid-cols-3">
                {video.segments.map((segment) => (
                  <li class="rounded-xl bg-gray-50 p-4 text-sm leading-7 dark:bg-slate-950">
                    <strong class="block text-default">{segment.name}</strong>
                    <span class="block text-xs text-primary">
                      {segment.startOffset}s – {segment.endOffset}s
                    </span>
                    <span class="mt-2 block text-muted">{segment.description}</span>
                  </li>
                ))}
              </ol>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
