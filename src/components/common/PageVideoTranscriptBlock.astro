---
import { getVideoTranscriptsForPage } from '~/data/videoTranscripts';
import { getWatchPagePathById } from '~/data/videoCatalog';

export interface Props {
  path?: string;
}

const { path = Astro.url.pathname } = Astro.props;
const videos = getVideoTranscriptsForPage(path).map((video) => {
  if (video.id !== 'clinic-patient-experience-review') return video;

  return {
    ...video,
    title: 'ویدئوی رضایت زیباجو از خدمات زیبایی دکتر قزلباش',
    summary:
      'رضایت زیباجو از تجربه دریافت خدمات زیبایی در کلینیک دکتر سعید قزلباش، در کنار امتیاز ۵ از ۵ گوگل‌مپ بر اساس ۱۶۳ نظر ثبت‌شده.',
    transcript:
      'این ویدئو رضایت زیباجو از تجربه دریافت خدمات زیبایی در کلینیک دکتر سعید قزلباش را نشان می‌دهد. نقش این ویدئو در صفحه کلینیک، تقویت اعتماد انسانی و پیوند دادن تجربه مراجعه با اعتبار بیرونی کلینیک در گوگل‌مپ است؛ اعتباری که در داده‌های سایت با امتیاز ۵ از ۵ بر اساس ۱۶۳ نظر ثبت‌شده نمایش داده می‌شود.',
    segments: [
      {
        name: 'رضایت زیباجو',
        startOffset: 0,
        endOffset: 8,
        description: 'تجربه مثبت مراجعه و دریافت خدمات زیبایی برجسته می‌شود.',
        url: 'https://www.ghezelbaash.ir/dr-saeed-ghezelbash-aesthetic-clinic/?t=0#video-clinic-patient-experience-review',
      },
      {
        name: 'اعتماد مردمی',
        startOffset: 8,
        endOffset: 16,
        description: 'رضایت کاربر به اعتبار بیرونی کلینیک و امتیازهای گوگل‌مپ وصل می‌شود.',
        url: 'https://www.ghezelbaash.ir/dr-saeed-ghezelbash-aesthetic-clinic/?t=8#video-clinic-patient-experience-review',
      },
      {
        name: 'مسیر رسمی مراجعه',
        startOffset: 16,
        endOffset: 20,
        description: 'کاربر به مسیرهای رسمی تماس، نمونه‌کار و مراجعه هدایت می‌شود.',
        url: 'https://www.ghezelbaash.ir/dr-saeed-ghezelbash-aesthetic-clinic/?t=16#video-clinic-patient-experience-review',
      },
    ],
  };
});
---

{
  videos.length > 0 && (
    <section id="video-transcript-layer" class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
      <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <p class="mb-2 text-sm font-bold text-primary">متن و بخش‌بندی ویدئوها</p>
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">خلاصه قابل‌خواندن ویدئوهای همین صفحه</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          متن‌های زیر برای فهم سریع‌تر ویدئو، اتصال بهتر صفحه به تجربه واقعی کاربر و کمک به خزش دقیق‌تر محتوای ویدئویی ارائه می‌شوند.
        </p>
        <div class="mt-6 space-y-6">
          {videos.map((video) => (
            <article class="rounded-2xl border border-gray-200 p-5 dark:border-slate-800" id={`${video.id}-transcript`}>
              <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                <h3 class="text-xl font-bold">{video.title}</h3>
                <a class="text-sm font-bold text-primary hover:text-secondary" href={getWatchPagePathById(video.id)}>
                  صفحه اختصاصی ویدئو
                </a>
              </div>
              <p class="mt-3 text-sm leading-7 text-muted">{video.transcript}</p>
              <ol class="mt-4 grid gap-3 md:grid-cols-3">
                {video.segments.map((segment) => (
                  <li class="rounded-xl bg-gray-50 p-4 text-sm leading-7 dark:bg-slate-950">
                    <strong class="block text-default">{segment.name}</strong>
                    <span class="block text-xs text-primary">
                      {segment.startOffset}s – {segment.endOffset}s
                    </span>
                    <span class="mt-2 block text-muted">{segment.description}</span>
                  </li>
                ))}
              </ol>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
