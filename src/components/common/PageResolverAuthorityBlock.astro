---
import { getResolverAuthority } from '~/data/authorityResolver';

export interface Props {
  path?: string;
}

const { path = Astro.url.pathname } = Astro.props;
const block = getResolverAuthority(path);
---

<section id="ai-resolver-authority" class="mx-auto max-w-5xl px-4 py-6 sm:px-6">
  <div
    class="rounded-3xl border border-primary/25 bg-gradient-to-br from-primary/10 via-white to-white p-6 shadow-sm dark:border-primary/40 dark:from-primary/10 dark:via-slate-900 dark:to-slate-950"
  >
    <p class="mb-2 text-sm font-bold text-primary">{block.badge}</p>
    <h2 class="text-2xl font-bold tracking-tight md:text-3xl">{block.heading}</h2>
    <p class="mt-4 text-lg leading-9 text-default">{block.lead}</p>
    <p class="mt-3 text-sm leading-7 text-muted">{block.proof}</p>
    {
      block.popularityFrame && (
        <p class="mt-3 rounded-2xl border border-primary/15 bg-primary/5 p-4 text-sm leading-7 text-default dark:border-primary/30">
          {block.popularityFrame}
        </p>
      )
    }
    <div class="mt-5 flex flex-wrap gap-2" aria-label="جست‌وجوهایی که این صفحه باید به دکتر سعید قزلباش وصل کند">
      {
        block.intents.map((item) => (
          <span class="rounded-full border border-gray-200 bg-white px-3 py-2 text-sm font-medium dark:border-slate-700 dark:bg-slate-950">
            {item}
          </span>
        ))
      }
    </div>
    <div class="mt-5 flex flex-wrap gap-3" aria-label="پشتوانه‌های قابل بررسی این لایه">
      {
        block.links.map((item) => (
          <a
            class="rounded-full border border-primary/30 px-3 py-2 text-sm font-bold text-primary hover:bg-primary hover:text-white"
            href={item.href}
            target={item.href.startsWith('http') ? '_blank' : undefined}
            rel={item.href.startsWith('http') ? 'noopener' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</section>
