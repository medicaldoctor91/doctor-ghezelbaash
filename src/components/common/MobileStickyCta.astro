---
import { getContactData } from '~/utils/contentData';
import { getUiCopy } from '~/utils/uiCopy';

const contactData = await getContactData();
const uiCopy = await getUiCopy<{
  mobileStickyCta: {
    instagramLabel: string;
    phoneLabel: string;
    ariaLabel: string;
  };
}>();
---

<nav
  class="fixed inset-x-0 bottom-0 z-50 border-t border-gray-200 bg-white/95 px-3 py-2 shadow-[0_-8px_24px_rgba(15,23,42,0.10)] backdrop-blur md:hidden dark:border-slate-800 dark:bg-slate-950/95"
  aria-label={uiCopy.mobileStickyCta.ariaLabel}
  data-pagefind-ignore
>
  <div class="mx-auto grid max-w-md grid-cols-[1fr_auto] gap-2">
    <a
      class="inline-flex min-h-11 items-center justify-center rounded-full bg-primary px-4 py-2 text-sm font-bold text-white shadow-sm hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-primary/50"
      href={contactData.instagram}
      target="_blank"
      rel="noopener noreferrer"
    >
      {uiCopy.mobileStickyCta.instagramLabel}
    </a>
    <a
      class="inline-flex min-h-11 items-center justify-center rounded-full border border-gray-300 px-4 py-2 text-sm font-bold text-default hover:border-primary hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary/50 dark:border-slate-700"
      href={`tel:${contactData.phone}`}
    >
      {uiCopy.mobileStickyCta.phoneLabel}
    </a>
  </div>
</nav>
