---
import { getPageGovernance } from '~/data/pageGovernance';

export interface Props {
  path?: string;
}

const { path = Astro.url.pathname } = Astro.props;
const page = getPageGovernance(path);
---

<section id="medical-review-freshness" class="mx-auto max-w-5xl px-4 py-4 sm:px-6">
  <div
    class="grid gap-3 rounded-2xl border border-gray-200 bg-white p-5 text-sm shadow-sm dark:border-slate-800 dark:bg-slate-900 md:grid-cols-3"
  >
    <div>
      <p class="font-bold text-default">آخرین بازبینی</p>
      <p class="mt-1 text-muted">{page.reviewedAtPersian} / {page.reviewedAt}</p>
    </div>
    <div>
      <p class="font-bold text-default">بازبین مسئول</p>
      <p class="mt-1 text-muted">{page.reviewedBy}، {page.reviewerCredential}</p>
    </div>
    <div>
      <p class="font-bold text-default">دامنه بازبینی</p>
      <p class="mt-1 text-muted">هم‌خوانی متن قابل مشاهده، گراف انتیتی، ویدئو و شواهد</p>
    </div>
  </div>
</section>
