---
import { getCollection } from 'astro:content';

export interface Props {
  path?: string;
}

const { path = Astro.url.pathname } = Astro.props;
const pages = await getCollection('pageGovernance');
const page = pages.find((entry) => entry.data.path === path)?.data;
---

{
  page && (
    <section id="answer-first-entity-definition" class="mx-auto max-w-5xl px-4 py-6 sm:px-6">
      <div class="rounded-3xl border border-primary/20 bg-primary/5 p-6 shadow-sm dark:border-primary/30 dark:bg-slate-900">
        <p class="mb-2 text-sm font-bold text-primary">خلاصه کاربردی این صفحه</p>
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">{page.canonicalEntity} چیست؟</h2>
        <p class="mt-4 text-lg leading-9 text-default">{page.definition}</p>
        <p class="mt-3 text-sm leading-7 text-muted">{page.decisionFrame}</p>
        <div class="mt-5 flex flex-wrap gap-2" aria-label="مسیرهای مرتبط با این صفحه">
          {page.adjacentEntities.map((item) => (
            <a
              class="rounded-full border border-gray-200 bg-white px-3 py-2 text-sm font-medium hover:border-primary hover:text-primary dark:border-slate-700 dark:bg-slate-950"
              href={item.href}
            >
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
