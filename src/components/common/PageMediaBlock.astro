---
import Image from '~/components/common/Image.astro';
import { getPageMedia } from '~/data/pageMedia';

export interface Props {
  path?: string;
  title?: string;
  subtitle?: string;
}

const {
  path = Astro.url.pathname,
  title = 'رسانه‌های همین صفحه',
  subtitle = 'این بخش دارایی‌های تصویری و ویدئویی صفحه را به مسیر تصمیم‌گیری، گراف انتیتی و محتوای قابل‌خزش وصل می‌کند.',
} = Astro.props;

const media = getPageMedia(path);
---

<section id="page-media-assets" class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
  <div class="rounded-3xl border border-gray-200 bg-white p-6 md:p-8 shadow-sm dark:bg-slate-900 dark:border-slate-800">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-bold text-primary mb-2">Media & video layer</p>
        <h2 class="text-3xl font-bold tracking-tight">{title}</h2>
      </div>
      <p class="max-w-2xl text-sm leading-7 text-muted">{subtitle}</p>
    </div>

    <div class="mt-6 grid gap-5 lg:grid-cols-2">
      <figure
        class="overflow-hidden rounded-2xl border border-gray-200 bg-gray-50 dark:border-slate-800 dark:bg-slate-950"
      >
        <Image
          src={media.supportImage}
          alt={media.supportAlt}
          layout="responsive"
          widths={[720, 1200]}
          class="w-full"
        />
        <figcaption class="border-t border-gray-200 px-4 py-3 text-sm leading-7 text-muted dark:border-slate-800">
          {media.supportCaption}
        </figcaption>
      </figure>

      <figure
        class="overflow-hidden rounded-2xl border border-gray-200 bg-gray-50 dark:border-slate-800 dark:bg-slate-950"
      >
        <Image
          src={media.galleryImage}
          alt={media.galleryAlt}
          layout="responsive"
          widths={[720, 1200]}
          class="w-full"
        />
        <figcaption class="border-t border-gray-200 px-4 py-3 text-sm leading-7 text-muted dark:border-slate-800">
          {media.galleryCaption}
        </figcaption>
      </figure>
    </div>

    <div class="mt-5 rounded-2xl border border-primary/20 bg-primary/5 p-5 dark:border-primary/30 dark:bg-slate-950">
      <p class="text-sm font-bold text-primary">لایه ویدئو و رسانه فعال</p>
      <p class="mt-2 text-sm leading-7 text-muted">
        تصویر اصلی صفحه در Hero می‌ماند؛ این بخش سیگنال‌های تصویری مکمل را نشان می‌دهد و {media.videoLabel}
      </p>
    </div>
  </div>
</section>
