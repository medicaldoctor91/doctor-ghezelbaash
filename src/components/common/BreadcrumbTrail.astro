---
import { getUiCopy } from '~/utils/uiCopy';

export interface BreadcrumbItem {
  name: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const uiCopy = await getUiCopy<{ breadcrumb: { ariaLabel: string } }>();
---

<nav aria-label={uiCopy.breadcrumb.ariaLabel} class="mx-auto max-w-7xl px-4 sm:px-6 pt-6 md:pt-8">
  <ol class="flex flex-wrap items-center gap-2 text-sm text-muted">
    {
      items.map((item, index) => (
        <>
          <li>
            {item.href ? (
              <a class="hover:text-primary transition-colors" href={item.href}>
                {item.name}
              </a>
            ) : (
              <span class="font-semibold text-default" aria-current="page">
                {item.name}
              </span>
            )}
          </li>
          {index < items.length - 1 && (
            <li aria-hidden="true" class="text-muted/60">
              —
            </li>
          )}
        </>
      ))
    }
  </ol>
</nav>
