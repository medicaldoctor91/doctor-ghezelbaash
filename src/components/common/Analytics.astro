---
import { ANALYTICS } from '~/site.config';

const envId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID || import.meta.env.PUBLIC_GA_ID || '';
const configId = ANALYTICS?.vendors?.googleAnalytics?.id ? String(ANALYTICS.vendors.googleAnalytics.id) : '';
const id = configId || envId;
---

{id && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${id}`} />}

<script is:inline id="ga-init" data-id={id}>
  const analyticsElement = document.getElementById('ga-init');
  const trackingId = analyticsElement?.dataset.id;

  if (trackingId) {
    window.dataLayer = window.dataLayer || [];
    window.gtag = (...args) => {
      window.dataLayer.push(args);
    };
    window.gtag('js', new Date());
    window.gtag('config', trackingId);
  }
</script>
