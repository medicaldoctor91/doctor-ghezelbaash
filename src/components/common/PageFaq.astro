---
import { getPageFaqQuestions } from '~/utils/pageSchema';
import { getUiCopy } from '~/utils/uiCopy';

export interface Props {
  path: string;
}

const { path } = Astro.props;
const uiCopy = await getUiCopy<{ pageFaq: { title: string } }>();
const questions = await getPageFaqQuestions(path);
---

{
  questions.length > 0 && (
    <section id="faq" class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
      <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <p class="text-sm font-bold text-primary">پاسخ‌های کوتاه و قابل تصمیم‌گیری</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight">{uiCopy.pageFaq.title}</h2>
        <div class="mt-6 divide-y divide-gray-200 dark:divide-slate-800">
          {questions.map((question) => (
            <details class="group py-4">
              <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-lg font-semibold text-default marker:text-primary">
                <span>{question.name}</span>
                <span class="mt-1 text-primary transition group-open:rotate-45" aria-hidden="true">
                  +
                </span>
              </summary>
              <p class="mt-3 leading-8 text-muted" set:html={question.answer} />
            </details>
          ))}
        </div>
      </div>
    </section>
  )
}
