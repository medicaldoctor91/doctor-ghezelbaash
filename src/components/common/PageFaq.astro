---
import pageGraphs from '~/data/schema/ghezelbaash-page-graphs.json';

type JsonLdNode = {
  '@id'?: string;
  '@type'?: string | string[];
  name?: string;
  acceptedAnswer?: { text?: string };
  mainEntity?: { '@id': string }[];
  [key: string]: unknown;
};

type PageGraphMap = Record<string, { '@graph': JsonLdNode[] }>;

const graphs = pageGraphs as PageGraphMap;
const rawPath = Astro.url.pathname;
const pathname = rawPath === '/' ? '/' : rawPath.endsWith('/') ? rawPath : `${rawPath}/`;
const graph = graphs[pathname]?.['@graph'] ?? [];
const faqId = `https://www.ghezelbaash.ir${pathname}#faq`;
const faqPage = graph.find((node) => node['@id'] === faqId);
const questionIds = Array.isArray(faqPage?.mainEntity) ? faqPage.mainEntity.map((item) => item['@id']) : [];
const questions = questionIds
  .map((id) => graph.find((node) => node['@id'] === id))
  .filter((node): node is JsonLdNode => Boolean(node?.name && node?.acceptedAnswer?.text));
---

{
  questions.length > 0 && (
    <section id="faq" class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 md:p-8 shadow-sm dark:bg-slate-900 dark:border-slate-800">
        <h2 class="text-3xl font-bold tracking-tight mb-4">پرسش‌های متداول</h2>
        <div class="space-y-5">
          {questions.map((question) => (
            <details class="rounded-xl bg-gray-50 p-4 open:bg-gray-100 dark:bg-slate-800 dark:open:bg-slate-700">
              <summary class="cursor-pointer font-bold">{question.name}</summary>
              <p class="mt-3 text-muted leading-8">{question.acceptedAnswer?.text}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )
}
