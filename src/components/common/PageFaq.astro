---
import { getFaqQuestionsForPathname } from '~/data/schema/schemaProjection';
const questions = getFaqQuestionsForPathname(Astro.url.pathname);
---

{questions.length > 0 && <section id="faq" class="max-w-5xl mx-auto px-4 sm:px-6 py-10"><div class="rounded-2xl border border-gray-200 bg-white p-6 md:p-8 shadow-sm dark:bg-slate-900 dark:border-slate-800"><h2 class="text-3xl font-bold tracking-tight mb-4">&#1662;&#1585;&#1587;&#1588;&#8204;&#1607;&#1575;&#1740; &#1605;&#1578;&#1583;&#1575;&#1608;&#1604;</h2><div class="space-y-5">{questions.map((question) => <article class="rounded-xl bg-gray-50 p-4 dark:bg-slate-800"><h3 class="font-bold">{question.name}</h3><p class="mt-3 text-muted leading-8">{question.text}</p></article>)}</div></div></section>}
