---
import { getAsset } from '~/utils/permalinks';

const isSearchPage = Astro.url.pathname === '/search/';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="sitemap" href={getAsset('/sitemap-index.xml')} />
<link rel="alternate" type="application/rss+xml" title="خوراک RSS دکتر سعید قزلباش" href={getAsset('/rss.xml')} />
<link
  rel="alternate"
  type="application/ld+json"
  title="گراف هویتی رسمی دکتر سعید قزلباش"
  href={getAsset('/graph.json')}
/>
<link
  rel="alternate"
  type="application/ld+json"
  title="فهرست داده‌های ماشینی دکتر سعید قزلباش"
  href={getAsset('/data/index.json')}
/>
<link rel="alternate" type="text/plain" title="راهنمای LLM دکتر سعید قزلباش" href={getAsset('/llms.txt')} />
<link rel="alternate" type="text/plain" title="راهنمای کامل LLM دکتر سعید قزلباش" href={getAsset('/llms-full.txt')} />

{isSearchPage && <link rel="stylesheet" href={getAsset('/pagefind/pagefind-ui.css')} />}
