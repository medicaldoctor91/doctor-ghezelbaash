---
import { getContactData } from '~/utils/contentData';
import GoogleMapsRatingBadge from '~/components/common/GoogleMapsRatingBadge.astro';
import { getUiCopy } from '~/utils/uiCopy';

export interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  showRatingBadge?: boolean;
}

const uiCopy = await getUiCopy<{
  contentContactBox: {
    defaultTitle: string;
    defaultSubtitle: string;
    phoneLabel: string;
    instagramLabel: string;
    mapLabel: string;
    hoursPrefix: string;
  };
}>();

const {
  id,
  title = uiCopy.contentContactBox.defaultTitle,
  subtitle = uiCopy.contentContactBox.defaultSubtitle,
  showRatingBadge = true,
} = Astro.props;
const contactData = await getContactData();
---

<section {...id ? { id } : {}} class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
  <div class="rounded-2xl border border-gray-200 bg-white p-6 md:p-8 shadow-sm dark:bg-slate-900 dark:border-slate-800">
    <h2 class="text-3xl font-bold tracking-tight mb-3">{title}</h2>
    <p class="text-muted leading-8 mb-6">{subtitle}</p>

    <div class:list={['grid gap-4', showRatingBadge ? 'md:grid-cols-2 lg:grid-cols-4' : 'md:grid-cols-3']}>
      <a
        class="rounded-xl bg-primary p-4 text-white transition hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-primary/50"
        href={contactData.instagram}
        target="_blank"
        rel="noopener noreferrer"
      >
        <strong>{uiCopy.contentContactBox.instagramLabel}</strong>
        <span class="mt-2 block text-sm text-white/85">@doctor.ghezelbaash</span>
      </a>

      <a
        class="rounded-xl bg-gray-50 p-4 transition hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-primary/50 dark:bg-slate-800 dark:hover:bg-slate-700"
        href={`tel:${contactData.phone}`}
      >
        <strong>{uiCopy.contentContactBox.phoneLabel}</strong>
        <span class="block text-sm text-muted mt-2">{contactData.phoneDisplay}</span>
      </a>

      <a
        class="rounded-xl bg-gray-50 p-4 transition hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-primary/50 dark:bg-slate-800 dark:hover:bg-slate-700"
        href={contactData.googleMap}
        target="_blank"
        rel="noopener noreferrer"
      >
        <strong>{uiCopy.contentContactBox.mapLabel}</strong>
        <span class="block text-sm text-muted mt-2">{contactData.address}</span>
      </a>

      {showRatingBadge && <GoogleMapsRatingBadge compact />}
    </div>

    <p class="text-sm text-muted leading-7 mt-5">
      {uiCopy.contentContactBox.hoursPrefix}
      {contactData.openingHours}
    </p>
  </div>
</section>
