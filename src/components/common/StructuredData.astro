---
import fs from 'node:fs';
import path from 'node:path';
import { SITE } from 'astrowind:config';
import { googleMapsRating } from '~/data/googleMapsRating';
import { getPageMedia } from '~/data/pageMedia';

type JsonLdNode = Record<string, any>;
type MasterGraphDocument = { '@context'?: string; '@graph'?: JsonLdNode[] };

const SITE_URL = 'https://www.ghezelbaash.ir';
const SERVICE_PAGE_PATHS = [
  '/botox-kermanshah/',
  '/filler-kermanshah/',
  '/thread-lift-kermanshah/',
  '/aesthetic-concerns-kermanshah/',
];

const normalizePathname = (pathname: string): string => {
  if (!pathname || pathname === '/') return '/';
  return pathname.endsWith('/') ? pathname : `${pathname}/`;
};

const pageUrlForPathname = (pathname: string): string => {
  const normalized = normalizePathname(pathname);
  return `${SITE_URL}${normalized === '/' ? '' : normalized}`;
};

const pageWebPageId = (pathname: string): string => `${pageUrlForPathname(pathname)}#webpage`;

const getNodeId = (node: JsonLdNode | undefined): string | undefined =>
  typeof node?.['@id'] === 'string' ? node['@id'] : undefined;

const getNodeTypes = (node: JsonLdNode | undefined): string[] => {
  const type = node?.['@type'];
  if (Array.isArray(type)) return type.filter((item): item is string => typeof item === 'string');
  return typeof type === 'string' ? [type] : [];
};

const hasNodeType = (node: JsonLdNode | undefined, type: string): boolean =>
  getNodeTypes(node).includes(type);

const getRefId = (value: unknown): string | undefined => {
  if (typeof value === 'string') return value;
  if (value && typeof value === 'object' && typeof (value as JsonLdNode)['@id'] === 'string') {
    return (value as JsonLdNode)['@id'];
  }
  return undefined;
};

const asArray = <T,>(value: T | T[] | undefined): T[] => {
  if (typeof value === 'undefined') return [];
  return Array.isArray(value) ? value : [value];
};

const getItemListReferencedIds = (node: JsonLdNode | undefined): string[] =>
  asArray(node?.itemListElement as unknown)
    .map((item) => {
      if (!item || typeof item !== 'object') return undefined;
      return getRefId((item as JsonLdNode).item);
    })
    .filter((id): id is string => Boolean(id));

const getFaqQuestionIds = (node: JsonLdNode): string[] =>
  asArray(node.mainEntity as unknown)
    .map((item) => getRefId(item))
    .filter((id): id is string => Boolean(id));

const readMasterGraph = (): JsonLdNode[] => {
  const graphPath = path.join(process.cwd(), 'public', 'graph.json');
  const document = JSON.parse(fs.readFileSync(graphPath, 'utf-8')) as MasterGraphDocument;
  return Array.isArray(document['@graph']) ? document['@graph'] : [];
};

const getIdentityNodeIds = (graph: JsonLdNode[]): string[] => {
  const identityLayer = graph.find((node) => getNodeId(node) === `${SITE_URL}/graph.json#identity-layer`);
  const ids = getItemListReferencedIds(identityLayer);

  for (const node of graph) {
    const id = getNodeId(node);
    if (!id) continue;
    if (id === `${SITE_URL}/#contact-point` || hasNodeType(node, 'ContactPoint')) ids.push(id);
  }

  return [...new Set(ids)];
};

const isPillarServiceNode = (node: JsonLdNode): boolean => {
  const id = getNodeId(node);
  if (!id || !hasNodeType(node, 'Service')) return false;
  return SERVICE_PAGE_PATHS.some((servicePath) => id === `${SITE_URL}${servicePath}#service`);
};

const isServiceRelevantToPath = (node: JsonLdNode, pathname: string): boolean => {
  if (!hasNodeType(node, 'Service')) return false;

  const normalized = normalizePathname(pathname);
  const pageUrl = pageUrlForPathname(normalized);
  const id = getNodeId(node);
  const url = typeof node.url === 'string' ? node.url : undefined;

  if (normalized === '/' || normalized === '/dr-saeed-ghezelbash-aesthetic-clinic/') {
    return isPillarServiceNode(node);
  }

  return Boolean(id?.startsWith(`${pageUrl}#`) || url?.startsWith(pageUrl));
};

const isPageScopedNode = (node: JsonLdNode, pathname: string): boolean => {
  const normalized = normalizePathname(pathname);
  const pageUrl = pageUrlForPathname(normalized);
  const pageId = pageWebPageId(normalized);
  const id = getNodeId(node);

  if (id) {
    if (normalized === '/') {
      if (id.startsWith(`${SITE_URL}/#`) && !id.startsWith(`${SITE_URL}/#service-`)) return true;
    } else if (id.startsWith(`${pageUrl}#`)) {
      return true;
    }
  }

  const relationKeys = ['mainEntityOfPage', 'isPartOf', 'partOf', 'about', 'subjectOf'];
  return relationKeys.some((key) =>
    asArray(node[key] as unknown).some((value) => getRefId(value) === pageId)
  );
};

const isFaqForPath = (node: JsonLdNode, pathname: string): boolean => {
  if (!hasNodeType(node, 'FAQPage')) return false;

  const normalized = normalizePathname(pathname);
  const pageUrl = pageUrlForPathname(normalized);
  const id = getNodeId(node);

  if (normalized === '/') return id === `${SITE_URL}/#faq`;
  if (normalized === '/dr-saeed-ghezelbash-aesthetic-clinic/') {
    return id === `${pageUrl}#faq` || id === `${pageUrl}#clinic-faq-kermanshah`;
  }

  return id === `${pageUrl}#faq`;
};

const isBreadcrumbForPath = (node: JsonLdNode, pathname: string): boolean => {
  if (!hasNodeType(node, 'BreadcrumbList')) return false;
  const normalized = normalizePathname(pathname);
  if (normalized === '/') return false;
  return getNodeId(node) === `${pageUrlForPathname(normalized)}#breadcrumb`;
};

const indexById = (graph: JsonLdNode[]): Map<string, JsonLdNode> =>
  new Map(
    graph
      .map((node) => [getNodeId(node), node] as const)
      .filter((entry): entry is readonly [string, JsonLdNode] => Boolean(entry[0]))
  );

const projectPageGraph = (pathnameInput: string, masterGraph: JsonLdNode[]): JsonLdNode[] => {
  const pathname = normalizePathname(pathnameInput);
  const pageId = pageWebPageId(pathname);
  const index = indexById(masterGraph);
  const include = new Set<string>();

  const includeId = (id: string | undefined) => {
    if (id && index.has(id)) include.add(id);
  };

  for (const id of getIdentityNodeIds(masterGraph)) includeId(id);
  includeId(pageId);

  for (const node of masterGraph) {
    const id = getNodeId(node);
    if (!id) continue;

    if (
      isPageScopedNode(node, pathname) ||
      isServiceRelevantToPath(node, pathname) ||
      isFaqForPath(node, pathname) ||
      isBreadcrumbForPath(node, pathname)
    ) {
      include.add(id);
    }
  }

  for (const id of Array.from(include)) {
    const node = index.get(id);
    if (!node || !hasNodeType(node, 'FAQPage')) continue;
    for (const questionId of getFaqQuestionIds(node)) includeId(questionId);
  }

  return masterGraph.filter((node) => {
    const id = getNodeId(node);
    return Boolean(id && include.has(id));
  });
};

const normalizeDateTimeFields = (node: JsonLdNode): JsonLdNode => {
  const types = getNodeTypes(node);
  const shouldNormalize = types.includes('VideoObject') || types.includes('ProfilePage');
  if (!shouldNormalize) return node;

  const copy = { ...node };
  for (const key of ['uploadDate', 'dateModified']) {
    const value = copy[key];
    if (typeof value === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(value)) {
      copy[key] = `${value}T00:00:00+03:30`;
    }
  }

  return copy;
};

const rawPath = Astro.url.pathname;
const pathname = normalizePathname(rawPath);
const masterGraph = readMasterGraph();
const graph = projectPageGraph(pathname, masterGraph);
const siteUrl = SITE?.site || SITE_URL;
const pageMedia = getPageMedia(pathname);
const pageImageUrl = `${siteUrl}${pageMedia.ogImagePath}`;
const pageImageId = `${siteUrl}${pathname === '/' ? '' : pathname}#primary-image`;

const pageImageObject = {
  '@type': 'ImageObject',
  '@id': pageImageId,
  url: pageImageUrl,
  contentUrl: pageImageUrl,
  width: 1200,
  height: 630,
  caption: pageMedia.imageCaption,
};

const logo = {
  '@type': 'ImageObject',
  '@id': `${siteUrl}/#logo`,
  url: `${siteUrl}/favicon.svg`,
  contentUrl: `${siteUrl}/favicon.svg`,
};

const enrichNode = (node: JsonLdNode): JsonLdNode => {
  const id = getNodeId(node);

  if (id === `${siteUrl}/#clinic`) {
    return {
      ...node,
      logo,
      image: pageImageObject,
      hasMap: googleMapsRating.mapsUrl,
      aggregateRating: googleMapsRating.enabledInSchema
        ? {
            '@type': 'AggregateRating',
            ratingValue: googleMapsRating.ratingValue,
            reviewCount: googleMapsRating.ratingCount,
            bestRating: 5,
            worstRating: 1,
          }
        : undefined,
      sameAs: Array.from(
        new Set([...(Array.isArray(node.sameAs) ? node.sameAs : []), googleMapsRating.mapsUrl])
      ),
    };
  }

  if (id === `${siteUrl}/#website`) {
    return {
      ...node,
      logo,
      publisher: { '@id': `${siteUrl}/#clinic` },
    };
  }

  if (hasNodeType(node, 'WebPage')) {
    return {
      ...node,
      image: pageImageObject,
      primaryImageOfPage: { '@id': pageImageId },
      thumbnailUrl: pageImageUrl,
    };
  }

  if (hasNodeType(node, 'Service')) {
    return {
      ...node,
      image: pageImageObject,
    };
  }

  return node;
};

const finalGraph = graph.map((node) => normalizeDateTimeFields(enrichNode(node)));
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [...finalGraph, pageImageObject],
};
---

{
  finalGraph.length > 0 && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData).replace(/</g, '\\u003c')}
    />
  )
}
