---
import { site, absoluteUrl, canonicalImage } from '../data/site.mjs';
import { location } from '../data/location.mjs';
import { publicDataset } from '../data/dataset.mjs';
import { services } from '../data/services.mjs';

const serviceGraph = services.map((service) => ({
  '@type': 'Service',
  '@id': absoluteUrl(`/${service.slug}/#service`),
  name: service.title,
  description: service.description,
  url: absoluteUrl(`/${service.slug}/`),
  provider: { '@id': absoluteUrl('/#clinic') },
  areaServed: { '@type': 'City', name: location.addressLocality }
}));

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': absoluteUrl('/#website'),
      url: absoluteUrl('/'),
      name: site.nameFa,
      alternateName: site.nameEn,
      inLanguage: site.locale,
      publisher: { '@id': absoluteUrl('/#clinic') }
    },
    {
      '@type': 'Organization',
      '@id': absoluteUrl('/#organization'),
      name: site.nameEn,
      alternateName: site.nameFa,
      url: absoluteUrl('/'),
      logo: canonicalImage(site.logo),
      image: canonicalImage(),
      sameAs: [...site.sameAs.person, ...site.sameAs.clinic]
    },
    {
      '@type': ['Person', 'Physician'],
      '@id': absoluteUrl('/#dr-saeed-ghezelbash'),
      name: site.personFa,
      alternateName: [site.personEn, 'Mohammad Saeed Ghezelbash', 'Ghezelbash MS'],
      url: absoluteUrl(site.pages.person),
      image: canonicalImage(),
      workLocation: { '@id': absoluteUrl('/#clinic') },
      sameAs: site.sameAs.person
    },
    {
      '@type': ['MedicalClinic', 'LocalBusiness'],
      '@id': absoluteUrl('/#clinic'),
      name: site.nameFa,
      alternateName: site.nameEn,
      url: absoluteUrl(site.pages.clinic),
      image: canonicalImage(),
      logo: canonicalImage(site.logo),
      telephone: location.telephone,
      address: {
        '@type': 'PostalAddress',
        streetAddress: location.streetAddressFa,
        addressLocality: location.addressLocality,
        addressRegion: location.addressRegion,
        addressCountry: location.addressCountry
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: location.geo.latitude,
        longitude: location.geo.longitude
      },
      hasMap: [location.googleMapsCid, location.googleMapsPlace, location.openStreetMap],
      areaServed: { '@type': 'City', name: location.addressLocality },
      availableService: serviceGraph.map((service) => ({ '@id': service['@id'] })),
      sameAs: site.sameAs.clinic
    },
    {
      '@type': 'Dataset',
      '@id': absoluteUrl('/kg/#dataset'),
      name: publicDataset.name,
      description: publicDataset.description,
      url: absoluteUrl(site.pages.kg),
      identifier: publicDataset.doi,
      license: publicDataset.license,
      datePublished: publicDataset.datePublished,
      version: publicDataset.version,
      creator: { '@id': absoluteUrl('/#dr-saeed-ghezelbash') },
      sameAs: [publicDataset.wikidata, publicDataset.doiUrl, publicDataset.zenodo, publicDataset.huggingFace, publicDataset.github]
    },
    ...serviceGraph
  ]
};
---
<script type="application/ld+json" set:html={JSON.stringify(graph)} />
