---
import { clinic } from '../data/clinic';
---

<header id="site-header" class="site-header">
  <div class="header-notice">
    <div class="header-notice__inner">
      <span class="status-dot" aria-hidden="true"></span>
      <span>پزشکی زیبایی مبتنی بر تشخیص، آناتومی و انتخاب درست بیمار</span>
      <a href="#contact">اطلاعات مراجعه</a>
    </div>
  </div>

  <div class="header-main">
    <a class="brand" href="/" aria-label="صفحه اصلی دکتر سعید قزلباش">
      <span class="brand__seal" aria-hidden="true">ق</span>
      <span class="brand__copy">
        <strong>دکتر سعید قزلباش</strong>
        <small>پزشک زیبایی · کرمانشاه</small>
      </span>
    </a>

    <nav class="primary-nav" aria-label="دسترسی اصلی">
      <a href="#doctor-entity">درباره پزشک</a>
      <a href="#aesthetic-medicine-map">حوزه‌ها</a>
      <a href="#comparison-hub">مقایسه روش‌ها</a>
      <a href="#video-library">ویدئوها</a>
      <a href="#faq">پرسش‌ها</a>
    </nav>

    <div class="header-actions">
      <a class="header-map" href={clinic.mapsUrl} rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s6-5.3 6-12A6 6 0 1 0 6 9c0 6.7 6 12 6 12Zm0-9.3A2.7 2.7 0 1 1 12 6a2.7 2.7 0 0 1 0 5.7Z" /></svg>
        مسیر
      </a>
      <a class="header-call" href={`tel:${clinic.telephone}`}>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.2 3.5 10 7.7 8.5 9.2c.8 1.8 2.3 3.3 4.1 4.1l1.5-1.5 4.3 2.8-.8 3.6c-.2.8-.9 1.3-1.7 1.3A13.5 13.5 0 0 1 4.5 8.1c0-.8.5-1.5 1.3-1.7l1.4-2.9Z" /></svg>
        <span>{clinic.telephoneDisplay}</span>
      </a>
    </div>
  </div>

  <nav class="quick-nav" aria-label="دسترسی سریع به موضوعات">
    <a href="#injectable-procedures">تزریق</a>
    <a href="#skin-rejuvenation">پوست</a>
    <a href="#hair-aesthetics">مو</a>
    <a href="#eye-area">زیر چشم</a>
    <a href="#nose-aesthetics">بینی</a>
    <a href="#jawline-and-chin">چانه و فک</a>
    <a href="#facial-contouring">کانتورینگ</a>
    <a href="#safety-limitations">ایمنی</a>
  </nav>
</header>
