---

<style is:inline>
  :root {
    --aw-font-sans: 'Tahoma', 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    --aw-font-serif: 'Tahoma', 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    --aw-font-heading: 'Tahoma', 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-page: var(--aw-color-text-default);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(3 6 32);
  }

  ::selection {
    background-color: lavender;
  }

  .dark {
    --aw-font-sans: 'Tahoma', 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    --aw-font-serif: 'Tahoma', 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    --aw-font-heading: 'Tahoma', 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-page: var(--aw-color-text-default);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);
  }

  .dark ::selection {
    background-color: black;
    color: snow;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--aw-font-sans);
    text-rendering: optimizeLegibility;
  }

  html,
  body {
    max-width: 100%;
    overflow-x: clip;
  }

  .prose :where(img, video, iframe) {
    max-width: 100%;
    height: auto;
  }

  .prose :where(p, li, td, th) {
    overflow-wrap: anywhere;
  }

  @media (max-width: 767px) {
    body {
      padding-bottom: 4.75rem;
    }

    h1 {
      overflow-wrap: anywhere;
    }

    .prose {
      font-size: 1rem;
    }

    .prose h2 {
      font-size: 1.55rem;
      line-height: 1.45;
    }

    .prose h3 {
      font-size: 1.3rem;
      line-height: 1.5;
    }
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: var(--aw-font-heading);
  }

  a {
    text-underline-offset: 0.18em;
  }

  .pillar-topic-index,
  .pillar-related-routes {
    margin: 2rem 0;
    padding: 1.25rem;
    border: 1px solid rgb(226 232 240);
    border-radius: 1rem;
    background: rgb(248 250 252);
  }

  .dark .pillar-topic-index,
  .dark .pillar-related-routes {
    border-color: rgb(30 41 59);
    background: rgb(15 23 42);
  }

  .pillar-topic-index h2,
  .pillar-related-routes h2 {
    margin-top: 0;
  }

  .pillar-topic-index ul,
  .pillar-related-routes ul {
    margin: 0.75rem 0 0;
    padding-right: 1.25rem;
  }

  .pillar-topic-index li,
  .pillar-related-routes li {
    margin: 0.35rem 0;
  }

  .pillar-topic-index a,
  .pillar-related-routes a {
    color: rgb(1 97 239);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .prose h2[id],
  .prose h3[id],
  .prose h4[id] {
    scroll-margin-top: 6rem;
  }

  .prose table {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
    white-space: nowrap;
  }

  .prose video {
    max-width: 100%;
  }

  @media (max-width: 640px) {
    .prose table {
      font-size: 0.875rem;
    }
  }
</style>
