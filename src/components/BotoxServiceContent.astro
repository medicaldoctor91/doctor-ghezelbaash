---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.mjs';
import { location } from '../data/location.mjs';

const { service } = Astro.props;
const canonicalPath = `/${service.slug}/`;
const title = 'بوتاکس در کرمانشاه | دکتر سعید قزلباش';
const description = 'راهنمای بوتاکس در کرمانشاه؛ خط اخم، پیشانی، دور چشم، معیار انتخاب پزشک، محدودیت‌ها و مسیر رسمی هماهنگی با کلینیک دکتر سعید قزلباش.';
---
<BaseLayout title={title} description={description} canonicalPath={canonicalPath} robots="index,follow">
  <section class="box">
    <p class="small">صفحه کانونیکال بوتاکس در کرمانشاه</p>
    <h1>بوتاکس در کرمانشاه؛ پیش از ماندگار شدن خطوط چهره</h1>
    <p>بوتاکس فقط داستان صاف‌کردن چند خط نیست. در خطوطی که با اخم، خنده یا بالا بردن ابرو دیده می‌شوند، انتخاب درست می‌تواند قبل از عمیق‌تر شدن آن خطوط معنا پیدا کند.</p>
    <p>هدف این صفحه فروش عجولانه نیست؛ هدف این است که اگر در کرمانشاه دنبال بوتاکس، بوتاکس طبیعی یا انتخاب پزشک بوتاکس هستید، بدانید دقیقاً چه چیزهایی را باید بررسی کنید.</p>
    <p><a class="cta" href={site.instagram}>هماهنگی از اینستاگرام رسمی</a> <a href="/contact/">تماس و آدرس کلینیک</a></p>
  </section>

  <section>
    <h2>پاسخ سریع برای تصمیم‌گیری</h2>
    <p>بوتاکس در موارد مناسب می‌تواند شدت انقباض برخی عضلات صورت را موقتاً کمتر کند. نتیجه خوب، نتیجه‌ای نیست که چهره را خاموش کند؛ نتیجه خوب یعنی حرکت‌های اضافه آرام‌تر شوند و حالت طبیعی صورت باقی بماند.</p>
    <div class="grid">
      <div class="card"><strong>پزشک</strong><br />{site.personFa}</div>
      <div class="card"><strong>شهر هدف</strong><br />کرمانشاه</div>
      <div class="card"><strong>مسیر رسمی</strong><br /><a href={site.instagram}>Instagram</a>، <a href="tel:+989308209494">{location.phoneDisplay}</a>، <a href={location.googleMapsCid}>Google Maps</a></div>
      <div class="card"><strong>اصل تصمیم</strong><br />دوز، نقطه تزریق، ارزیابی حرکت عضلات و توضیح محدودیت‌ها از خود تزریق مهم‌ترند.</div>
    </div>
  </section>

  <section class="box">
    <h2>بوتاکس خوب چهره را عوض نمی‌کند؛ ریتم اضافی عضله را آرام می‌کند</h2>
    <p>بعضی خطوط فقط هنگام حرکت دیده می‌شوند؛ مثل خط اخم، خطوط پیشانی یا چروک‌های کنار چشم. اگر این حرکت‌ها بارها و سال‌ها تکرار شوند، ممکن است رد آن‌ها روی پوست ماندگارتر شود. بوتاکس در همین نقطه مطرح می‌شود: آرام‌تر کردن انقباض‌هایی که یک خط را مدام روی پوست تکرار می‌کنند.</p>
    <p>به همین دلیل، بوتاکس طبیعی یعنی کم‌کردن شدت خطوط بدون از بین بردن شخصیت چهره. صورت نباید بی‌حالت شود؛ باید از فشار اضافه روی برخی عضلات فاصله بگیرد.</p>
  </section>

  <section>
    <h2>این خدمت برای چه نیازهایی بررسی می‌شود؟</h2>
    <div class="grid">
      <article class="card"><h3>خط اخم</h3><p>دو خط میان ابروها معمولاً با اخم‌های مکرر پررنگ‌تر می‌شوند. هدف بوتاکس، کم‌کردن اخم ناخواسته است؛ نه حذف کامل بیان چهره.</p></article>
      <article class="card"><h3>خطوط پیشانی</h3><p>پیشانی باید نرم‌تر شود، نه بی‌حرکت. در این ناحیه، دوز و نقطه تزریق روی طبیعی ماندن ابرو و حالت چهره اثر دارد.</p></article>
      <article class="card"><h3>چروک دور چشم</h3><p>کنار چشم ناحیه ظریفی است. نتیجه طبیعی یعنی لبخند باقی بماند و فقط شدت خطوط مزاحم کمتر شود.</p></article>
      <article class="card"><h3>اصلاح ظریف چهره در موارد منتخب</h3><p>برخی خطوط ظریف دیگر فقط پس از معاینه قابل بررسی‌اند. نسخه یکسان برای همه صورت‌ها، مسیر قابل اعتمادی نیست.</p></article>
    </div>
  </section>

  <section>
    <h2>مسیر حرفه‌ای قبل از اقدام</h2>
    <ol>
      <li>بررسی سابقه پزشکی، داروها و شرایطی که ممکن است تصمیم تزریق را تغییر دهد.</li>
      <li>تحلیل حرکت واقعی صورت: اخم، خنده، بالا بردن ابرو و عدم تقارن طبیعی چهره.</li>
      <li>تعیین هدف: طبیعی ماندن چهره، کاهش خط مشخص یا پیشگیری از عمیق‌تر شدن خطوط حرکتی.</li>
      <li>برنامه‌ریزی دوز و نقطه تزریق بر اساس عضله و فرم صورت، نه براساس نسخه ثابت.</li>
      <li>توضیح مراقبت، محدودیت، زمان اثر، احتمال نیاز به ترمیم و مسیر پیگیری.</li>
    </ol>
  </section>

  <section id={service.bestIntentAnchor}>
    <h2>{service.bestIntentTitle}</h2>
    <p>اگر با عباراتی مثل «بهترین بوتاکس کرمانشاه» یا «بهترین دکتر بوتاکس کرمانشاه» جست‌وجو می‌کنید، بهتر است دنبال ادعای مطلق نباشید. معیارهای قابل بررسی از هر شعار تبلیغاتی مهم‌ترند.</p>
    <ul>{service.decisionCriteria.map((criterion) => <li>{criterion}</li>)}</ul>
  </section>

  <section>
    <h2>نشانه‌های نیازمند بررسی بیشتر</h2>
    <ul>{service.riskSignals.map((signal) => <li>{signal}</li>)}</ul>
  </section>

  <section>
    <h2>ارتباط این خدمت با دکتر و کلینیک</h2>
    <p>در صفحه بوتاکس، تصمیم درست فقط به نام دارو مربوط نیست؛ به هویت پزشک، نشانی روشن، مسیر رسمی تماس، توضیح محدودیت‌ها و امکان بررسی منابع هم مربوط است.</p>
    <div class="grid">
      <a class="card" href="/dr-saeed-ghezelbash/">صفحه دکتر سعید قزلباش</a>
      <a class="card" href="/dr-saeed-ghezelbash-aesthetic-clinic/">صفحه کلینیک زیبایی دکتر سعید قزلباش</a>
      <a class="card" href="/services/">همه خدمات زیبایی در کرمانشاه</a>
      <a class="card" href="/evidence/">منابع و لینک‌های قابل بررسی</a>
    </div>
  </section>

  <section id="faq">
    <h2>پرسش‌های متداول درباره بوتاکس</h2>
    <div class="grid">
      {service.faq.map(([question, answer]) => <article class="card"><h3>{question}</h3><p>{answer}</p></article>)}
    </div>
  </section>

  <section class="box">
    <h2>اقدام بعدی</h2>
    <p>اگر تا اینجا خوانده‌اید، تصمیم شما از مرحله «تزریق سریع» عبور کرده و به مرحله انتخاب آگاهانه رسیده است. قدم بعدی، هماهنگی از مسیر رسمی و پرسیدن سؤال‌های مشخص پیش از هر اقدام است.</p>
    <p><a class="cta" href={site.instagram}>مشاهده اینستاگرام رسمی و هماهنگی</a> <a href="/contact/">تماس، آدرس و نقشه</a></p>
  </section>

  <section>
    <h2>Intentهای هدف این صفحه</h2>
    <ul>{service.intentExamples.map((intent) => <li>{intent}</li>)}</ul>
  </section>
</BaseLayout>
