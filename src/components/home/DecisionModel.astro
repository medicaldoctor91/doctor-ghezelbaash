---
import { Activity, Layers3, ScanFace, ShieldCheck } from '@lucide/astro';

const layers = [
  {
    number: '۰۱',
    title: 'سطح و بافت',
    text: 'رنگ، التهاب، اسکار، خشکی و کیفیت پوست؛ چیزی که با نور و لمس خوانده می‌شود.',
    icon: ScanFace,
  },
  {
    number: '۰۲',
    title: 'حرکت و دینامیک',
    text: 'عضله، لبخند، جبران ابرو و عدم‌تقارن؛ عکس ثابت فقط نیمی از این لایه را نشان می‌دهد.',
    icon: Activity,
  },
  {
    number: '۰۳',
    title: 'حجم و ساختار',
    text: 'حمایت استخوانی، چربی، افت بافت و نسبت‌های صورت؛ مرزی که ابزار نامتناسب را متوقف می‌کند.',
    icon: Layers3,
  },
];
---

<section id="decision-model" class="section section--tint" aria-labelledby="decision-title">
  <div class="shell">
    <div class="section-heading section-heading--split">
      <div>
        <p class="eyebrow">مدل تصمیم سه‌لایه</p>
        <h2 id="decision-title">اول مکانیسم؛ بعد ابزار</h2>
      </div>
      <p>
        یک ظاهر می‌تواند از چند علت ساخته شود. تشخیص، ابزار را انتخاب می‌کند؛ نام خدمت نباید تشخیص را به عقب براند.
      </p>
    </div>

    <div class="layer-grid">
      {layers.map(({ number, title, text, icon: Icon }) => (
        <article class="layer-card">
          <div class="layer-card__top">
            <span>{number}</span>
            <Icon size={26} aria-hidden="true" />
          </div>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>

    <div id="clinical-process" class="decision-note">
      <ShieldCheck size={28} aria-hidden="true" />
      <div>
        <strong>مرز درمان بخشی از درمان است.</strong>
        <p>اگر قدرت روش از شدت مسئله کمتر باشد، تعویق، تغییر مسیر یا ارجاع از اجرای یک مداخلهٔ نامتناسب دقیق‌تر است.</p>
      </div>
    </div>
  </div>
</section>

