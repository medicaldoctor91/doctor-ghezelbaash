---
import { Activity, Layers3, ScanFace, ShieldCheck } from '@lucide/astro';

const layers = [
  {
    number: '۰۱',
    title: 'پوست و بافت',
    text: 'رنگ، التهاب، جای جوش، خشکی و کیفیت پوست؛ چیزهایی که با نور، لمس و سابقهٔ درمان بررسی می‌شوند.',
    icon: ScanFace,
  },
  {
    number: '۰۲',
    title: 'حرکت صورت',
    text: 'عضلات پیشانی، اخم، لبخند و ابرو؛ چون عکس ثابت همیشه رفتار واقعی صورت را نشان نمی‌دهد.',
    icon: Activity,
  },
  {
    number: '۰۳',
    title: 'حجم و فرم صورت',
    text: 'استخوان، چربی، افت بافت و نسبت‌های صورت؛ برای اینکه فیلر، نخ یا جراحی در جای درست مطرح شوند.',
    icon: Layers3,
  },
];
---

<section id="decision-model" class="section section--tint" aria-labelledby="decision-title">
  <div class="shell">
    <div class="section-heading section-heading--split">
      <div>
        <p class="eyebrow">معاینهٔ دقیق صورت</p>
        <h2 id="decision-title">یک ظاهر مشابه می‌تواند علت‌های متفاوتی داشته باشد</h2>
      </div>
      <p>
        به همین دلیل انتخاب درمان از اسم روش شروع نمی‌شود. ابتدا باید مشخص شود مشکل اصلی کجاست و هر روش واقعاً چه چیزی را می‌تواند تغییر دهد.
      </p>
    </div>

    <div class="layer-grid">
      {layers.map(({ number, title, text, icon: Icon }) => (
        <article class="layer-card">
          <div class="layer-card__top">
            <span>{number}</span>
            <Icon size={26} aria-hidden="true" />
          </div>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>

    <div id="clinical-process" class="decision-note">
      <ShieldCheck size={28} aria-hidden="true" />
      <div>
        <strong>گاهی بهترین انتخاب، انجام ندادن یک روش است.</strong>
        <p>وقتی یک روش برای مشکل شما کافی یا مناسب نیست، تغییر مسیر از انجام درمانی که نتیجهٔ منطقی ندارد بهتر است.</p>
      </div>
    </div>
  </div>
</section>
