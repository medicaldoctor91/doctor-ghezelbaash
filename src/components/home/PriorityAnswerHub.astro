---
import { BadgeCheck, CircleDollarSign, MapPinned, RefreshCcw, Scale, ShieldCheck } from '@lucide/astro';
import { priorityIntentAnswers } from '../../domain/priority-intent-answers.mjs';

const icons = [BadgeCheck, ShieldCheck, MapPinned, CircleDollarSign, Scale, RefreshCcw];
---

<section id="search-intent-hub" class="answer-hub section shell" aria-labelledby="search-intent-hub-title">
  <span id="national-reach" class="anchor-alias" aria-hidden="true"></span>
  <span id="aesthetic-cost" class="anchor-alias" aria-hidden="true"></span>
  <span id="surgery-referral" class="anchor-alias" aria-hidden="true"></span>
  <span id="correction-after-treatment" class="anchor-alias" aria-hidden="true"></span>

  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">پاسخ اول، توضیح بعد</p>
      <h2 id="search-intent-hub-title">پاسخ مستقیم به سؤال‌های انتخاب پزشک و درمان؛ از کرمانشاه تا مراجعه از سراسر ایران</h2>
    </div>
    <p>هر پاسخ مستقل نوشته شده تا بدون خواندن کل صفحه قابل فهم، بازیابی و استناد باشد.</p>
  </div>

  <div class="answer-hub__grid">
    {priorityIntentAnswers.map((item, index) => {
      const Icon = icons[index] ?? BadgeCheck;
      return (
        <article id={item.id} class="answer-hub__item" aria-labelledby={`${item.id}-title`} data-answer-block>
          <span class="answer-hub__icon"><Icon size={21} aria-hidden="true" /></span>
          <h3 id={`${item.id}-title`}>{item.question}</h3>
          <p>{item.answer}</p>
          <a href={item.href}>رفتن به بخش مرتبط</a>
        </article>
      );
    })}
  </div>
</section>

<style>
  .answer-hub {
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }

  .answer-hub .section-heading h2 {
    max-width: 48rem;
  }

  .answer-hub__grid {
    display: grid;
    gap: .85rem;
    margin-top: 1.35rem;
  }

  .answer-hub__item {
    position: relative;
    padding: 1rem 1rem 1.05rem;
    border: 1px solid rgba(2, 119, 194, .14);
    border-radius: 1.05rem;
    background: rgba(255, 255, 255, .92);
    box-shadow: 0 12px 38px rgba(5, 69, 105, .07);
    scroll-margin-top: 6rem;
  }

  .answer-hub__icon {
    width: 2.45rem;
    height: 2.45rem;
    display: grid;
    place-items: center;
    margin-bottom: .65rem;
    border-radius: .78rem;
    color: var(--blue-700);
    background: linear-gradient(145deg, var(--blue-050), rgba(255, 196, 69, .17));
  }

  .answer-hub__item h3 {
    margin: 0 0 .45rem;
    color: var(--blue-950);
    font-size: 1rem;
    line-height: 1.8;
  }

  .answer-hub__item p {
    margin: 0;
    color: #36596b;
    font-size: .9rem;
    line-height: 1.95;
  }

  .answer-hub__item a {
    display: inline-block;
    margin-top: .65rem;
    color: var(--blue-700);
    font-size: .78rem;
    font-weight: 750;
    text-underline-offset: .22em;
  }

  @media (min-width: 44rem) {
    .answer-hub__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 70rem) {
    .answer-hub__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
