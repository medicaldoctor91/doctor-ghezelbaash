---
const images = [
  { base: 'doctor-with-staff', width: 1600, height: 1067, alt: 'دکتر سعید قزلباش همراه با تیم کلینیک', wide: true },
  { base: 'clinic-interior', width: 768, height: 1024, alt: 'فضای داخلی کلینیک زیبایی دکتر سعید قزلباش' },
  { base: 'clinic-waiting-room', width: 768, height: 1024, alt: 'فضای انتظار کلینیک زیبایی دکتر سعید قزلباش' },
  { base: 'clinic-corridor', width: 768, height: 1365, alt: 'راهروی کلینیک زیبایی دکتر سعید قزلباش' },
  { base: 'clinic-interior-2', width: 768, height: 1024, alt: 'نمای دیگری از فضای بالینی کلینیک' },
];
---

<section id="clinic" class="section shell" aria-labelledby="clinic-title">
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">محیط واقعی کلینیک</p>
      <h2 id="clinic-title">پزشک، تیم و فضای مراجعه</h2>
    </div>
    <p>تصاویر همین کلینیک در کرمانشاه‌اند؛ بدون عکس stock و بدون ادعایی که از تصویر قابل اثبات نیست.</p>
  </div>

  <div class="gallery-grid">
    {images.map((image) => (
      <figure class:list={['gallery-item', { 'gallery-item--wide': image.wide }]}>
        <picture>
          <source type="image/avif" srcset={`/images/responsive/${image.base}-480.avif 480w, /images/responsive/${image.base}-768.avif 768w${image.wide ? `, /images/responsive/${image.base}-1200.avif 1200w` : ''}`} sizes={image.wide ? '(min-width: 900px) 50vw, 100vw' : '(min-width: 900px) 24vw, 50vw'} />
          <source type="image/webp" srcset={`/images/responsive/${image.base}-480.webp 480w, /images/responsive/${image.base}-768.webp 768w${image.wide ? `, /images/responsive/${image.base}-1200.webp 1200w` : ''}`} sizes={image.wide ? '(min-width: 900px) 50vw, 100vw' : '(min-width: 900px) 24vw, 50vw'} />
          <img src={`/images/responsive/${image.base}-${image.wide ? 1200 : 768}.jpg`} alt={image.alt} width={image.width} height={image.height} loading="lazy" decoding="async" />
        </picture>
      </figure>
    ))}
  </div>
</section>

