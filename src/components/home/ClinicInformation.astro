---
import { Clock3, MapPin, MessageCircleMore, Phone, Star } from '@lucide/astro';
import { site } from '../../domain/entities';
import { galleryImages, videos } from '../../domain/media.mjs';
import { homepageEntityIds } from '../../domain/homepage-sections';

const clinicImages = galleryImages.filter((image: any) => image.id.startsWith('clinic-'));
const clinicVideo = videos.find((video: any) => video.sectionId === 'clinic-information-kermanshah');
const srcset = (image: any, format: string) => image.widths.map((width: number) => `/images/responsive/${image.base}-${width}.${format} ${width}w`).join(', ');
const observedAt = new Intl.DateTimeFormat('fa-IR', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'Asia/Tehran' }).format(new Date(`${site.googleBusinessProfile.observedAt}T12:00:00+03:30`));
---

<section id="clinic-information-kermanshah" class="clinic-info section" aria-labelledby="clinic-information-kermanshah-title">
  <span id={homepageEntityIds.clinic} class="anchor-alias" aria-hidden="true"></span>
  <div class="shell">
    <div class="section-heading section-heading--split">
      <div>
        <p class="eyebrow">انتیتی مستقل محل فعالیت</p>
        <h2 id="clinic-information-kermanshah-title">کلینیک محل فعالیت دکتر سعید قزلباش در کرمانشاه</h2>
      </div>
      <p>اطلاعات کلینیک، شهرت عمومی محل مراجعه و موقعیت مکانی را نشان می‌دهد؛ هویت و مسئولیت پزشکی دکتر سعید قزلباش به‌صورت مستقل ثبت شده است.</p>
    </div>

    <div class="clinic-info__grid">
      <div class="clinic-info__copy medical-article">
        <p><strong>{site.clinicName}</strong> در {site.address} محل فعالیت دکتر سعید قزلباش است. برای هماهنگی مراجعه، سابقه درمان‌های قبلی، نام مواد تزریق‌شده، داروهای مصرفی و تصاویر مربوط به تغییر یا عارضه را آماده کنید.</p>
        <p>امتیاز عمومی زیر از Google Maps و متعلق به انتیتی کلینیک است. این داده تجربه عمومی مراجعه‌کنندگان را توصیف می‌کند و به‌تنهایی تضمین نتیجه درمان یا جایگزین بررسی هویت پزشک، کاندید مناسب و محدودیت روش نیست.</p>

        <dl class="clinic-info__details">
          <div><dt><Star size={19} aria-hidden="true" /> امتیاز Google Maps</dt><dd><bdi dir="ltr">{site.googleBusinessProfile.ratingValue.toFixed(1)} / {site.googleBusinessProfile.bestRating}</bdi> · {site.googleBusinessProfile.ratingCount.toLocaleString('fa-IR')} ارزیابی</dd></div>
          <div><dt><MapPin size={19} aria-hidden="true" /> نشانی</dt><dd>{site.address}</dd></div>
          <div><dt><Phone size={19} aria-hidden="true" /> تلفن</dt><dd><a href={`tel:${site.phone}`}><bdi dir="ltr">{site.phoneDisplay}</bdi></a></dd></div>
          <div><dt><Clock3 size={19} aria-hidden="true" /> ساعات پاسخ‌گویی ثبت‌شده</dt><dd>{site.hours}</dd></div>
          <div><dt><MessageCircleMore size={19} aria-hidden="true" /> تاریخ مشاهده داده امتیاز</dt><dd><time datetime={site.googleBusinessProfile.observedAt}>{observedAt}</time></dd></div>
        </dl>

        <p class="clinic-info__links">
          <a href={site.maps} target="_blank" rel="noopener noreferrer external">بازکردن موقعیت کلینیک در Google Maps</a>
          <span aria-hidden="true"> · </span>
          <a href={site.openStreetMap} target="_blank" rel="noopener noreferrer external">مشاهده موقعیت در OpenStreetMap</a>
          <span aria-hidden="true"> · </span>
          <a href={site.placeWikidata} target="_blank" rel="noopener noreferrer external">انتیتی کلینیک در Wikidata</a>
        </p>
      </div>

      <div class="clinic-info__media" role="group" aria-label="تصاویر کلینیک">
        {clinicImages.slice(0, 4).map((image: any) => (
          <figure data-contextual-image>
            <picture>
              <source type="image/avif" srcset={srcset(image, 'avif')} sizes="(min-width: 928px) 18vw, 50vw" />
              <source type="image/webp" srcset={srcset(image, 'webp')} sizes="(min-width: 928px) 18vw, 50vw" />
              <img src={`/images/responsive/${image.base}-${Math.max(...image.widths)}.jpg`} alt={image.alt} width={image.width} height={image.height} loading="lazy" decoding="async" />
            </picture>
            <figcaption>{image.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>

    {clinicVideo && (
      <figure id={`video-${clinicVideo.id}`} class="clinic-info__video article-video">
        <div class="article-video__media">
          <video controls playsinline preload="none" poster={clinicVideo.thumbnail} width={clinicVideo.width} height={clinicVideo.height} aria-labelledby={`video-${clinicVideo.id}-title`} aria-describedby={`video-${clinicVideo.id}-description`}>
            <source src={`/videos/${clinicVideo.file}`} type="video/mp4" />
            {clinicVideo.chapterTrack && <track kind="chapters" src={clinicVideo.chapterTrack} srclang="fa" label="فصل‌بندی فارسی" default />}
            مرورگر شما پخش ویدئو را پشتیبانی نمی‌کند.
          </video>
        </div>
        <figcaption class="article-video__body">
          <h3 id={`video-${clinicVideo.id}-title`}>{clinicVideo.title}</h3>
          <p id={`video-${clinicVideo.id}-description`}>{clinicVideo.description}</p>
        </figcaption>
      </figure>
    )}
  </div>
</section>

<style>
  .clinic-info{scroll-margin-top:6rem}.clinic-info__grid{display:grid;gap:1.2rem;margin-top:1.3rem}.clinic-info__copy{padding:clamp(1rem,3vw,1.5rem);border:1px solid rgba(2,119,194,.14);border-radius:1.1rem;background:rgba(255,255,255,.94)}.clinic-info__details{display:grid;gap:.65rem;margin:1.1rem 0}.clinic-info__details div{padding:.75rem .85rem;border:1px solid rgba(2,119,194,.1);border-radius:.85rem;background:rgba(247,251,254,.82)}.clinic-info__details dt{display:flex;gap:.4rem;align-items:center;color:var(--muted);font-size:.76rem;font-weight:750}.clinic-info__details dd{margin:.35rem 0 0;color:var(--blue-950);font-weight:800;line-height:1.8}.clinic-info__links{font-size:.86rem}.clinic-info__media{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.65rem}.clinic-info__media figure{margin:0;overflow:hidden;border-radius:.9rem;background:#fff}.clinic-info__media picture,.clinic-info__media img{display:block;width:100%;height:100%}.clinic-info__media img{object-fit:cover;aspect-ratio:4/5}.clinic-info__media figcaption{padding:.5rem;color:var(--muted);font-size:.7rem;line-height:1.6}.clinic-info__video{max-width:58rem;margin:1.5rem auto 0}.clinic-info__video h3{margin:.3rem 0;color:var(--blue-950);font-size:1.05rem;line-height:1.8}@media(min-width:62rem){.clinic-info__grid{grid-template-columns:minmax(0,1.15fr) minmax(24rem,.85fr)}.clinic-info__details{grid-template-columns:repeat(2,minmax(0,1fr))}}
</style>
