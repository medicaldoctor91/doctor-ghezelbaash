---
import { Braces, Database, FileCode2, Network } from '@lucide/astro';
import { site } from '../../domain/entities';
import { resolveHomepageExternalDirectory } from '../../domain/homepage-external-directory.mjs';
import { homepageSectionById } from '../../domain/homepage-sections';

const graphSection = homepageSectionById.get('knowledge-graph-and-datasets');
if (!graphSection) throw new Error('Canonical machine-data section is missing from the Homepage registry.');
const machineGroup = resolveHomepageExternalDirectory(site).find((group: any) => group.id === 'machine-data');
if (!machineGroup) throw new Error('Stage 7 machine-data directory group is missing.');

const presentation: Record<string, { text: string; icon: any }> = {
  'knowledge-graph-jsonld': {
    text: 'نمایش ماشین‌خوان انتیتی پزشک، کلینیک، خدمات، ویدئوها، منابع و روابط اصلی سایت.',
    icon: Network,
  },
  'huggingface-dataset': {
    text: 'مخزن عمومی داده‌های انتیتی و شواهد ساختاریافته دکتر سعید قزلباش.',
    icon: Database,
  },
  'dataset-wikidata': {
    text: `شناسه ${site.datasetWikidataId} برای دیتاست ساختاریافته منتشرشده.`,
    icon: Braces,
  },
  'zenodo-archive': {
    text: 'نسخه آرشیوشده و دارای DOI از داده منتشرشده برای ارجاع پایدار.',
    icon: Database,
  },
  'llms-text': {
    text: 'خلاصه مسیرهای اصلی و منابع قابل استفاده برای سامانه‌های زبانی.',
    icon: FileCode2,
  },
  'ai-text': {
    text: 'بیانیه تکمیلی ماشین‌خوان در مسیر استاندارد سایت.',
    icon: FileCode2,
  },
  'github-source-repository': {
    text: 'کد منبع، compilerها، Registryها و validatorهای پروژه.',
    icon: FileCode2,
  },
};
---

<section
  id={graphSection.id}
  class="machine-sources section shell"
  aria-labelledby={`${graphSection.id}-title`}
  data-stage-seven-machine-data
>
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">داده‌های قابل بررسی</p>
      <h2 id={`${graphSection.id}-title`}>{graphSection.title}</h2>
    </div>
    <p>این بخش فقط دروازه قابل‌مشاهده منابع ماشین‌خوان موجود است. فایل تازه و موازی برای هر خدمت، ویدئو یا سکشن ساخته نمی‌شود.</p>
  </div>

  <div class="machine-sources__intro medical-article">
    <p><strong>منبع اصلی حقیقت، محتوای قابل‌مشاهده همین Homepage است.</strong> JSON-LD داخلی و فایل گراف دانش باید همان نام‌ها، عنوان‌ها، شناسه‌ها و روابط را بازتاب دهند. منابع آرشیوی و Datasetها نیز فقط در محدوده داده‌ای که واقعاً منتشر کرده‌اند استفاده می‌شوند.</p>
  </div>

  <div class="machine-sources__grid">
    {machineGroup.links.map((resource: any) => {
      const details = presentation[resource.id];
      if (!details) throw new Error(`Stage 7 machine resource presentation is missing: ${resource.id}`);
      const Icon = details.icon;
      return (
        <a
          class="machine-sources__item"
          href={resource.href}
          target={resource.external ? '_blank' : undefined}
          rel={resource.external ? 'noopener noreferrer external' : undefined}
          data-machine-resource={resource.id}
        >
          <span><Icon size={22} aria-hidden="true" /></span>
          <strong>{resource.label}</strong>
          <p>{details.text}</p>
        </a>
      );
    })}
  </div>
</section>

<style>
  .machine-sources{scroll-margin-top:6rem}.machine-sources__intro{max-width:68rem;margin:1.1rem 0 1.4rem}.machine-sources__grid{display:grid;gap:.75rem}.machine-sources__item{display:grid;grid-template-columns:auto minmax(0,1fr);gap:.3rem .7rem;align-items:start;padding:1rem;border:1px solid rgba(2,119,194,.14);border-radius:1rem;color:inherit;background:rgba(255,255,255,.94);text-decoration:none;box-shadow:0 10px 30px rgba(5,69,105,.055)}.machine-sources__item>span{grid-row:1/3;display:grid;width:2.5rem;height:2.5rem;place-items:center;border-radius:.8rem;color:var(--blue-700);background:rgba(2,119,194,.08)}.machine-sources__item strong{color:var(--blue-950);line-height:1.7}.machine-sources__item p{margin:0;color:var(--muted);font-size:.8rem;line-height:1.8}@media(min-width:48rem){.machine-sources__grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(min-width:72rem){.machine-sources__grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
</style>
