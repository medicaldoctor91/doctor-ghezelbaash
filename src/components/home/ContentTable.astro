---
import { ChevronDown, ListTree } from '@lucide/astro';
import { homepageSections, homepageTocGroups } from '../../domain/homepage-sections';
---

<nav id="content-table" class="content-table shell" aria-labelledby="content-table-title">
  <div class="content-table__heading">
    <span class="content-table__icon"><ListTree size={22} aria-hidden="true" /></span>
    <div>
      <p class="eyebrow">نقشه مطالعه این صفحه</p>
      <h2 id="content-table-title">فهرست کامل راهنمای پزشکی زیبایی</h2>
      <p>هر لینک مستقیماً به یک بخش واقعی و یکتا در همین Homepage می‌رسد.</p>
    </div>
  </div>

  <div class="content-table__groups">
    {homepageTocGroups.map((group, groupIndex) => {
      const sections = homepageSections.filter((section) => section.tocGroup === group.id && section.includeInToc);
      return (
        <details class="content-table__group" open={groupIndex === 0}>
          <summary>
            <span>{group.title}</span>
            <ChevronDown size={18} aria-hidden="true" />
          </summary>
          <ol>
            {sections.map((section) => (
              <li><a href={`#${section.id}`}>{section.title}</a></li>
            ))}
          </ol>
        </details>
      );
    })}
  </div>
</nav>

<style>
  .content-table {
    padding-block: clamp(1.2rem, 4vw, 3rem);
    scroll-margin-top: 6rem;
  }

  .content-table__heading {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: .85rem;
    align-items: start;
    padding: clamp(1rem, 3vw, 1.5rem);
    border: 1px solid rgba(2, 119, 194, .14);
    border-radius: 1.15rem 1.15rem 0 0;
    background: linear-gradient(145deg, rgba(239, 248, 255, .96), rgba(255, 255, 255, .96));
  }

  .content-table__icon {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border-radius: .85rem;
    color: var(--blue-700);
    background: rgba(2, 119, 194, .1);
  }

  .content-table__heading h2 {
    margin: .2rem 0 .35rem;
    color: var(--blue-950);
    font-size: clamp(1.25rem, 3vw, 1.8rem);
    line-height: 1.65;
  }

  .content-table__heading p:last-child {
    margin: 0;
    color: var(--muted);
    line-height: 1.9;
  }

  .content-table__groups {
    display: grid;
    gap: .65rem;
    padding: clamp(.85rem, 2vw, 1.25rem);
    border: 1px solid rgba(2, 119, 194, .14);
    border-top: 0;
    border-radius: 0 0 1.15rem 1.15rem;
    background: rgba(255, 255, 255, .92);
  }

  .content-table__group {
    border: 1px solid rgba(2, 119, 194, .12);
    border-radius: .9rem;
    background: rgba(247, 251, 254, .75);
  }

  .content-table__group summary {
    display: flex;
    gap: .65rem;
    align-items: center;
    justify-content: space-between;
    padding: .8rem .9rem;
    color: var(--blue-950);
    font-weight: 800;
    cursor: pointer;
    list-style: none;
  }

  .content-table__group summary::-webkit-details-marker {
    display: none;
  }

  .content-table__group summary svg {
    flex: 0 0 auto;
    transition: transform .2s ease;
  }

  .content-table__group[open] summary svg {
    transform: rotate(180deg);
  }

  .content-table__group ol {
    display: grid;
    gap: .45rem;
    margin: 0;
    padding: 0 .95rem .95rem 2.4rem;
  }

  .content-table__group a {
    color: #174f6c;
    font-size: .9rem;
    line-height: 1.8;
    text-decoration-thickness: .07em;
    text-underline-offset: .2em;
  }

  @media (min-width: 60rem) {
    .content-table__groups {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .content-table__group:last-child {
      grid-column: 1 / -1;
    }
  }
</style>
