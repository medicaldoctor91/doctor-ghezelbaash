---
import { AtSign, Clock3, MapPin, Phone } from '@lucide/astro';
import { site } from '../../domain/entities';
import { galleryImages } from '../../domain/media.mjs';

const clinicImages = galleryImages.filter((image: any) => image.id.startsWith('clinic-'));
const srcset = (image: any, format: string) => image.widths
  .map((width: number) => `/images/responsive/${image.base}-${width}.${format} ${width}w`)
  .join(', ');
---

<section id="contact" class="section contact-section" aria-labelledby="contact-title">
  <span id="clinic" class="anchor-alias" aria-hidden="true"></span>
  <div class="shell contact-card">
    <div class="contact-card__copy">
      <p class="eyebrow">هماهنگی مراجعه</p>
      <h2 id="contact-title">با درخواست آماده نیایید؛ با مسئلهٔ واقعی بیایید</h2>
      <p>سابقهٔ درمان، نام مواد قبلی، داروها و نتیجه‌ای که واقعاً می‌خواهید را همراه داشته باشید. ممکن است پاسخ معاینه درمان، تعویق یا تغییر مسیر باشد.</p>
      <div class="contact-card__actions">
        <a class="button button--primary" href={`tel:${site.phone}`}><Phone size={19} aria-hidden="true" /> تماس با کلینیک</a>
        <a class="button button--light" href={site.maps} target="_blank" rel="noopener noreferrer external"><MapPin size={19} aria-hidden="true" /> مسیریابی</a>
      </div>
    </div>
    <dl class="contact-details">
      <div>
        <dt><Phone size={20} aria-hidden="true" /> تلفن</dt>
        <dd><a href={`tel:${site.phone}`}><bdi dir="ltr">{site.phoneDisplay}</bdi></a></dd>
      </div>
      <div>
        <dt><MapPin size={20} aria-hidden="true" /> نشانی</dt>
        <dd>{site.address}</dd>
      </div>
      <div>
        <dt><Clock3 size={20} aria-hidden="true" /> ساعات پاسخ‌گویی</dt>
        <dd>{site.hours}</dd>
      </div>
      <div>
        <dt><AtSign size={20} aria-hidden="true" /> اینستاگرام رسمی</dt>
        <dd><a href={site.instagram} target="_blank" rel="me noopener noreferrer external"><bdi dir="ltr">{site.instagramHandle}</bdi></a></dd>
      </div>
    </dl>

    <div class="contact-card__media" role="group" aria-label="تصاویر واقعی محیط مراجعه">
      {clinicImages.map((image: any) => (
        <figure data-contextual-image>
          <picture>
            <source type="image/avif" srcset={srcset(image, 'avif')} sizes="(min-width: 928px) 18vw, 50vw" />
            <source type="image/webp" srcset={srcset(image, 'webp')} sizes="(min-width: 928px) 18vw, 50vw" />
            <img
              src={`/images/responsive/${image.base}-${Math.max(...image.widths)}.jpg`}
              alt={image.alt}
              width={image.width}
              height={image.height}
              loading="lazy"
              decoding="async"
            />
          </picture>
        </figure>
      ))}
    </div>
  </div>
</section>
