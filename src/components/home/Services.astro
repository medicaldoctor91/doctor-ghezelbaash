---
import { Activity, CircleDot, Droplets, ScanFace, Sparkles, Syringe, UserRoundSearch } from '@lucide/astro';

const services = [
  {
    id: 'service-botulinum-toxin',
    aliases: [],
    title: 'بوتاکس و حرکت عضله',
    text: 'برای الگوهای وابسته به حرکت؛ با ارزیابی ابرو، پلک، لبخند، تقارن و عملکرد.',
    icon: Activity,
    href: '#botulinum-toxin-guide',
  },
  {
    id: 'service-dermal-filler',
    aliases: [],
    title: 'فیلر و حمایت حجمی',
    text: 'برای کمبود حجم یا حمایت انتخابی؛ نه برای سنگین‌کردن بافتی که پایین آمده است.',
    icon: Syringe,
    href: '#dermal-fillers-revision',
  },
  {
    id: 'service-thread-lift',
    aliases: [],
    title: 'لیفت نخ',
    text: 'برای شلی محدود و کاندید منتخب؛ با مرزبندی روشن در برابر افتادگی شدید و جراحی.',
    icon: Sparkles,
    href: '#thread-lift-surgery-boundary',
  },
  {
    id: 'service-subcision',
    aliases: ['service-acne-scar-treatment'],
    title: 'اسکار، آکنه و سابسیژن',
    text: 'تفکیک لک، التهاب، rolling، boxcar و ice-pick پیش از انتخاب ابزار یا درمان ترکیبی.',
    icon: CircleDot,
    href: '#acne-scar-guide',
  },
  {
    id: 'service-skin-rejuvenation',
    aliases: [],
    title: 'کیفیت و جوان‌سازی پوست',
    text: 'PRP، اسکین‌بوستر، مزوتراپی و دستگاه فقط وقتی معنا دارند که هدف بافتی روشن باشد.',
    icon: Droplets,
    href: '#skin-quality-rejuvenation-guide',
  },
  {
    id: 'service-prp-skin-hair',
    aliases: ['service-hair-loss-evaluation'],
    title: 'مو و پوست سر',
    text: 'تشخیص الگوی ریزش، التهاب و عوامل زمینه‌ای پیش از PRP، مزوتراپی یا مسیر تخصصی.',
    icon: UserRoundSearch,
    href: '#hair-guide',
  },
  {
    id: 'service-submental-liposuction',
    aliases: [],
    title: 'غبغب و کانتورینگ',
    text: 'تفکیک چربی، پوست، پلاتیسما، چانه و ساختار گردن پیش از ساکشن یا روش‌های غیرجراحی.',
    icon: ScanFace,
    href: '#submental-and-body-contouring-guide',
  },
];
---

<section id="services" class="section shell" aria-labelledby="services-title">
  <span id="service-coverage-panel" class="anchor-alias" aria-hidden="true"></span>
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">حوزه‌های ارزیابی و درمان</p>
      <h2 id="services-title">هر ابزار، یک مأموریت محدود</h2>
    </div>
    <p>این دسته‌ها نقطهٔ شروع گفت‌وگو هستند؛ انتخاب نهایی پس از شرح‌حال، معاینه و تعیین مرز نتیجه انجام می‌شود.</p>
  </div>

  <div class="service-grid">
    {services.map(({ id, aliases, title, text, icon: Icon, href }) => (
      <a id={id} class="service-card" href={href}>
        {aliases.map((alias) => <span id={alias} class="anchor-alias" aria-hidden="true"></span>)}
        <span class="service-card__icon"><Icon size={25} aria-hidden="true" /></span>
        <h3>{title}</h3>
        <p>{text}</p>
        <span class="service-card__link">مطالعهٔ راهنمای کامل</span>
      </a>
    ))}
  </div>
</section>
