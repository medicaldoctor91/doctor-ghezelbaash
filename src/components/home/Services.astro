---
import { Activity, CircleDot, Droplets, ScanFace, Sparkles, Syringe, UserRoundSearch } from '@lucide/astro';

const services = [
  {
    id: 'service-botulinum-toxin',
    aliases: [],
    title: 'بوتاکس',
    text: 'برای خطوط و تغییراتی که به حرکت عضله مربوط‌اند؛ با بررسی ابرو، پلک، لبخند و تقارن صورت.',
    icon: Activity,
    href: '#botulinum-toxin-guide',
  },
  {
    id: 'service-dermal-filler',
    aliases: [],
    title: 'فیلر و ژل',
    text: 'برای اصلاح کمبود حجم یا فرم بخش‌های مشخص صورت؛ با مقدار کنترل‌شده و متناسب با چهره.',
    icon: Syringe,
    href: '#dermal-fillers-revision',
  },
  {
    id: 'service-thread-lift',
    aliases: [],
    title: 'لیفت نخ',
    text: 'برای بعضی موارد افت خفیف تا متوسط؛ پس از بررسی کیفیت پوست و شدت افتادگی.',
    icon: Sparkles,
    href: '#thread-lift-surgery-boundary',
  },
  {
    id: 'service-subcision',
    aliases: ['service-acne-scar-treatment'],
    title: 'جای جوش و سابسیژن',
    text: 'با تشخیص نوع اسکار و انتخاب روش مناسب برای لک، فرورفتگی و ناهمواری پوست.',
    icon: CircleDot,
    href: '#acne-scar-guide',
  },
  {
    id: 'service-skin-rejuvenation',
    aliases: [],
    title: 'جوان‌سازی و کیفیت پوست',
    text: 'PRP، اسکین‌بوستر، مزوتراپی و روش‌های دیگر بر اساس نیاز واقعی پوست انتخاب می‌شوند.',
    icon: Droplets,
    href: '#skin-quality-rejuvenation-guide',
  },
  {
    id: 'service-prp-skin-hair',
    aliases: ['service-hair-loss-evaluation'],
    title: 'ریزش مو و پوست سر',
    text: 'بررسی نوع ریزش، وضعیت پوست سر و عوامل زمینه‌ای پیش از PRP، مزوتراپی یا درمان دیگر.',
    icon: UserRoundSearch,
    href: '#hair-guide',
  },
  {
    id: 'service-submental-liposuction',
    aliases: [],
    title: 'غبغب و فرم پایین صورت',
    text: 'بررسی چربی، پوست، چانه و گردن پیش از ساکشن یا انتخاب روش‌های غیرجراحی.',
    icon: ScanFace,
    href: '#submental-and-body-contouring-guide',
  },
];
---

<section id="services" class="section shell" aria-labelledby="services-title">
  <span id="service-coverage-panel" class="anchor-alias" aria-hidden="true"></span>
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">خدمات و درمان‌ها</p>
      <h2 id="services-title">هر روش برای مشکل مشخصی مناسب است</h2>
    </div>
    <p>انتخاب نهایی پس از شرح‌حال و معاینه انجام می‌شود؛ چون یک روش برای همهٔ صورت‌ها و همهٔ مشکلات مناسب نیست.</p>
  </div>

  <div class="service-grid">
    {services.map(({ id, aliases, title, text, icon: Icon, href }) => (
      <a id={id} class="service-card" href={href}>
        {aliases.map((alias) => <span id={alias} class="anchor-alias" aria-hidden="true"></span>)}
        <span class="service-card__icon"><Icon size={25} aria-hidden="true" /></span>
        <h3>{title}</h3>
        <p>{text}</p>
        <span class="service-card__link">توضیحات کامل</span>
      </a>
    ))}
  </div>
</section>
