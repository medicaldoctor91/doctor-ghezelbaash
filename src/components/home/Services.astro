---
import { Activity, CircleDot, Droplets, ScanFace, Sparkles, Syringe, UserRoundSearch } from '@lucide/astro';

const services = [
  {
    id: 'service-botulinum-toxin',
    aliases: [],
    title: 'بوتاکس',
    text: 'خطوط پیشانی، اخم، دور چشم و موارد وابسته به حرکت عضله.',
    icon: Activity,
    href: '#botulinum-toxin-guide',
  },
  {
    id: 'service-dermal-filler',
    aliases: [],
    title: 'فیلر',
    text: 'لب، زیر چشم، گونه، چانه، خط فک و اصلاح فیلر قبلی.',
    icon: Syringe,
    href: '#dermal-fillers-revision',
  },
  {
    id: 'service-thread-lift',
    aliases: [],
    title: 'لیفت نخ',
    text: 'بررسی افتادگی خفیف تا متوسط صورت، ابرو و خط فک.',
    icon: Sparkles,
    href: '#thread-lift-surgery-boundary',
  },
  {
    id: 'service-subcision',
    aliases: ['service-acne-scar-treatment'],
    title: 'جوش، لک و اسکار',
    text: 'درمان جوش، لک، جای جوش و بررسی نیاز به سابسیژن یا روش‌های ترکیبی.',
    icon: CircleDot,
    href: '#acne-scar-guide',
  },
  {
    id: 'service-skin-rejuvenation',
    aliases: [],
    title: 'جوان‌سازی پوست',
    text: 'PRP، اسکین‌بوستر، مزوتراپی و روش‌های بهبود کیفیت پوست.',
    icon: Droplets,
    href: '#skin-quality-rejuvenation-guide',
  },
  {
    id: 'service-prp-skin-hair',
    aliases: ['service-hair-loss-evaluation'],
    title: 'ریزش مو',
    text: 'بررسی علت ریزش مو و انتخاب درمان مناسب برای مو و پوست سر.',
    icon: UserRoundSearch,
    href: '#hair-guide',
  },
  {
    id: 'service-submental-liposuction',
    aliases: [],
    title: 'غبغب و فرم پایین صورت',
    text: 'بررسی چربی غبغب، پوست، چانه و روش‌های جراحی یا غیرجراحی.',
    icon: ScanFace,
    href: '#submental-and-body-contouring-guide',
  },
];
---

<section id="services" class="section shell" aria-labelledby="services-title">
  <span id="service-coverage-panel" class="anchor-alias" aria-hidden="true"></span>
  <div class="section-heading section-heading--split">
    <div>
      <h2 id="services-title">خدمات و موضوعات اصلی</h2>
    </div>
    <p>برای دیدن توضیحات کامل هر موضوع، روی آن بزنید.</p>
  </div>

  <div class="service-grid">
    {services.map(({ id, aliases, title, text, icon: Icon, href }) => (
      <a id={id} class="service-card" href={href}>
        {aliases.map((alias) => <span id={alias} class="anchor-alias" aria-hidden="true"></span>)}
        <span class="service-card__icon"><Icon size={25} aria-hidden="true" /></span>
        <h3>{title}</h3>
        <p>{text}</p>
        <span class="service-card__link">توضیحات بیشتر</span>
      </a>
    ))}
  </div>
</section>
