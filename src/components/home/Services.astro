---
import { Activity, CircleDot, Droplets, ScanFace, Sparkles, Syringe, UserRoundSearch } from '@lucide/astro';

const offeredServices = [
  { id: 'botox-kermanshah', title: 'بوتاکس در کرمانشاه', text: 'ارزیابی خطوط وابسته به حرکت، موقعیت ابرو و پلک، عدم تقارن و سابقه تزریق پیش از انتخاب ناحیه و دوز.', icon: Activity, href: '#botulinum-toxin-guide' },
  { id: 'dermal-filler-kermanshah', title: 'فیلر و تزریق ژل در کرمانشاه', text: 'لب، زیر چشم، گونه، چانه، خط فک، خط خنده و بررسی فیلر قبلی یا نیاز احتمالی به هیالورونیداز.', icon: Syringe, href: '#dermal-filler-guide' },
  { id: 'thread-lift-kermanshah', title: 'لیفت نخ در کرمانشاه', text: 'بررسی افتادگی خفیف تا متوسط، کیفیت پوست، وزن بافت و مرز واقعی توان نخ.', icon: Sparkles, href: '#thread-lift-guide' },
  { id: 'acne-scar-subcision-kermanshah', title: 'درمان جای جوش و سابسیژن در کرمانشاه', text: 'تفکیک آکنه فعال، لک و قرمزی از rolling، boxcar و ice-pick و انتخاب درمان مرحله‌ای.', icon: CircleDot, href: '#acne-scar-types' },
  { id: 'skin-rejuvenation-kermanshah', title: 'جوان‌سازی پوست در کرمانشاه', text: 'ارزیابی خشکی، بافت، لک، التهاب و اسکار پیش از انتخاب اسکین‌بوستر، مزوژل، PRP یا روش‌های دیگر.', icon: Droplets, href: '#skin-booster-mesogel' },
  { id: 'hair-loss-prp-kermanshah', title: 'ریزش مو، PRP و مزوتراپی در کرمانشاه', text: 'بررسی الگوی ریزش، وضعیت پوست سر و علت‌های زمینه‌ای پیش از درمان تزریقی یا ارجاع.', icon: UserRoundSearch, href: '#hair-loss-diagnosis' },
  { id: 'submental-liposuction-kermanshah', title: 'ساکشن غبغب در کرمانشاه', text: 'تفکیک سهم چربی، پوست، پلاتیسما، چانه و فک پیش از انتخاب مسیر جراحی یا غیرجراحی.', icon: ScanFace, href: '#submental-liposuction-guide' },
];

const evaluationTopics = [
  { title: 'بلفاروپلاستی و جراحی پلک', text: 'پوست اضافه، پف چربی، افت ابرو، خشکی چشم و پتوز باید از هم جدا شوند.', icon: Activity, href: '#blepharoplasty-evaluation' },
  { title: 'رینوپلاستی و جراحی بینی', text: 'تغییر ظاهری محدود تزریقی با اصلاح ساختاری و عملکرد تنفسی یکسان نیست.', icon: Sparkles, href: '#rhinoplasty-evaluation' },
  { title: 'لیفت جراحی صورت و گردن', text: 'افتادگی خارج از ظرفیت نخ، فیلر یا انرژی به ارزیابی جراحی نیاز دارد.', icon: ScanFace, href: '#facelift-necklift-evaluation' },
  { title: 'جراحی فک و اصلاح اسکلتی', text: 'مشکل بایت و ساختار اسکلتی با کانتور تزریقی درمان نمی‌شود.', icon: UserRoundSearch, href: '#orthognathic-surgery-evaluation' },
  { title: 'کاشت و پیوند مو', text: 'ثبات ریزش، بانک مو، پوست سر و انتظار نتیجه باید پیش از ارجاع بررسی شوند.', icon: UserRoundSearch, href: '#hair-transplant-surgical-evaluation' },
  { title: 'کانتورینگ بدن', text: 'چربی، شلی پوست، سلولیت، وزن پایدار و محدودیت روش‌ها باید جداگانه ارزیابی شوند.', icon: ScanFace, href: '#body-contouring-evaluation' },
];
---

<section id="aesthetic-services-kermanshah" class="section shell" aria-labelledby="aesthetic-services-kermanshah-title">
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">خدمات و مرز ارجاع</p>
      <h2 id="aesthetic-services-kermanshah-title">خدمات زیبایی در کرمانشاه؛ خدمات ارائه‌شده، ارزیابی و مرز ارجاع</h2>
    </div>
    <p>حضور یک موضوع در این فهرست به معنی ارائه همه روش‌های آن نیست؛ خدمات کلینیک و موضوعات صرفاً ارزیابی یا ارجاع به‌صورت روشن جدا شده‌اند.</p>
  </div>

  <div class="service-group" aria-labelledby="offered-services-title">
    <h3 id="offered-services-title" class="service-group__title">خدمات ارائه‌شده پس از ارزیابی پزشکی</h3>
    <div class="service-grid">
      {offeredServices.map(({ id, title, text, icon: Icon, href }) => (
        <section id={id} class="service-card" aria-labelledby={`${id}-title`}>
          <span class="service-card__icon"><Icon size={25} aria-hidden="true" /></span>
          <h3 id={`${id}-title`}>{title}</h3>
          <p>{text}</p>
          <a class="service-card__link" href={href}>توضیحات، کاندید و محدودیت‌ها</a>
        </section>
      ))}
    </div>
  </div>

  <section id="aesthetic-surgery-evaluation-kermanshah" class="service-group service-group--evaluation" aria-labelledby="aesthetic-surgery-evaluation-kermanshah-title">
    <div class="service-group__heading">
      <h3 id="aesthetic-surgery-evaluation-kermanshah-title" class="service-group__title">ارزیابی جراحی زیبایی و مرز ارجاع در کرمانشاه</h3>
      <p>هدف این بخش تشخیص مرز روش جاری و معرفی مسیر ارجاع مناسب است؛ نه ادعای ارائه تمام جراحی‌ها.</p>
    </div>
    <div class="service-grid service-grid--evaluation">
      {evaluationTopics.map(({ title, text, icon: Icon, href }) => (
        <article class="service-card service-card--evaluation">
          <span class="service-card__badge">ارزیابی و ارجاع</span>
          <span class="service-card__icon"><Icon size={25} aria-hidden="true" /></span>
          <h4>{title}</h4>
          <p>{text}</p>
          <a class="service-card__link" href={href}>دیدن معیار تصمیم و ارجاع</a>
        </article>
      ))}
    </div>
  </section>
</section>

<style>
  #aesthetic-services-kermanshah{scroll-margin-top:6rem}.service-group+.service-group{margin-top:clamp(2rem,5vw,3.5rem)}.service-group__title{margin:0 0 .9rem;color:var(--blue-950);font-size:1.08rem}.service-group__heading{display:grid;gap:.35rem;margin-bottom:.9rem}.service-group__heading p{max-width:58rem;margin:0;color:var(--muted);font-size:.88rem;line-height:1.85}.service-card{display:block;scroll-margin-top:6rem}.service-card h4{margin:.85rem 0 .4rem;color:var(--blue-950);font-size:1rem;line-height:1.75}.service-card__link{display:inline-block;margin-top:.65rem;color:var(--blue-700);font-size:.78rem;font-weight:750;text-underline-offset:.22em}.service-card--evaluation{position:relative;border-style:dashed;background:radial-gradient(circle at 100% 0%,rgba(239,106,39,.09),transparent 9rem),rgba(255,255,255,.86)}.service-card__badge{position:absolute;inset:.72rem auto auto .72rem;padding:.23rem .48rem;border-radius:999px;color:#8a431d;background:rgba(239,106,39,.11);font-size:.64rem;font-weight:800}@media(min-width:64rem){.service-grid--evaluation{grid-template-columns:repeat(3,minmax(0,1fr))}}
</style>
