---
import { Activity, CircleDot, Droplets, ScanFace, Sparkles, Syringe, UserRoundSearch } from '@lucide/astro';

const offeredServices = [
  {
    id: 'service-botulinum-toxin',
    aliases: [],
    title: 'بوتاکس و بوتولینوم توکسین',
    text: 'خطوط پیشانی، اخم، دور چشم، ماستر، لبخند لثه‌ای و موارد وابسته به حرکت عضله.',
    icon: Activity,
    href: '#botulinum-toxin-guide',
  },
  {
    id: 'service-dermal-filler',
    aliases: [],
    title: 'فیلر و اصلاح تزریق قبلی',
    text: 'لب، زیر چشم، گونه، چانه، خط فک، خط خنده و بررسی نیاز به هیالورونیداز.',
    icon: Syringe,
    href: '#dermal-fillers-revision',
  },
  {
    id: 'service-thread-lift',
    aliases: [],
    title: 'لیفت با نخ',
    text: 'بررسی افتادگی خفیف تا متوسط صورت، ابرو، میدفیس، jowl و خط فک.',
    icon: Sparkles,
    href: '#thread-lift-surgery-boundary',
  },
  {
    id: 'service-subcision',
    aliases: ['service-acne-scar-treatment'],
    title: 'جوش، لک، اسکار و سابسیژن',
    text: 'تفکیک لک و قرمزی از اسکار و انتخاب سابسیژن، TCA CROSS، میکرونیدلینگ یا درمان ترکیبی.',
    icon: CircleDot,
    href: '#acne-scar-guide',
  },
  {
    id: 'service-skin-rejuvenation',
    aliases: [],
    title: 'جوان‌سازی و کیفیت پوست',
    text: 'اسکین‌بوستر، مزوژل، PRP، مزوتراپی و روش‌های بهبود بافت، رطوبت و کیفیت پوست.',
    icon: Droplets,
    href: '#skin-quality-rejuvenation-guide',
  },
  {
    id: 'service-prp-skin-hair',
    aliases: ['service-hair-loss-evaluation'],
    title: 'ریزش مو، PRP و مزوتراپی مو',
    text: 'بررسی الگوی ریزش، پوست سر، علت‌های زمینه‌ای و انتخاب درمان تزریقی یا مسیر ارجاع.',
    icon: UserRoundSearch,
    href: '#hair-guide',
  },
  {
    id: 'service-submental-liposuction',
    aliases: [],
    title: 'ساکشن غبغب و فرم پایین صورت',
    text: 'بررسی سهم چربی، پوست، پلاتیسما، چانه و ساختار فک پیش از انتخاب روش جراحی یا غیرجراحی.',
    icon: ScanFace,
    href: '#submental-and-body-contouring-guide',
  },
];

const evaluationTopics = [
  {
    title: 'مزوتراپی پوست و مو',
    text: 'انتخاب ماده، هدف، تعداد جلسات و کاندید مناسب؛ نه یک نسخه ثابت برای همه.',
    icon: Droplets,
    href: '#service-mesotherapy',
    status: 'ارائه پس از ارزیابی',
  },
  {
    title: 'کانتورینگ و لاغری موضعی',
    text: 'تفکیک چربی، شلی پوست، سلولیت و محدودیت روش‌ها پیش از انتخاب مسیر.',
    icon: ScanFace,
    href: '#service-body-contouring',
    status: 'ارزیابی',
  },
  {
    title: 'بلفاروپلاستی و جراحی پلک',
    text: 'تفکیک پوست اضافه، پف چربی، افت ابرو، خشکی چشم و زمان ارجاع جراحی.',
    icon: Activity,
    href: '#service-blepharoplasty',
    status: 'مرز ارجاع',
  },
  {
    title: 'رینوپلاستی و جراحی بینی',
    text: 'مقایسه اصلاح محدود تزریقی با تغییر ساختاری، عملکرد تنفسی و ارجاع مناسب.',
    icon: Sparkles,
    href: '#service-rhinoplasty',
    status: 'مرز ارجاع',
  },
  {
    title: 'لیفت جراحی صورت و گردن',
    text: 'تشخیص افتادگی خارج از ظرفیت نخ، فیلر یا روش‌های انرژی‌محور.',
    icon: ScanFace,
    href: '#service-facelift-necklift',
    status: 'مرز ارجاع',
  },
  {
    title: 'جراحی فک و اصلاح اسکلتی',
    text: 'تفکیک مشکل اسکلتی و بایت از کانتور تزریقی و تعیین مسیر تیم تخصصی.',
    icon: UserRoundSearch,
    href: '#service-orthognathic-surgery',
    status: 'مرز ارجاع',
  },
  {
    title: 'کاشت و پیوند مو',
    text: 'بررسی ثبات ریزش، بانک مو، پوست سر و زمان مناسب ارجاع برای کاشت.',
    icon: UserRoundSearch,
    href: '#service-hair-transplant',
    status: 'مرز ارجاع',
  },
];
---

<section id="services" class="section shell" aria-labelledby="services-title">
  <span id="service-coverage-panel" class="anchor-alias" aria-hidden="true"></span>
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">پوشش کامل، بدون مخلوط‌کردن خدمت و ارجاع</p>
      <h2 id="services-title">خدمات ارائه‌شده و موضوعات جراحی یا غیرجراحی که پیش از انتخاب باید ارزیابی شوند</h2>
    </div>
    <p>هر کارت به توضیح همان موضوع در همین صفحه متصل است.</p>
  </div>

  <div class="service-group" aria-labelledby="offered-services-title">
    <h3 id="offered-services-title" class="service-group__title">خدمات ارائه‌شده در کلینیک</h3>
    <div class="service-grid">
      {offeredServices.map(({ id, aliases, title, text, icon: Icon, href }) => (
        <a id={id} class="service-card" href={href}>
          {aliases.map((alias) => <span id={alias} class="anchor-alias" aria-hidden="true"></span>)}
          <span class="service-card__icon"><Icon size={25} aria-hidden="true" /></span>
          <h3>{title}</h3>
          <p>{text}</p>
          <span class="service-card__link">توضیحات، کاندید و محدودیت‌ها</span>
        </a>
      ))}
    </div>
  </div>

  <div class="service-group service-group--evaluation" aria-labelledby="evaluation-services-title">
    <div class="service-group__heading">
      <h3 id="evaluation-services-title" class="service-group__title">موضوعات ارزیابی، مقایسه و مرز ارجاع</h3>
      <p>حضور یک موضوع در این بخش به معنی ارائه همه روش‌ها نیست؛ هدف، تشخیص مرز روش جاری و ارجاع درست است.</p>
    </div>
    <div class="service-grid service-grid--evaluation">
      {evaluationTopics.map(({ title, text, icon: Icon, href, status }) => (
        <a class="service-card service-card--evaluation" href={href}>
          <span class="service-card__badge">{status}</span>
          <span class="service-card__icon"><Icon size={25} aria-hidden="true" /></span>
          <h3>{title}</h3>
          <p>{text}</p>
          <span class="service-card__link">دیدن معیار تصمیم و ارجاع</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .service-group + .service-group {
    margin-top: clamp(2rem, 5vw, 3.5rem);
  }

  .service-group__title {
    margin: 0 0 .9rem;
    color: var(--blue-950);
    font-size: 1.08rem;
  }

  .service-group__heading {
    display: grid;
    gap: .35rem;
    margin-bottom: .9rem;
  }

  .service-group__heading p {
    max-width: 58rem;
    margin: 0;
    color: var(--muted);
    font-size: .88rem;
    line-height: 1.85;
  }

  .service-card--evaluation {
    border-style: dashed;
    background:
      radial-gradient(circle at 100% 0%, rgba(239, 106, 39, .09), transparent 9rem),
      rgba(255, 255, 255, .86);
  }

  .service-card__badge {
    position: absolute;
    inset: .72rem auto auto .72rem;
    padding: .23rem .48rem;
    border-radius: 999px;
    color: #8a431d;
    background: rgba(239, 106, 39, .11);
    font-size: .64rem;
    font-weight: 800;
  }

  @media (min-width: 64rem) {
    .service-grid--evaluation {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .service-grid--evaluation .service-card:first-child,
    .service-grid--evaluation .service-card:nth-child(5) {
      grid-column: auto;
    }
  }
</style>
