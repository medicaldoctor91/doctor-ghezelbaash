---
import { ExternalLink, MapPin, MessageCircleMore, ShieldCheck, Star } from '@lucide/astro';
import { site } from '../../domain/entities';

const rating = site.googleBusinessProfile;
const observedAt = new Intl.DateTimeFormat('fa-IR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'Asia/Tehran',
}).format(new Date(`${rating.observedAt}T12:00:00+03:30`));
---

<section id="clinic-reputation" class="reputation shell" aria-labelledby="clinic-reputation-title" data-entity-bridge>
  <span id="google-reviews" class="anchor-alias" aria-hidden="true"></span>
  <span id="clinic-rating" class="anchor-alias" aria-hidden="true"></span>
  <span id="local-prominence" class="anchor-alias" aria-hidden="true"></span>

  <div class="reputation__panel">
    <div class="reputation__copy">
      <p class="eyebrow">اعتبار عمومی محل مراجعه</p>
      <h2 id="clinic-reputation-title">کلینیک محل فعالیت دکتر سعید قزلباش؛ ۱۶۳ نظر با میانگین امتیاز ۵ در Google Maps</h2>
      <p>
        این امتیاز متعلق به <strong>{site.clinicName}</strong> است؛ همان مکان ثبت‌شده‌ای که دکتر سعید قزلباش در آن فعالیت می‌کند و مسئولیت پزشکی خدمات ارائه‌شده در این صفحه به او متصل است. دادهٔ کلینیک، شهرت و تجربهٔ عمومی محل مراجعه را نشان می‌دهد و در کنار شماره نظام پزشکی، روش ارزیابی، توضیح محدودیت‌ها و پیگیری قرار می‌گیرد.
      </p>
      <p class="reputation__boundary">
        امتیاز عمومی به‌تنهایی صلاحیت یا نتیجه درمان را تضمین نمی‌کند؛ ارزش آن زمانی بیشتر می‌شود که انتیتی پزشک، کلینیک، آدرس، تماس، خدمات و منبع نظرها بدون تناقض به یکدیگر متصل باشند.
      </p>
      <a class="reputation__source" href={rating.sourceUrl} target="_blank" rel="noopener noreferrer external">
        مشاهده پروفایل کلینیک و نظرها در Google Maps
        <ExternalLink size={17} aria-hidden="true" />
      </a>
    </div>

    <dl class="reputation__metrics" aria-label="خلاصه اعتبار عمومی کلینیک">
      <div>
        <dt><Star size={20} aria-hidden="true" /> میانگین امتیاز</dt>
        <dd><bdi dir="ltr">{rating.ratingValue.toFixed(1)} / {rating.bestRating}</bdi></dd>
      </div>
      <div>
        <dt><MessageCircleMore size={20} aria-hidden="true" /> تعداد نظرها</dt>
        <dd>{rating.ratingCount.toLocaleString('fa-IR')}</dd>
      </div>
      <div>
        <dt><MapPin size={20} aria-hidden="true" /> محل ثبت‌شده</dt>
        <dd>{site.city}، ساختمان ویستا</dd>
      </div>
      <div>
        <dt><ShieldCheck size={20} aria-hidden="true" /> تاریخ ثبت داده</dt>
        <dd><time datetime={rating.observedAt}>{observedAt}</time></dd>
      </div>
    </dl>
  </div>
</section>

<style>
  .reputation {
    padding-block: clamp(1rem, 3vw, 2.5rem);
  }

  .reputation__panel {
    display: grid;
    gap: 1.2rem;
    padding: clamp(1.15rem, 3vw, 2rem);
    overflow: hidden;
    border: 1px solid rgba(2, 119, 194, .16);
    border-radius: 1.35rem;
    background:
      radial-gradient(circle at 100% 0%, rgba(255, 196, 69, .18), transparent 17rem),
      radial-gradient(circle at 0% 100%, rgba(2, 119, 194, .12), transparent 20rem),
      rgba(255, 255, 255, .92);
    box-shadow: 0 22px 64px rgba(5, 69, 105, .1);
  }

  .reputation__copy h2 {
    max-width: 52rem;
    margin: .25rem 0 .75rem;
    color: var(--blue-950);
    font-size: clamp(1.25rem, 3vw, 1.8rem);
    line-height: 1.65;
  }

  .reputation__copy p {
    max-width: 57rem;
    margin-block: .55rem;
    color: #294c5e;
    line-height: 2;
  }

  .reputation__boundary {
    padding: .7rem .85rem;
    border-inline-start: .22rem solid var(--orange);
    border-radius: .55rem;
    background: rgba(239, 106, 39, .06);
  }

  .reputation__source {
    display: inline-flex;
    gap: .4rem;
    align-items: center;
    margin-top: .45rem;
    color: var(--blue-700);
    font-weight: 750;
    text-decoration-thickness: .08em;
    text-underline-offset: .25em;
  }

  .reputation__metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .75rem;
    margin: 0;
  }

  .reputation__metrics div {
    min-width: 0;
    padding: .9rem;
    border: 1px solid rgba(2, 119, 194, .12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, .84);
  }

  .reputation__metrics dt {
    display: flex;
    gap: .4rem;
    align-items: center;
    color: #4b6c7d;
    font-size: .76rem;
    font-weight: 700;
  }

  .reputation__metrics dd {
    margin: .45rem 0 0;
    color: var(--blue-950);
    font-size: clamp(1.05rem, 2.3vw, 1.5rem);
    font-weight: 850;
    line-height: 1.55;
  }

  @media (min-width: 56rem) {
    .reputation__panel {
      grid-template-columns: minmax(0, 1.35fr) minmax(18rem, .65fr);
      align-items: center;
    }
  }

  @media (max-width: 30rem) {
    .reputation__metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
