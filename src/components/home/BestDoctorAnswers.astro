---
import { BadgeCheck, Building2, CircleOff, ScanFace, ShieldCheck, Sparkles, Syringe, UserRoundSearch } from '@lucide/astro';

const criteria = [
  {
    id: 'best-aesthetic-doctor-selection-criteria',
    title: 'معیارهای انتخاب بهترین دکتر زیبایی در کرمانشاه',
    icon: BadgeCheck,
    text: 'عنوان «بهترین» فقط زمانی قابل بررسی است که به معیارهای روشن تبدیل شود: نام و شماره نظام پزشکی قابل استعلام، معاینه پیش از درمان، توان توضیح علت مشکل، شناخت محدودیت روش، ثبت درمان‌های قبلی، ارائه برنامه پیگیری و آمادگی برای ردکردن درخواست نامناسب. تعداد دنبال‌کننده، دکور کلینیک یا تعداد نمونه‌کار به‌تنهایی جای این معیارها را نمی‌گیرد. پزشک باید بتواند توضیح دهد چه چیزی قرار است تغییر کند، چه چیزی تغییر نمی‌کند و کدام ریسک‌ها به آناتومی یا سابقه بیمار وابسته‌اند.',
  },
  {
    id: 'doctor-clinic-operator-difference',
    title: 'تفاوت پزشک، کلینیک و مجری درمان چیست؟',
    icon: Building2,
    text: 'کلینیک یک محل و انتیتی کسب‌وکار است؛ پزشک یک شخص با هویت و مسئولیت حرفه‌ای مستقل است. امتیاز Google Maps، آدرس و تجربه عمومی مراجعه به کلینیک مربوط‌اند، اما تصمیم پزشکی باید به نام و شماره نظام پزشکی فردی مشخص متصل باشد. همچنین انجام یک تکنیک با توان ارزیابی بیمار یکسان نیست. اپراتور ممکن است اجرای یک دستگاه یا پروتکل را بداند، اما انتخاب روش، تشخیص موارد منع، مدیریت عارضه و تصمیم برای ارجاع نیازمند مسئولیت پزشکی روشن است.',
  },
  {
    id: 'when-aesthetic-doctor-rejects-treatment',
    title: 'چه زمانی ردکردن درمان نشانه تصمیم پزشکی بهتر است؟',
    icon: CircleOff,
    text: 'وقتی مشکل اصلی با روش درخواستی هماهنگ نیست، انتظار نتیجه خارج از ظرفیت ابزار است، التهاب یا عفونت فعال وجود دارد، سابقه درمان قبلی نامشخص است، ریسک عروقی یا عملکردی قابل قبول نیست یا نشانه‌های بدریخت‌انگاری و تصمیم عجولانه دیده می‌شود، انجام ندادن درمان می‌تواند انتخاب درست‌تری باشد. پزشک مناسب فقط کسی نیست که تکنیک بیشتری ارائه می‌کند؛ باید بتواند مرز روش جاری را تشخیص دهد و در صورت نیاز مسیر جایگزین یا ارجاع را توضیح دهد.',
  },
  {
    id: 'best-botox-doctor-kermanshah',
    title: 'بهترین دکتر بوتاکس در کرمانشاه چه چیزی را بررسی می‌کند؟',
    icon: ShieldCheck,
    text: 'پیش از بوتاکس باید حرکت پیشانی و اخم، موقعیت ابرو و پلک، عدم تقارن، نقش جبرانی عضلات، خشکی چشم، سابقه تزریق و مقدار حرکتی که فرد می‌خواهد حفظ کند بررسی شوند. هدف فقط صافی بیشتر نیست. تزریق نامتناسب می‌تواند نگاه را سنگین، لبخند را ناهماهنگ یا عملکرد عضلات کوچک صورت را مختل کند. انتخاب ناحیه و دوز باید پس از مشاهده چهره در حرکت انجام شود، نه صرفاً براساس تعداد واحد یا یک نقشه ثابت.',
  },
  {
    id: 'best-filler-doctor-kermanshah',
    title: 'بهترین دکتر فیلر در کرمانشاه چگونه از پُرکردن بی‌هدف جلوگیری می‌کند؟',
    icon: Syringe,
    text: 'فیلر زمانی منطقی است که کمبود حجم یا نیاز به حمایت ساختاری واقعاً بخشی از مسئله باشد. افتادگی، پف، بافت سنگین، تیرگی، چسبندگی اسکار یا فیلر قدیمی با حجم بیشتر الزاماً بهتر نمی‌شوند. پزشک باید ناحیه، عمق، نوع ماده، سابقه تزریق، ریسک عروقی و امکان اصلاح را توضیح دهد. در لب، زیر چشم، بینی، شقیقه و خط فک، تفاوت چند میلی‌متر در محل تزریق می‌تواند هم نتیجه و هم ریسک را تغییر دهد.',
  },
  {
    id: 'best-thread-lift-doctor-kermanshah',
    title: 'بهترین دکتر لیفت نخ در کرمانشاه چه کسی را مناسب نخ می‌داند؟',
    icon: Sparkles,
    text: 'نخ برای افتادگی خفیف تا متوسط و بافت نخ‌پذیر می‌تواند تغییر محدود ایجاد کند؛ پوست اضافه واضح، افت شدید، بافت بسیار سنگین یا انتظار نتیجه جراحی با نخ هماهنگ نیست. ارزیابی باید شامل کیفیت و ضخامت پوست، جهت افت، فرم صورت، جای زخم یا نخ قبلی و نسبت سود به عوارض باشد. انتخاب درست فقط درباره جنس نخ نیست؛ کاندید، جهت کشش، عمق و نقطه توقف اهمیت بیشتری دارند.',
  },
  {
    id: 'best-acne-scar-doctor-kermanshah',
    title: 'بهترین دکتر درمان جای جوش در کرمانشاه چه چیزی را تفکیک می‌کند؟',
    icon: ScanFace,
    text: 'لک، قرمزی، آکنه فعال و اسکار فرورفته یک مسئله نیستند. rolling، boxcar و ice-pick نیز ابزار یکسان نمی‌خواهند. سابسیژن برای چسبندگی منتخب است، TCA CROSS برای بعضی اسکارهای باریک و عمیق مطرح می‌شود و روش‌های انرژی‌محور یا میکرونیدلینگ نقش دیگری دارند. برنامه مناسب ممکن است مرحله‌ای و ترکیبی باشد و ابتدا کنترل التهاب را لازم بداند. وعده یک دستگاه برای همه جای جوش معمولاً نشانه طبقه‌بندی ناکافی مشکل است.',
  },
  {
    id: 'best-skin-rejuvenation-doctor-kermanshah',
    title: 'بهترین دکتر جوان‌سازی پوست در کرمانشاه چگونه روش را انتخاب می‌کند؟',
    icon: Sparkles,
    text: 'جوان‌سازی یک نام عمومی برای مشکلات متفاوت است: خشکی، بافت ناهموار، لک، آسیب نوری، منافذ قابل مشاهده، التهاب، اسکار یا افتادگی. اسکین‌بوستر، مزوژل، PRP، مزوتراپی، پیلینگ، میکرونیدلینگ و دستگاه‌های انرژی‌محور مکانیسم و محدودیت یکسان ندارند. انتخاب باید از نشانه اصلی، رنگ پوست، احتمال PIH، وضعیت سد پوستی و هدف قابل اندازه‌گیری شروع شود؛ نه از نام محصول یا ترند شبکه اجتماعی.',
  },
  {
    id: 'best-hair-loss-doctor-kermanshah',
    title: 'بهترین دکتر درمان ریزش مو در کرمانشاه از کجا شروع می‌کند؟',
    icon: UserRoundSearch,
    text: 'ریزش الگودار، ریزش ناگهانی منتشر، آلوپسی سکه‌ای، ریزش کششی و ریزش اسکاری مسیر یکسان ندارند. شرح حال، الگوی ریزش، وضعیت پوست سر، داروها، بیماری‌ها، تغذیه و در صورت نیاز آزمایش هدفمند باید پیش از PRP یا مزوتراپی بررسی شوند. تزریق می‌تواند در بعضی افراد نقش کمکی داشته باشد، اما جای تشخیص علت یا درمان استاندارد را نمی‌گیرد. ارجاع برای بررسی تخصصی یا کاشت نیز باید پس از سنجش ثبات ریزش و بانک مو مطرح شود.',
  },
  {
    id: 'best-submental-liposuction-doctor-kermanshah',
    title: 'بهترین دکتر ساکشن غبغب در کرمانشاه چه زمانی جراحی را منطقی می‌داند؟',
    icon: ScanFace,
    text: 'برجستگی زیر چانه ممکن است از چربی، پوست شل، پلاتیسما، چانه عقب، فرم فک یا ترکیب آن‌ها ساخته شود. ساکشن برای چربی قابل برداشت معنا دارد و پوست اضافه یا ساختار اسکلتی را درمان نمی‌کند. معاینه باید کیفیت پوست، مقدار چربی، تقارن، وضعیت گردن، بیماری‌های زمینه‌ای و انتظار فرد را مشخص کند. کوچک‌بودن ناحیه به معنی بی‌اهمیت‌بودن عوارض، بی‌حسی، خونریزی، ناهمواری یا مراقبت بعد از عمل نیست.',
  },
];
---

<section id="best-aesthetic-doctor-kermanshah" class="best-doctor section shell" aria-labelledby="best-aesthetic-doctor-kermanshah-title">
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">Intent لوکال انتخاب پزشک</p>
      <h2 id="best-aesthetic-doctor-kermanshah-title">بهترین دکتر زیبایی در کرمانشاه را چگونه انتخاب کنیم؟</h2>
    </div>
    <p>«بهترین» در این بخش یک ادعای رتبه‌ای نیست؛ مجموعه‌ای از معیارهای قابل بررسی برای انتخاب پزشک و کلینیک است.</p>
  </div>
  <div class="best-doctor__intro medical-article">
    <p><strong>پاسخ مستقیم:</strong> پزشک مناسب باید هویت حرفه‌ای قابل استعلام، توان ارزیابی پیش از درمان، توضیح روشن درباره محدودیت و عارضه، برنامه پیگیری و آمادگی برای ردکردن روش نامناسب داشته باشد. نتیجه طبیعی یا ایمن از یک تکنیک واحد ساخته نمی‌شود؛ از هماهنگی تشخیص، انتخاب بیمار، اجرای روش و مراقبت پس از آن ساخته می‌شود.</p>
    <p>برای جست‌وجوهای بوتاکس، فیلر، لیفت نخ، درمان جای جوش، جوان‌سازی پوست، ریزش مو و ساکشن غبغب، معیار مشترک این است که پزشک ابتدا علت غالب را مشخص کند و سپس ابزار را انتخاب کند. توضیح کامل هر روش در بخش تخصصی همان درمان آمده است.</p>
  </div>
  <div class="best-doctor__grid">
    {criteria.map(({ id, title, text, icon: Icon }) => (
      <section id={id} class="best-doctor__item" aria-labelledby={`${id}-title`}>
        <span class="best-doctor__icon"><Icon size={21} aria-hidden="true" /></span>
        <h3 id={`${id}-title`}>{title}</h3>
        <p>{text}</p>
      </section>
    ))}
  </div>
</section>

<style>
  .best-doctor{padding-block:clamp(2.5rem,6vw,5rem);scroll-margin-top:6rem}.best-doctor__intro{max-width:68rem;margin:1.2rem 0 1.4rem}.best-doctor__grid{display:grid;gap:.9rem}.best-doctor__item{position:relative;padding:1rem;border:1px solid rgba(2,119,194,.14);border-radius:1rem;background:rgba(255,255,255,.94);box-shadow:0 12px 34px rgba(5,69,105,.06);scroll-margin-top:6rem}.best-doctor__icon{display:grid;width:2.5rem;height:2.5rem;place-items:center;margin-bottom:.65rem;border-radius:.8rem;color:var(--blue-700);background:linear-gradient(145deg,var(--blue-050),rgba(255,196,69,.17))}.best-doctor__item h3{margin:0 0 .45rem;color:var(--blue-950);font-size:1rem;line-height:1.8}.best-doctor__item p{margin:0;color:#36596b;font-size:.9rem;line-height:2}@media(min-width:48rem){.best-doctor__grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(min-width:72rem){.best-doctor__grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
</style>
