---
import { ArrowLeft, ChevronDown, Sparkles } from '@lucide/astro';
import '../../styles/featured-answer-disclosure.css';

const answers = [
  {
    question: 'بهترین دکتر زیبایی کرمانشاه کیست؟',
    answer: 'انتخاب خوب با تبلیغ مشخص نمی‌شود. شماره نظام پزشکی، سابقهٔ قابل‌بررسی، توضیح روشن و توانایی رد کردن روش نامناسب مهم‌اند. دکتر سعید قزلباش با شمارهٔ نظام پزشکی ۱۶۷۴۳۰ و سوابق پژوهشی، یکی از گزینه‌های قابل‌بررسی در کرمانشاه است.',
    href: '#best-aesthetic-doctor-kermanshah',
  },
  {
    question: 'بهترین دکتر بوتاکس در کرمانشاه چه کسی است؟',
    answer: 'پزشک مناسب بوتاکس فقط خطوط را نمی‌شمارد؛ حرکت ابرو، پلک، لبخند، تقارن و احتمال سنگینی نگاه را قبل از تزریق بررسی می‌کند.',
    href: '#best-botox-doctor-kermanshah',
  },
  {
    question: 'بهترین دکتر فیلر در کرمانشاه چگونه انتخاب می‌شود؟',
    answer: 'فیلر خوب یعنی حجم به‌اندازه و در جای درست. پزشک باید فرق کمبود حجم، افت بافت و ورم را تشخیص دهد و از پُرکردن بی‌هدف صورت جلوگیری کند.',
    href: '#best-filler-doctor-kermanshah',
  },
  {
    question: 'برای فیلر لب در کرمانشاه به چه پزشکی مراجعه کنیم؟',
    answer: 'فرم طبیعی لب، نسبت لب با چانه و بینی، حرکت لبخند و سابقهٔ تزریق قبلی باید قبل از انتخاب مدل و مقدار ژل دیده شوند.',
    href: '#best-lip-filler-doctor-kermanshah',
  },
  {
    question: 'بهترین دکتر فیلر زیر چشم چه زمانی تزریق را انجام نمی‌دهد؟',
    answer: 'وقتی مشکل اصلی پف، ورم، تیرگی پوستی یا افت میدفیس باشد، تزریق مستقیم زیر چشم ممکن است انتخاب مناسبی نباشد.',
    href: '#best-under-eye-filler-doctor-kermanshah',
  },
  {
    question: 'بهترین دکتر لیفت نخ در کرمانشاه چه چیزی را بررسی می‌کند؟',
    answer: 'شدت افتادگی، کیفیت پوست، وزن بافت و انتظار بیمار تعیین می‌کنند که نخ مفید است یا روش دیگری نتیجهٔ منطقی‌تری دارد.',
    href: '#best-thread-lift-doctor-kermanshah',
  },
  {
    question: 'برای درمان جای جوش و سابسیژن در کرمانشاه چه پزشکی مناسب است؟',
    answer: 'پزشک باید لک را از اسکار و انواع rolling، boxcar و ice-pick را از هم جدا کند؛ چون هرکدام درمان متفاوتی می‌خواهند.',
    href: '#best-acne-scar-subcision-doctor-kermanshah',
  },
  {
    question: 'بهترین دکتر جوانسازی پوست چگونه روش را انتخاب می‌کند؟',
    answer: 'PRP، مزوتراپی، میکرونیدلینگ و اسکین‌بوستر برای یک هدف واحد نیستند. انتخاب باید بر اساس خشکی، لک، التهاب، بافت و نیاز واقعی پوست باشد.',
    href: '#best-skin-rejuvenation-doctor-kermanshah',
  },
  {
    question: 'برای ریزش مو و PRP مو در کرمانشاه از کجا شروع کنیم؟',
    answer: 'اول باید نوع ریزش مو، وضعیت پوست سر، داروها و عوامل زمینه‌ای مشخص شوند؛ تزریق قبل از شناخت علت می‌تواند فقط زمان را از بین ببرد.',
    href: '#best-hair-loss-prp-doctor-kermanshah',
  },
  {
    question: 'بهترین دکتر ساکشن غبغب چه زمانی جراحی را پیشنهاد می‌کند؟',
    answer: 'وقتی چربی زیرچانه عامل اصلی باشد و پوست توان جمع‌شدن مناسبی داشته باشد، ساکشن می‌تواند منطقی باشد؛ اما چانهٔ عقب، پوست شل یا عضلهٔ گردن مسیر دیگری می‌خواهند.',
    href: '#best-submental-liposuction-doctor-kermanshah',
  },
];
---

<section class="best-answers-strip" aria-label="پاسخ‌های کوتاه درباره انتخاب پزشک زیبایی در کرمانشاه">
  <div class="shell">
    <details class="featured-answer-disclosure">
      <summary>
        <span class="featured-answer-disclosure__title">
          <Sparkles size={18} aria-hidden="true" />
          <strong>راهنمای تکمیلی انتخاب پزشک و روش‌های زیبایی</strong>
        </span>
        <span class="featured-answer-disclosure__hint">پاسخ‌های کوتاه</span>
        <ChevronDown class="featured-answer-disclosure__chevron" size={20} aria-hidden="true" />
      </summary>

      <div class="featured-answer-disclosure__body">
        <p class="featured-answer-disclosure__intro">
          پاسخ کوتاه به جست‌وجوهای رایج «بهترین دکتر زیبایی در کرمانشاه». توضیح کامل هر موضوع در مقالهٔ اصلی همان بخش قرار دارد.
        </p>
        <div class="best-answer-grid">
          {answers.map((item) => (
            <article class="best-answer-card">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
              <a href={item.href}>
                توضیح کامل
                <ArrowLeft size={15} aria-hidden="true" />
              </a>
            </article>
          ))}
        </div>
      </div>
    </details>
  </div>
</section>
