---
import { BadgeCheck, Building2, CircleOff, MapPin, SearchCheck, ShieldCheck } from '@lucide/astro';
import { homepageSectionById } from '../../domain/homepage-sections';
import {
  homepageMissionLock,
  localServiceIntentAnswers,
  nationalAuthorityAnswers,
} from '../../domain/homepage-mission-lock.mjs';

const bestDoctorSection = homepageSectionById.get('best-aesthetic-doctor-kermanshah');
if (!bestDoctorSection) throw new Error('Canonical best-doctor section is missing from the Homepage registry.');

const coreCriteria = [
  {
    id: 'best-aesthetic-doctor-selection-criteria',
    title: 'معیارهای انتخاب بهترین دکتر زیبایی در کرمانشاه',
    icon: BadgeCheck,
    answer: 'عنوان «بهترین» فقط زمانی معنا دارد که به معیارهای قابل بررسی تبدیل شود: نام و شماره نظام پزشکی قابل استعلام، معاینه پیش از درمان، توان توضیح علت مشکل، شناخت محدودیت روش، ثبت درمان‌های قبلی، برنامه پیگیری و آمادگی برای ردکردن درخواست نامناسب.',
    detail: 'در جلسه مشاوره باید بتوانید علت انتخاب روش، گزینه‌های جایگزین، احتمال نیاز به چند مرحله، عوارض مهم و زمان ارزیابی نتیجه را بفهمید. تعداد دنبال‌کننده، دکور کلینیک یا تعداد نمونه‌کار به‌تنهایی جای این معیارها را نمی‌گیرد.',
    href: '#medical-research-and-education',
    linkLabel: 'بررسی شواهد علمی و حرفه‌ای پزشک',
  },
  {
    id: 'doctor-clinic-operator-difference',
    title: 'تفاوت پزشک، کلینیک و مجری درمان چیست؟',
    icon: Building2,
    answer: 'کلینیک یک انتیتی مکان و کسب‌وکار است؛ پزشک یک Person با هویت و مسئولیت حرفه‌ای مستقل است. امتیاز، آدرس و تجربه عمومی مراجعه به کلینیک مربوط‌اند، اما ارزیابی و تصمیم پزشکی باید به نام و شماره نظام پزشکی فرد مشخص متصل باشد.',
    detail: 'هنگام مقایسه گزینه‌ها جداگانه بپرسید چه کسی معاینه می‌کند، چه کسی طرح درمان را می‌نویسد، چه کسی مداخله را انجام می‌دهد و در صورت عارضه چه فردی پاسخ‌گوست. اعتبار کلینیک باید پزشک را تقویت کند، نه جایگزین هویت او شود.',
    href: '#clinic-information-kermanshah',
    linkLabel: 'مشاهده رابطه مستقل پزشک و کلینیک',
  },
  {
    id: 'when-aesthetic-doctor-rejects-treatment',
    title: 'چه زمانی ردکردن درمان نشانه تصمیم پزشکی بهتر است؟',
    icon: CircleOff,
    answer: 'وقتی مشکل اصلی با روش درخواستی هماهنگ نیست، انتظار نتیجه خارج از ظرفیت ابزار است، التهاب یا عفونت فعال وجود دارد، درمان قبلی نامشخص است یا ریسک قابل قبول نیست، انجام ندادن درمان می‌تواند انتخاب درست‌تری باشد.',
    detail: 'رد درمان باید همراه با دلیل، گزینه جایگزین، زمان ارزیابی دوباره یا مسیر ارجاع باشد. پذیرش فوری همه درخواست‌ها پوشش درمانی بیشتر نیست؛ می‌تواند نشانه حذف مرحله تشخیص باشد.',
    href: '#aesthetic-treatment-selection',
    linkLabel: 'دیدن مسیر انتخاب درمان براساس مشکل',
  },
];

const relationshipLabels = {
  offered: 'خدمت ارائه‌شده پس از ارزیابی',
  evaluated: 'ارزیابی و انتخاب مسیر مناسب',
  'referral-context': 'مرز ارجاع و انتخاب جراح واجد صلاحیت',
};
---

<section
  id={bestDoctorSection.id}
  class="best-doctor section shell"
  aria-labelledby={`${bestDoctorSection.id}-title`}
  data-mission-lock="local-to-national-physician-authority"
>
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">Intent لوکال انتخاب پزشک</p>
      <h2 id={`${bestDoctorSection.id}-title`}>{bestDoctorSection.title}</h2>
    </div>
    <p>«بهترین» در این صفحه ادعای رتبه‌ای خودساخته نیست؛ یک سؤال انتخاب پزشک است که با معیارهای قابل بررسی، پاسخ‌های خدمت‌محور و مرز روشن ارجاع پوشش داده می‌شود.</p>
  </div>

  <div class="best-doctor__intro medical-article">
    <p><strong>پاسخ مستقیم:</strong> پزشک مناسب باید هویت حرفه‌ای قابل استعلام، توان ارزیابی پیش از درمان، توضیح روشن درباره محدودیت و عارضه، برنامه پیگیری و آمادگی برای ردکردن روش نامناسب داشته باشد. نتیجه از هماهنگی تشخیص، انتخاب بیمار، اجرای روش و مراقبت پس از آن ساخته می‌شود.</p>
    <p>پاسخ‌های زیر هرکدام یک passage مستقل برای یک Search Intent مشخص‌اند. خدمات ارائه‌شده، موضوعات ارزیابی و جراحی‌های نیازمند ارجاع عمداً از یکدیگر جدا شده‌اند تا پوشش گسترده با ادعای خدمت ناموجود مخلوط نشود.</p>
  </div>

  <div class="best-doctor__grid best-doctor__grid--core">
    {coreCriteria.map(({ id, title, answer, detail, href, linkLabel, icon: Icon }) => (
      <section id={id} class="best-doctor__item best-doctor__item--core" aria-labelledby={`${id}-title`}>
        <span class="best-doctor__icon"><Icon size={21} aria-hidden="true" /></span>
        <h3 id={`${id}-title`}>{title}</h3>
        <p><strong>پاسخ مستقیم:</strong> {answer}</p>
        <p>{detail}</p>
        <a href={href}>{linkLabel}</a>
      </section>
    ))}
  </div>

  <div class="best-doctor__subheading">
    <ShieldCheck size={23} aria-hidden="true" />
    <div>
      <p class="eyebrow">پوشش «بهترین دکتر + خدمت + کرمانشاه»</p>
      <p>{homepageMissionLock.localAnswerCount} پاسخ مستقل، بدون ادغام خدمت ارائه‌شده با ارزیابی یا ارجاع</p>
    </div>
  </div>

  <div id={homepageMissionLock.localAnswerListId} class="best-doctor__grid best-doctor__grid--intent" data-answer-list="local-service-intents">
    {localServiceIntentAnswers.map((entry) => (
      <section
        id={entry.id}
        class="best-doctor__item best-doctor__item--intent"
        aria-labelledby={`${entry.id}-title`}
        data-intent-scope={entry.scope}
        data-service-family={entry.family}
        data-coverage-relationship={entry.relationship}
      >
        <span class="best-doctor__icon"><SearchCheck size={20} aria-hidden="true" /></span>
        <span class="best-doctor__relationship">{relationshipLabels[entry.relationship]}</span>
        <h3 id={`${entry.id}-title`}>{entry.question}</h3>
        <p><strong>پاسخ مستقیم:</strong> {entry.answer}</p>
        <a href={entry.href}>راهنمای کامل و معیارهای همین موضوع</a>
      </section>
    ))}
  </div>

  <div class="best-doctor__subheading best-doctor__subheading--national">
    <MapPin size={23} aria-hidden="true" />
    <div>
      <p class="eyebrow">توسعه Authority از لوکال به ملی</p>
      <p>استاندارد تصمیم، پرونده پیچیده و پیگیری مراجعه‌کننده غیربومی</p>
    </div>
  </div>

  <div id={homepageMissionLock.nationalAnswerListId} class="best-doctor__grid best-doctor__grid--national" data-answer-list="national-authority-intents">
    {nationalAuthorityAnswers.map((entry) => (
      <section
        id={entry.id}
        class="best-doctor__item best-doctor__item--national"
        aria-labelledby={`${entry.id}-title`}
        data-intent-scope={entry.scope}
        data-coverage-relationship={entry.relationship}
      >
        <span class="best-doctor__icon"><MapPin size={20} aria-hidden="true" /></span>
        <h3 id={`${entry.id}-title`}>{entry.question}</h3>
        <p><strong>پاسخ مستقیم:</strong> {entry.answer}</p>
        <a href={entry.href}>ادامه مسیر تصمیم در همین صفحه</a>
      </section>
    ))}
  </div>
</section>

<style>
  .best-doctor{padding-block:clamp(2.5rem,6vw,5.5rem)}
  .best-doctor__intro{max-width:76rem;margin:1.25rem 0 1.5rem}
  .best-doctor__grid{display:grid;grid-template-columns:repeat(12,minmax(0,1fr));gap:1rem}
  .best-doctor__item{position:relative;grid-column:span 6;padding:1.15rem;border:1px solid var(--line);border-radius:1.25rem;background:var(--surface);box-shadow:var(--shadow-sm)}
  .best-doctor__item--core{grid-column:span 4}
  .best-doctor__item--national{grid-column:span 4;background:linear-gradient(180deg,var(--surface),var(--surface-soft))}
  .best-doctor__item h3{margin:.75rem 0;font-size:clamp(1.05rem,2vw,1.3rem);line-height:1.75}
  .best-doctor__item p{margin:.55rem 0;line-height:2}
  .best-doctor__item a{display:inline-flex;margin-top:.55rem;font-weight:800;text-underline-offset:.3em}
  .best-doctor__icon{display:inline-grid;place-items:center;width:2.3rem;height:2.3rem;border-radius:.8rem;background:var(--accent-soft);color:var(--accent)}
  .best-doctor__relationship{display:inline-flex;margin-inline-start:.5rem;padding:.25rem .55rem;border-radius:999px;background:var(--surface-soft);font-size:.78rem;font-weight:800}
  .best-doctor__subheading{display:flex;align-items:center;gap:.75rem;margin:2rem 0 1rem;padding:1rem 1.1rem;border-inline-start:.25rem solid var(--accent);background:var(--surface-soft);border-radius:1rem}
  .best-doctor__subheading p{margin:0}
  .best-doctor__subheading--national{margin-top:2.5rem}
  @media (max-width:900px){.best-doctor__item,.best-doctor__item--core,.best-doctor__item--national{grid-column:span 12}}
</style>
