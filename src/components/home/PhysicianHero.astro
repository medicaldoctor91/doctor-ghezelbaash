---
import { CalendarCheck, MapPin, MessageCircle, Star } from '@lucide/astro';
import { site } from '../../domain/entities';
import { homepageEntityIds } from '../../domain/homepage-sections';

const ratingValue = site.googleBusinessProfile.ratingValue.toLocaleString('fa-IR');
const bestRating = site.googleBusinessProfile.bestRating.toLocaleString('fa-IR');
const ratingCount = site.googleBusinessProfile.ratingCount.toLocaleString('fa-IR');
---

<header id={homepageEntityIds.person} class="physician-hero shell" aria-labelledby="page-title" data-main-entity="Person">
  <div class="physician-hero__copy">
    <h1 id="page-title">دکتر سعید قزلباش؛ پزشک زیبایی، پوست و مو در کرمانشاه</h1>
    <div class="physician-hero__introduction" data-physician-introduction>
      <p><strong>{site.legalName}</strong>، با نام حرفه‌ای <strong>دکتر سعید قزلباش</strong>، دارای دکترای حرفه‌ای پزشکی و شماره نظام پزشکی <strong>{site.irimc}</strong> است. فعالیت او در کرمانشاه بر ارزیابی و درمان مسائل پزشکی زیبایی، پوست و مو متمرکز است. نقطه شروع این رویکرد انتخاب نام یک روش یا محصول نیست؛ ابتدا باید مشخص شود مسئله ظاهری از حرکت عضله، کیفیت پوست، کاهش حجم، جابه‌جایی بافت، چربی، ساختار استخوانی یا ترکیبی از این عوامل ایجاد شده است.</p>
      <p>در ارزیابی پیش از درمان، سابقه تزریق یا جراحی قبلی، داروها، بیماری‌های زمینه‌ای، کیفیت پوست، آناتومی و نتیجه واقع‌بینانه بررسی می‌شوند. بخشی از تصمیم پزشکی نیز تشخیص مرز روش‌های غیرجراحی است؛ در مواردی که قدرت ابزار با شدت مشکل هماهنگ نیست، انجام ندادن درمان یا ارجاع برای ارزیابی جراحی می‌تواند انتخاب دقیق‌تری باشد.</p>
      <p>فعالیت پژوهشی و آموزش پزشکی نیز بخشی از سابقه حرفه‌ای دکتر قزلباش است. مقاله‌های منتشرشده، شناسه ORCID و کتاب‌شناسی عمومی NCBI در همین صفحه به منبع اصلی متصل شده‌اند. دو نمونه ویدئوی آموزش پزشکی نیز در بخش اختصاصی پژوهش و آموزش قرار دارند تا این سابقه با محتوای قابل مشاهده و قابل بررسی معرفی شود، نه با یک عنوان تبلیغاتی کوتاه.</p>
    </div>
  </div>

  <div class="physician-hero__media">
    <figure class="physician-hero__portrait" data-contextual-image data-lcp-portrait>
      <picture>
        <source type="image/avif" srcset="/images/responsive/doctor-portrait-480.avif 480w, /images/responsive/doctor-portrait-768.avif 768w, /images/responsive/doctor-portrait-1200.avif 1200w, /images/responsive/doctor-portrait-1600.avif 1600w" sizes="(min-width: 72rem) 68rem, 100vw" />
        <source type="image/webp" srcset="/images/responsive/doctor-portrait-480.webp 480w, /images/responsive/doctor-portrait-768.webp 768w, /images/responsive/doctor-portrait-1200.webp 1200w, /images/responsive/doctor-portrait-1600.webp 1600w" sizes="(min-width: 72rem) 68rem, 100vw" />
        <img src="/images/responsive/doctor-portrait-1200.jpg" srcset="/images/responsive/doctor-portrait-1200.jpg 1200w, /images/responsive/doctor-portrait-1600.jpg 1600w" sizes="(min-width: 72rem) 68rem, 100vw" alt="دکتر سعید قزلباش، پزشک زیبایی، پوست و مو در کرمانشاه" width="1600" height="1067" loading="eager" fetchpriority="high" decoding="async" />
      </picture>
      <figcaption>دکتر سعید قزلباش در کلینیک پزشکی زیبایی در کرمانشاه</figcaption>
    </figure>

    <div class="physician-hero__bar" aria-label="اعتبار کلینیک و اقدام‌های اصلی" data-hero-trust-bar>
      <div class="physician-hero__clinic">
        <span class="physician-hero__rating" data-rating-value={site.googleBusinessProfile.ratingValue} data-rating-count={site.googleBusinessProfile.ratingCount}>
          <Star size={19} aria-hidden="true" />
          <strong><bdi dir="rtl">{ratingValue} از {bestRating}</bdi></strong>
          <span>بر پایه {ratingCount} ارزیابی Google Maps</span>
        </span>
        <a href={site.maps} target="_blank" rel="noopener noreferrer external" data-location-link="google-maps"><MapPin size={18} aria-hidden="true" /> {site.clinicName}، {site.city} · بازکردن موقعیت در Google Maps</a>
      </div>
      <div class="physician-hero__actions">
        <a class="button button--primary" href={`tel:${site.phone}`} data-primary-cta="appointment"><CalendarCheck size={19} aria-hidden="true" /> رزرو وقت مشاوره رایگان</a>
        <a class="button button--ghost" href={site.instagramDirect} target="_blank" rel="noopener noreferrer external" data-primary-cta="instagram-direct"><MessageCircle size={19} aria-hidden="true" /> گفت‌وگوی آنلاین با دکتر قزلباش</a>
      </div>
    </div>
  </div>
</header>

<style>
  .physician-hero{display:grid;gap:clamp(1.25rem,4vw,2.4rem);padding-block:clamp(2rem,6vw,5rem) clamp(1rem,3vw,2.5rem);scroll-margin-top:6rem}.physician-hero__copy{max-width:68rem}.physician-hero__copy h1{margin:0 0 1rem;color:var(--blue-950);font-size:clamp(2rem,5vw,4.3rem);line-height:1.32;letter-spacing:-.025em}.physician-hero__introduction{max-width:58rem;color:#294c5e;font-size:clamp(.98rem,1.5vw,1.08rem);line-height:2.05}.physician-hero__introduction p{margin:0 0 .75rem}.physician-hero__media{display:grid;gap:.8rem;max-width:68rem}.physician-hero__portrait{margin:0;overflow:hidden;border:1px solid rgba(2,119,194,.13);border-radius:1.35rem;background:#fff;box-shadow:0 22px 64px rgba(5,69,105,.12)}.physician-hero__portrait picture,.physician-hero__portrait img{display:block;width:100%}.physician-hero__portrait img{height:auto}.physician-hero__portrait figcaption{padding:.75rem 1rem;color:#466779;font-size:.78rem;line-height:1.7}.physician-hero__bar{display:grid;gap:1rem;padding:clamp(1rem,3vw,1.35rem);border:1px solid rgba(2,119,194,.15);border-radius:1.2rem;background:radial-gradient(circle at 100% 0%,rgba(255,196,69,.18),transparent 16rem),rgba(255,255,255,.94);box-shadow:0 18px 48px rgba(5,69,105,.08)}.physician-hero__clinic{display:grid;gap:.55rem}.physician-hero__rating,.physician-hero__clinic a{display:flex;gap:.42rem;align-items:center;flex-wrap:wrap}.physician-hero__rating{color:var(--blue-950)}.physician-hero__rating>span{color:var(--muted);font-size:.8rem;font-weight:700}.physician-hero__clinic a{width:fit-content;color:var(--blue-700);font-size:.83rem;font-weight:750;line-height:1.8;text-underline-offset:.22em}.physician-hero__actions{display:grid;gap:.65rem}.physician-hero__actions .button{justify-content:center;text-align:center}@media(min-width:58rem){.physician-hero__bar{grid-template-columns:minmax(0,1fr) auto;align-items:center}.physician-hero__actions{grid-template-columns:repeat(2,minmax(14rem,auto))}}
</style>
