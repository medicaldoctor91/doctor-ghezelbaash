---
import { BookOpen, ChevronLeft, ChevronRight, CirclePlay, Clock3, ListVideo } from '@lucide/astro';
import { videos } from '../../domain/media.mjs';
import { videoPageDetails } from '../../domain/video-pages.mjs';
import { readMediaChapters } from '../../lib/media';

const videoItems = videos.map((video: any) => {
  const details = videoPageDetails[video.id];
  const chapters = readMediaChapters(video.chapterTrack).slice(0, 3);
  return { ...video, details, chapters };
});

const timeLabel = (timestamp: string) => timestamp.replace(/^00:/, '');
const isoTime = (seconds: number) => `PT${Math.max(0, Math.round(seconds * 1000) / 1000)}S`;
---

<section id="videos" class="section section--tint" aria-labelledby="videos-title">
  <span id="video-knowledge-hub" class="anchor-alias" aria-hidden="true"></span>
  <div class="shell">
    <div class="section-heading section-heading--split video-library__heading">
      <div>
        <p class="eyebrow">کتابخانهٔ ویدئویی</p>
        <h2 id="videos-title">تصمیم بالینی در حرکت</h2>
      </div>
      <p>۱۲ ویدئوی واقعی در همین صفحه قرار گرفته‌اند؛ نمونه، آموزش و مرز درمان کنار هم، بدون صفحهٔ جداگانه.</p>
    </div>

    <div class="video-library__toolbar" role="group" aria-label="کنترل کتابخانهٔ ویدئویی">
      <p><strong>۱۲ ویدئو</strong><span aria-hidden="true">—</span> برای دیدن همه، ورق بزنید</p>
      <div class="video-library__buttons">
        <button type="button" class="video-library__button" data-video-previous aria-label="ویدئوی قبلی">
          <ChevronRight size={20} aria-hidden="true" />
        </button>
        <button type="button" class="video-library__button" data-video-next aria-label="ویدئوی بعدی">
          <ChevronLeft size={20} aria-hidden="true" />
        </button>
      </div>
    </div>

    <div class="video-rail" data-video-rail tabindex="0" role="region" aria-label="۱۲ ویدئوی آموزشی و نمونه‌های بالینی">
      {videoItems.map((video: any, index: number) => (
        <article id={`video-${video.id}`} class="video-card" data-video-card>
          <div class="video-card__media">
            <span class="video-card__number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
            <video
              controls
              playsinline
              preload="none"
              poster={video.thumbnail}
              width={video.width}
              height={video.height}
              aria-labelledby={`video-${video.id}-title`}
              aria-describedby={`video-${video.id}-description`}
            >
              <source src={`/videos/${video.file}`} type="video/mp4" />
              {video.chapterTrack && (
                <track kind="chapters" src={video.chapterTrack} srclang="fa" label="فصل‌بندی فارسی" default />
              )}
              مرورگر شما پخش ویدئو را پشتیبانی نمی‌کند.
            </video>
          </div>

          <div class="video-card__body">
            <div class="video-card__meta">
              <span><CirclePlay size={16} aria-hidden="true" /> ویدئوی کوتاه</span>
              <span><Clock3 size={16} aria-hidden="true" /> حدود {video.durationSeconds} ثانیه</span>
            </div>
            {video.tags?.[0] && <span class="video-card__tag">{video.tags[0]}</span>}
            <h3 id={`video-${video.id}-title`}>{video.title}</h3>
            <p id={`video-${video.id}-description`}>{video.description}</p>

            {video.chapters.length > 0 && (
              <div class="video-chapters" role="group" aria-label={`فصل‌های ${video.title}`}>
                <strong><ListVideo size={17} aria-hidden="true" /> فصل‌ها</strong>
                <ol>
                  {video.chapters.map((chapter: any, index: number) => (
                    <li id={`video-${video.id}-clip-${index + 1}`}>
                      <button type="button" data-video-id={`video-${video.id}`} data-start={chapter.startOffset}>
                        <span>{chapter.name}</span>
                        <time datetime={isoTime(chapter.startOffset)}>{timeLabel(chapter.startTimestamp)}</time>
                      </button>
                    </li>
                  ))}
                </ol>
              </div>
            )}

            {video.details && (
              <details class="video-context">
                <summary>شرح بالینی و مرز تصمیم</summary>
                <p>{video.details.summary}</p>
                <ul>
                  {video.details.takeaways.map((item: string) => <li>{item}</li>)}
                </ul>
                <p class="video-boundary"><strong>مرز تصمیم:</strong> {video.details.boundary}</p>
              </details>
            )}

            {video.details?.relatedPath && (
              <a class="video-card__related" href={video.details.relatedPath}>
                <BookOpen size={16} aria-hidden="true" />
                <span>{video.details.relatedLabel}</span>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>

  <script is:inline>
    const rail = document.querySelector('[data-video-rail]');
    const cards = rail ? Array.from(rail.querySelectorAll('[data-video-card]')) : [];
    const currentCardIndex = () => {
      if (!rail || !cards.length) return 0;
      const railRect = rail.getBoundingClientRect();
      const isRtl = getComputedStyle(rail).direction === 'rtl';
      const startEdge = isRtl ? railRect.right : railRect.left;
      return cards.reduce((closest, card, index) => {
        const cardRect = card.getBoundingClientRect();
        const cardEdge = isRtl ? cardRect.right : cardRect.left;
        return Math.abs(cardEdge - startEdge) < closest.distance
          ? { index, distance: Math.abs(cardEdge - startEdge) }
          : closest;
      }, { index: 0, distance: Number.POSITIVE_INFINITY }).index;
    };

    const scrollToCard = (index) => {
      if (!cards.length) return;
      const target = Math.max(0, Math.min(cards.length - 1, index));
      cards[target].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
    };

    document.querySelector('[data-video-previous]')?.addEventListener('click', () => scrollToCard(currentCardIndex() - 1));
    document.querySelector('[data-video-next]')?.addEventListener('click', () => scrollToCard(currentCardIndex() + 1));

    document.addEventListener('click', (event) => {
      const button = event.target.closest?.('.video-chapters button');
      if (!button) return;
      const figure = document.getElementById(button.dataset.videoId || '');
      const video = figure?.querySelector('video');
      if (!video) return;
      video.currentTime = Number(button.dataset.start || 0);
      video.play().catch(() => {});
    });

    document.addEventListener('play', (event) => {
      const current = event.target;
      if (!(current instanceof HTMLVideoElement) || !current.closest('#videos')) return;
      document.querySelectorAll('#videos video').forEach((video) => {
        if (video !== current) video.pause();
      });
    }, true);
  </script>
</section>
