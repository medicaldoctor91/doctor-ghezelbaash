const plain = (value: string) => value.replace(/<[^>]+>/gu, ' ').replace(/\s+/gu, ' ').replaceAll('¶', '').trim();
const stripHeadingAnchors = (value: string) => value.replace(/<a[^>]*class="[^"]*heading-anchor[^"]*"[^>]*>[\s\S]*?<\/a>/giu, '');
const demoteAllH3 = (value: string) => stripHeadingAnchors(value).replace(/<h3\b[^>]*>/giu, '<h4>').replace(/<\/h3>/giu, '</h4>');

const fragments = new Map<string, { title: string; html: string }>();
for (const section of sections) {
  const html = stripHeadingAnchors(section.html);
  const matches = [...html.matchAll(/<h3\b[^>]*id="([^"]+)"[^>]*>([\s\S]*?)<\/h3>/giu)];
  for (let index = 0; index < matches.length; index += 1) {
    const match = matches[index];
    const start = (match.index ?? 0) + match[0].length;
    const end = matches[index + 1]?.index ?? html.length;
    fragments.set(match[1], { title: plain(match[2]), html: html.slice(start, end) });
  }
}

const sourceHtml = (source: Source) => {
  if (source.manualHtml) return source.manualHtml;
  if (source.section) return demoteAllH3(bySection.get(source.section)?.html ?? '');
  return (source.headings ?? []).map((id) => {
    const fragment = fragments.get(id);
    if (!fragment) return '';
    return `<h4>${fragment.title}</h4>${fragment.html}`;
  }).join('');
};

const videoItems = videos.map((video: any) => ({ ...video, details: videoPageDetails[video.id], chapters: readMediaChapters(video.chapterTrack).slice(0, 3) }));
const videosFor = (sectionId: string, subsectionId: string) => videoItems.filter((video: any) => video.sectionId === sectionId && video.subsectionId === subsectionId);
const timeLabel = (timestamp: string) => timestamp.replace(/^00:/, '');
const isoTime = (seconds: number) => `PT${Math.max(0, Math.round(seconds * 1000) / 1000)}S`;
const titleById = new Map(articleHomepageSections.map((section) => [section.id, section.title]));
---

<article id="clinical-guide" class="article-flow shell" aria-label="راهنمای جامع پزشکی زیبایی، پوست و مو">
  {groups.map((group) => (
    <section id={group.id} class="article-flow__section" aria-labelledby={`${group.id}-title`}>
      <h2 id={`${group.id}-title`} tabindex="-1">{titleById.get(group.id)}</h2>
      <div class="medical-article article-flow__body">
        <p class="article-flow__answer"><strong>پاسخ مستقیم:</strong> {group.intro}</p>
        {group.subsections.map((subsection) => {
          const subsectionVideos = videosFor(group.id, subsection.id);
          return (
            <section id={subsection.id} class="article-flow__subsection" aria-labelledby={`${subsection.id}-title`}>
              <h3 id={`${subsection.id}-title`} tabindex="-1">{subsection.title}</h3>
              <div class="medical-article__segment" set:html={subsection.sources.map(sourceHtml).join('')}></div>
              {group.id === 'medical-research-and-education' && subsection.id === 'medical-research' && (
                <p class="article-profile-links">
                  <a href={site.orcidUrl} target="_blank" rel="me noopener noreferrer external">ORCID دکتر سعید قزلباش</a><span aria-hidden="true"> · </span>
                  <a href={site.ncbiBibliography} target="_blank" rel="noopener noreferrer external">کتاب‌شناسی عمومی NCBI</a><span aria-hidden="true"> · </span>
                  <a href={site.doctorWikidata} target="_blank" rel="noopener noreferrer external">Wikidata پزشک</a>
                </p>
              )}
              {subsectionVideos.length > 0 && (
                <div class="article-media" aria-label={`ویدئوهای مرتبط با ${subsection.title}`}>
                  {subsectionVideos.map((video: any) => (
                    <figure id={`video-${video.id}`} class="article-video" data-inline-video>
                      <div class="article-video__media">
                        <video controls playsinline preload="none" poster={video.thumbnail} width={video.width} height={video.height} aria-labelledby={`video-${video.id}-title`} aria-describedby={`video-${video.id}-description`}>
                          <source src={`/videos/${video.file}`} type="video/mp4" />
                          {video.chapterTrack && <track kind="chapters" src={video.chapterTrack} srclang="fa" label="فصل‌بندی فارسی" default />}
                          مرورگر شما پخش ویدئو را پشتیبانی نمی‌کند.
                        </video>
                      </div>
                      <figcaption class="article-video__body">
                        <div class="article-video__meta"><span><CirclePlay size={16} aria-hidden="true" /> ویدئو</span><span><Clock3 size={16} aria-hidden="true" /> <time datetime={video.duration}>{video.details?.durationLabel ?? video.duration}</time></span></div>
                        <h4 id={`video-${video.id}-title`}>{video.title}</h4>
                        <p id={`video-${video.id}-description`}>{video.description}</p>
                        {video.chapters.length > 0 && (
                          <nav class="article-video__chapters" aria-label={`فصل‌های ${video.title}`}>
                            <span><ListVideo size={16} aria-hidden="true" /> فصل‌ها:</span>
                            {video.chapters.map((chapter: any) => (
                              <a href={`#video-${video.id}`} data-video-id={video.id} data-start={chapter.startOffset}><time datetime={isoTime(chapter.startOffset)}>{timeLabel(chapter.startTimestamp)}</time><span>{chapter.name}</span></a>
                            ))}
                          </nav>
                        )}
                      </figcaption>
                    </figure>
                  ))}
                </div>
              )}
            </section>
          );
        })}
      </div>
    </section>
  ))}
</article>

<script is:inline>
  document.querySelectorAll('[data-video-id][data-start]').forEach((link) => {
    link.addEventListener('click', (event) => {
      const target = event.currentTarget;
      const video = document.querySelector(`#video-${target.dataset.videoId} video`);
      if (!video) return;
      event.preventDefault();
      video.currentTime = Number(target.dataset.start || 0);
      video.play().catch(() => undefined);
      video.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });
</script>

<style>
  .article-flow__section,.article-flow__subsection{scroll-margin-top:6rem}.article-flow__section{padding-block:clamp(2.5rem,6vw,5rem)}.article-flow__section>h2{margin:0 0 1.1rem;color:var(--blue-950);font-size:clamp(1.45rem,3.4vw,2.25rem);line-height:1.65}.article-flow__subsection{margin-top:clamp(2rem,5vw,3.5rem)}.article-flow__subsection>h3{margin:0 0 .85rem;color:var(--blue-900);font-size:clamp(1.15rem,2.4vw,1.55rem);line-height:1.75}.article-flow__answer{padding:1rem;border-inline-start:.25rem solid var(--blue-600);border-radius:.65rem;background:rgba(2,119,194,.055)}.article-video h4{margin:.45rem 0;color:var(--blue-950);font-size:1rem;line-height:1.8}
</style>
