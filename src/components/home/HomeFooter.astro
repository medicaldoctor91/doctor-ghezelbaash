---
import { ArrowUp, CalendarCheck, MessageCircle } from '@lucide/astro';
import { site } from '../../domain/entities';
import { resolveHomepageExternalDirectory } from '../../domain/homepage-external-directory.mjs';
import BrandLogo from './BrandLogo.astro';

const year = new Date().getFullYear();
const modified = new Intl.DateTimeFormat('fa-IR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(site.dateModified));
const groups = resolveHomepageExternalDirectory(site);
const relFor = (link: any) => link.external
  ? `${link.relMe ? 'me ' : ''}noopener noreferrer external`
  : undefined;
---

<footer class="home-footer" data-stage-seven-footer>
  <div class="shell footer-identity">
    <BrandLogo compact />
    <div>
      <strong>{site.legalName}</strong>
      <p>دکترای حرفه‌ای پزشکی · شماره نظام پزشکی {site.irimc} · پزشک زیبایی، پوست و مو در کرمانشاه</p>
    </div>
  </div>

  <div
    id="external-entity-directory"
    class="shell footer-directory"
    aria-label="دایرکتوری دسته‌بندی‌شده منابع رسمی و قابل‌بررسی"
    data-stage-seven-directory
  >
    {groups.map((group: any) => (
      <nav data-footer-group={group.id} aria-labelledby={`footer-group-${group.id}`}>
        <strong id={`footer-group-${group.id}`}>{group.title}</strong>
        {group.links.map((link: any) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={relFor(link)}
            data-footer-link={link.id}
            data-footer-relation={link.relation}
            data-footer-entity={link.entity}
          >
            {link.label}
          </a>
        ))}
      </nav>
    ))}
  </div>

  <div class="shell footer-bottom">
    <span>© {year} دکتر سعید قزلباش · آخرین بازبینی: {modified}</span>
    <a href="#top"><ArrowUp size={17} aria-hidden="true" /> بازگشت به بالا</a>
  </div>
</footer>

<nav id="conversion-dock" class="mobile-dock" aria-label="اقدام‌های اصلی موبایل">
  <a href={`tel:${site.phone}`} data-contact-cta="phone"><CalendarCheck size={20} aria-hidden="true" /><span>رزرو مشاوره</span></a>
  <a href={site.instagramDirect} target="_blank" rel="noopener noreferrer external" data-contact-cta="instagram-direct"><MessageCircle size={20} aria-hidden="true" /><span>گفت‌وگوی آنلاین</span></a>
</nav>

<style>
  .footer-identity{display:flex;gap:.9rem;align-items:center;padding-block:2rem 1rem}.footer-identity strong{color:#fff}.footer-identity p{margin:.25rem 0 0;color:rgba(255,255,255,.7);font-size:.78rem;line-height:1.7}.footer-directory{display:grid;gap:1.4rem;padding-block:1rem 2rem}.footer-directory nav{display:grid;align-content:start;gap:.5rem}.footer-directory strong{margin-bottom:.25rem;color:#fff;font-size:.9rem}.footer-directory a{color:rgba(255,255,255,.74);font-size:.76rem;line-height:1.75;text-decoration-thickness:.06em;text-underline-offset:.2em}.footer-directory a:hover{color:#fff}@media(min-width:48rem){.footer-directory{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(min-width:72rem){.footer-directory{grid-template-columns:repeat(5,minmax(0,1fr))}}
</style>
