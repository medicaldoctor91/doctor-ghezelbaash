---
import { ArrowLeft, BadgeCheck, MapPin, Phone, Star } from '@lucide/astro';
import { site } from '../../domain/entities';
---

<section class="hero shell" aria-labelledby="hero-title">
  <span id="doctor" class="anchor-alias" aria-hidden="true"></span>
  <span id="person" class="anchor-alias" aria-hidden="true"></span>
  <span id="entity-authority-panel" class="anchor-alias" aria-hidden="true"></span>
  <span id="decision-model" class="anchor-alias" aria-hidden="true"></span>
  <span id="clinical-process" class="anchor-alias" aria-hidden="true"></span>
  <span id="clinical-decision-model-overview" class="anchor-alias" aria-hidden="true"></span>

  <div class="hero__copy">
    <p class="eyebrow">پزشک، پژوهشگر و مدرس پزشکی زیبایی</p>
    <h1 id="hero-title">دکتر سعید قزلباش؛ پزشک زیبایی در کرمانشاه</h1>
    <p class="hero__lead">
      صفحه رسمی معرفی دکتر سعید قزلباش و کلینیک محل فعالیت او؛ شامل خدمات زیبایی جراحی و غیرجراحی، راهنمای انتخاب درمان، سوابق قابل بررسی، پاسخ‌های کوتاه و مسیر مستقیم تماس و مراجعه.
    </p>
    <div class="hero__actions">
      <a class="button button--primary" href={`tel:${site.phone}`}>
        <Phone size={19} aria-hidden="true" />
        تماس با کلینیک
      </a>
      <a class="button button--ghost" href="#services">
        خدمات را ببینید
        <ArrowLeft size={19} aria-hidden="true" />
      </a>
    </div>
    <dl class="hero__facts">
      <div>
        <dt><BadgeCheck size={18} aria-hidden="true" /> شماره نظام پزشکی</dt>
        <dd>{site.irimc}</dd>
      </div>
      <div>
        <dt><MapPin size={18} aria-hidden="true" /> نشانی</dt>
        <dd>{site.city}، ساختمان ویستا</dd>
      </div>
      <div>
        <dt><Star size={18} aria-hidden="true" /> امتیاز کلینیک در Google Maps</dt>
        <dd>
          <a href="#clinic-reputation">
            <bdi dir="ltr">{site.googleBusinessProfile.ratingValue.toFixed(1)} / {site.googleBusinessProfile.bestRating}</bdi>
            <span> · {site.googleBusinessProfile.ratingCount.toLocaleString('fa-IR')} نظر</span>
          </a>
        </dd>
      </div>
    </dl>
  </div>

  <figure class="hero__portrait" data-contextual-image>
    <picture>
      <source
        type="image/avif"
        srcset="/images/responsive/doctor-portrait-480.avif 480w, /images/responsive/doctor-portrait-768.avif 768w, /images/responsive/doctor-portrait-1200.avif 1200w, /images/responsive/doctor-portrait-1600.avif 1600w"
        sizes="(min-width: 920px) 42vw, 100vw"
      />
      <source
        type="image/webp"
        srcset="/images/responsive/doctor-portrait-480.webp 480w, /images/responsive/doctor-portrait-768.webp 768w, /images/responsive/doctor-portrait-1200.webp 1200w, /images/responsive/doctor-portrait-1600.webp 1600w"
        sizes="(min-width: 920px) 42vw, 100vw"
      />
      <img
        src="/images/responsive/doctor-portrait-1200.jpg"
        srcset="/images/responsive/doctor-portrait-1200.jpg 1200w, /images/responsive/doctor-portrait-1600.jpg 1600w"
        sizes="(min-width: 920px) 42vw, 100vw"
        alt="دکتر سعید قزلباش، پزشک زیبایی در کرمانشاه"
        width="1600"
        height="1067"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <figcaption>
      <strong>{site.legalName}</strong>
      <span>دکترای حرفه‌ای پزشکی · شماره نظام پزشکی {site.irimc}</span>
    </figcaption>
  </figure>
</section>

<style>
  .hero__facts dd a {
    color: inherit;
    text-decoration: none;
  }

  .hero__facts dd a span {
    color: var(--muted);
    font-size: .78rem;
    font-weight: 700;
  }
</style>
