---
import { Menu, Phone, X } from '@lucide/astro';
import { site } from '../../domain/entities';
import BrandLogo from './BrandLogo.astro';

const links = [
  { href: '#clinic-information-kermanshah', label: 'کلینیک و موقعیت' },
  { href: '#aesthetic-services-kermanshah', label: 'خدمات' },
  { href: '#aesthetic-faq-kermanshah-iran', label: 'پرسش‌های متداول' },
  { href: '#content-table', label: 'فهرست مطالب' },
  { href: '#sources-contact-and-appointment', label: 'تماس و نوبت' },
];
---

<header class="home-header">
  <nav class="shell home-header__inner" aria-label="ناوبری اصلی">
    <a class="home-brand" href="#top" aria-label="دکتر سعید قزلباش؛ بازگشت به ابتدای صفحه">
      <BrandLogo compact priority />
      <span class="home-brand__copy">
        <strong>{site.name}</strong>
        <small>پزشکی زیبایی، پوست و مو · کرمانشاه</small>
      </span>
    </a>

    <div class="home-header__links">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>

    <div class="home-header__actions">
      <a class="button button--primary header-call" href={`tel:${site.phone}`}>
        <Phone size={18} aria-hidden="true" />
        تماس
      </a>
      <details class="mobile-menu">
        <summary aria-label="بازکردن منو" aria-controls="mobile-navigation" aria-expanded="false">
          <Menu class="mobile-menu__open" aria-hidden="true" />
          <X class="mobile-menu__close" aria-hidden="true" />
        </summary>
        <nav id="mobile-navigation" aria-label="منوی موبایل">
          {links.map((link) => <a href={link.href}>{link.label}</a>)}
          <a href={`tel:${site.phone}`}>تماس با کلینیک</a>
        </nav>
      </details>
    </div>
  </nav>
</header>

<script>
  const menu = document.querySelector<HTMLDetailsElement>('.mobile-menu');

  if (menu) {
    const summary = menu.querySelector<HTMLElement>('summary');

    const syncState = () => {
      const isOpen = menu.open;
      summary?.setAttribute('aria-expanded', String(isOpen));
      summary?.setAttribute('aria-label', isOpen ? 'بستن منو' : 'بازکردن منو');
    };

    const closeMenu = () => {
      if (!menu.open) return;
      menu.open = false;
      syncState();
    };

    menu.addEventListener('toggle', syncState);
    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenu();
    });

    document.addEventListener('pointerdown', (event) => {
      if (menu.open && event.target instanceof Node && !menu.contains(event.target)) closeMenu();
    });
  }
</script>
