---
import { Menu, Phone, X } from '@lucide/astro';
import { site } from '../../domain/entities';
import BrandLogo from './BrandLogo.astro';

const links = [
  { href: '#clinic-information-kermanshah', label: 'کلینیک و موقعیت' },
  { href: '#aesthetic-services-kermanshah', label: 'موضوعات زیبایی' },
  { href: '#aesthetic-faq-kermanshah-iran', label: 'پرسش‌های متداول' },
  { href: '#content-table', label: 'فهرست مطالب' },
  { href: '#sources-contact-and-appointment', label: 'تماس و نوبت' },
];
---

<header class="home-header">
  <nav class="shell home-header__inner" aria-label="ناوبری اصلی">
    <a class="home-brand" href="#top" aria-label="دکتر سعید قزلباش؛ بازگشت به ابتدای صفحه" data-section-link>
      <BrandLogo compact priority />
      <span class="home-brand__copy">
        <strong>{site.name}</strong>
        <small>پزشکی زیبایی، پوست و مو · کرمانشاه</small>
      </span>
    </a>

    <div class="home-header__links">
      {links.map((link) => <a href={link.href} data-section-link>{link.label}</a>)}
    </div>

    <div class="home-header__actions">
      <a class="button button--primary header-call" href={`tel:${site.phone}`}>
        <Phone size={18} aria-hidden="true" />
        تماس
      </a>
      <details class="mobile-menu">
        <summary aria-label="بازکردن منو" aria-controls="mobile-navigation" aria-expanded="false">
          <Menu class="mobile-menu__open" aria-hidden="true" />
          <X class="mobile-menu__close" aria-hidden="true" />
        </summary>
        <nav id="mobile-navigation" aria-label="منوی موبایل">
          {links.map((link) => <a href={link.href} data-section-link>{link.label}</a>)}
          <a href={`tel:${site.phone}`}>تماس با کلینیک</a>
        </nav>
      </details>
    </div>
  </nav>
</header>

<script>
  const menu = document.querySelector<HTMLDetailsElement>('.mobile-menu');
  const sectionLinks = [...document.querySelectorAll<HTMLAnchorElement>('[data-section-link][href^="#"]')];

  const decodeFragment = (href: string) => {
    try { return decodeURIComponent(href.replace(/^#/, '')); } catch { return href.replace(/^#/, ''); }
  };

  const linksFor = (fragment: string) => sectionLinks.filter((link) => decodeFragment(link.hash) === fragment);

  const setCurrent = (fragment: string | null) => {
    sectionLinks.forEach((link) => link.removeAttribute('aria-current'));
    if (!fragment) return;
    linksFor(fragment).forEach((link) => link.setAttribute('aria-current', 'location'));
  };

  const focusFragment = () => {
    const fragment = decodeFragment(window.location.hash);
    if (!fragment) return;
    const target = document.getElementById(fragment);
    if (!target) return;
    const hadTabindex = target.hasAttribute('tabindex');
    if (!hadTabindex) target.setAttribute('tabindex', '-1');
    requestAnimationFrame(() => target.focus({ preventScroll: true }));
    if (!hadTabindex) target.addEventListener('blur', () => target.removeAttribute('tabindex'), { once: true });
  };

  if (menu) {
    const summary = menu.querySelector<HTMLElement>('summary');
    const syncState = () => {
      const isOpen = menu.open;
      summary?.setAttribute('aria-expanded', String(isOpen));
      summary?.setAttribute('aria-label', isOpen ? 'بستن منو' : 'بازکردن منو');
    };
    const closeMenu = () => {
      if (!menu.open) return;
      menu.open = false;
      syncState();
    };
    menu.addEventListener('toggle', syncState);
    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
    document.addEventListener('keydown', (event) => { if (event.key === 'Escape') closeMenu(); });
    document.addEventListener('pointerdown', (event) => {
      if (menu.open && event.target instanceof Node && !menu.contains(event.target)) closeMenu();
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const initialFragment = decodeFragment(window.location.hash);
    setCurrent(initialFragment || null);
    focusFragment();
    const targets = sectionLinks
      .map((link) => document.getElementById(decodeFragment(link.hash)))
      .filter((target): target is HTMLElement => Boolean(target));
    if (!('IntersectionObserver' in window) || !targets.length) return;
    const observer = new IntersectionObserver((entries) => {
      const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (visible?.target.id) setCurrent(visible.target.id);
    }, { rootMargin: '-18% 0px -68%', threshold: [0, .01, .25] });
    targets.forEach((target) => observer.observe(target));
  });

  window.addEventListener('hashchange', () => {
    const fragment = decodeFragment(window.location.hash);
    setCurrent(fragment || null);
    focusFragment();
  });
</script>

<style>
  [data-section-link][aria-current="location"]{color:var(--blue-800);text-decoration:underline;text-decoration-thickness:.12em;text-underline-offset:.35em}.mobile-menu nav [aria-current="location"]{background:var(--blue-050)}
</style>
