---
import { clinic } from '../data/clinic';
import type { AssetManifest } from '../utils/graph';
import ResponsiveImage from './ResponsiveImage.astro';

interface Props { assets: AssetManifest; }
const { assets } = Astro.props;
---

<section id="clinic-entity" class="entity-card entity-card--clinic" aria-labelledby="clinic-entity-title">
  <div class="entity-card__intro">
    <span class="section-kicker">محل ارزیابی و مراجعه حضوری</span>
    <h2 id="clinic-entity-title">کلینیک در کرمانشاه؛ مسیر روشن، تماس مستقیم</h2>
    <div class="content-slot"><slot /></div>
    <div class="clinic-actions">
      <a class="button button--primary" href={`tel:${clinic.telephone}`}>تماس با کلینیک</a>
      <a class="button button--outline" href={clinic.mapsUrl} rel="noopener noreferrer">بازکردن Google Maps</a>
    </div>
  </div>

  <aside class="location-panel" aria-label="اطلاعات مراجعه کلینیک">
    <ResponsiveImage id="clinic-interior" asset={assets.images['clinic-interior']} class="location-panel__photo" />
    <div class="location-panel__map" aria-hidden="true">
      <svg viewBox="0 0 240 150"><path d="M0 25c40 25 70-22 112 10s71 7 128-19v134H0V25Z" /><path d="M18 118c40-14 61-58 104-52s63 34 104 11" /><path d="M44 15c20 30 2 67 33 88s68 5 89 36" /><circle cx="133" cy="68" r="8" /><circle cx="133" cy="68" r="17" /></svg>
    </div>
    <span class="location-panel__pin" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 21s6-5.3 6-12A6 6 0 1 0 6 9c0 6.7 6 12 6 12Zm0-9.3A2.7 2.7 0 1 1 12 6a2.7 2.7 0 0 1 0 5.7Z" /></svg></span>
    <dl class="facts facts--location">
      <div><dt>نشانی</dt><dd><address>{clinic.address.addressLocality}، {clinic.address.streetAddress}</address></dd></div>
      <div><dt>تلفن مستقیم</dt><dd><a href={`tel:${clinic.telephone}`}>{clinic.telephoneDisplay}</a></dd></div>
      <div><dt>کد پستی</dt><dd><bdi>{clinic.address.postalCode}</bdi></dd></div>
    </dl>
    <div class="clinic-gallery" aria-label="تصاویر فضای کلینیک">
      <ResponsiveImage id="clinic-waiting-room" asset={assets.images['clinic-waiting-room']} />
      <ResponsiveImage id="clinic-interior-2" asset={assets.images['clinic-interior-2']} />
      <ResponsiveImage id="clinic-corridor" asset={assets.images['clinic-corridor']} />
      <ResponsiveImage id="clinic-environment-3" asset={assets.images['clinic-environment-3']} />
    </div>
  </aside>
</section>
