---
import '../styles/global.css';
import { site } from '../domain/entities';

interface Props {
  graph: Record<string, unknown>;
  title?: string;
  description?: string;
  canonical?: string;
  robots?: string;
  ogType?: 'website' | 'article';
}

const {
  graph,
  title = site.title,
  description = site.description,
  canonical = site.url,
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
  ogType = 'website',
} = Astro.props;

const absolute = (path: string) => new URL(path.replace(/^\//, ''), site.url).href;
---

<!doctype html>
<html lang={site.language} dir={site.direction}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#0277c2" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=yes" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.legalName} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="author" href={`${site.url}#person`} />
    <link rel="me" href={site.orcidUrl} />
    <link rel="me" href={site.instagram} />
    <link rel="alternate" hreflang="fa-IR" href={canonical} />
    <link rel="alternate" hreflang="fa" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="describedby" type="application/ld+json" href="/knowledge-graph.jsonld" title="گراف دانش اصلی وب‌سایت" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="خلاصهٔ متنی وب‌سایت" />
    <link
      rel="preload"
      as="image"
      href="/images/responsive/doctor-portrait-768.avif"
      type="image/avif"
      imagesrcset="/images/responsive/doctor-portrait-480.avif 480w, /images/responsive/doctor-portrait-768.avif 768w, /images/responsive/doctor-portrait-1200.avif 1200w, /images/responsive/doctor-portrait-1600.avif 1600w"
      imagesizes="(min-width: 920px) 42vw, 100vw"
      fetchpriority="high"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="geo.region" content="IR-05" />
    <meta name="geo.placename" content={site.city} />
    <meta name="geo.position" content={`${site.latitude};${site.longitude}`} />
    <meta name="ICBM" content={`${site.latitude}, ${site.longitude}`} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:site_name" content={site.clinicName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absolute(site.ogImage)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="دکتر سعید قزلباش؛ پزشکی زیبایی در کرمانشاه" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absolute(site.ogImage)} />
  </head>
  <body>
    <slot />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(graph)} />
  </body>
</html>

