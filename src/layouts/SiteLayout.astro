---
import '../styles/global.css';
import '../styles/goal-first.css';
import { site } from '../domain/entities';
interface Props {
  graph: Record<string, unknown>;
  title?: string;
  description?: string;
  canonical?: string;
  robots?: string;
  ogType?: 'website' | 'article';
}
const {
  graph,
  title = site.title,
  description = site.description,
  canonical = site.url,
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
  ogType = 'article',
} = Astro.props;
const absolute = (path: string) => new URL(path.replace(/^\//, ''), site.url).href;
const ogPrefix = ogType === 'article'
  ? 'og: https://ogp.me/ns# article: https://ogp.me/ns/article#'
  : 'og: https://ogp.me/ns#';
---
<!doctype html>
<html lang={site.language} dir={site.direction} prefix={ogPrefix}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#005b99" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=yes" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.legalName} />
    <meta name="creator" content={site.legalName} />
    <meta name="publisher" content={site.clinicName} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="author" href={`${site.url}#person`} />
    <link rel="author" href={site.orcidUrl} title="ORCID research profile" />
    <link rel="me" href={site.orcidUrl} />
    <link rel="me" href={site.instagram} />
    <link rel="me" href={site.githubProfile} />
    <link rel="me" href={site.huggingFaceProfile} />
    <link rel="alternate" hreflang="fa-IR" href={canonical} />
    <link rel="alternate" hreflang="fa" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="alternate" type="text/plain" href="/.well-known/ai.txt" title="AI discovery policy" />
    <link rel="alternate" type="application/json" href="/ai/summary.json" title="AI summary" />
    <link rel="alternate" type="application/json" href="/ai/faq.json" title="AI FAQ" />
    <link rel="alternate" type="application/json" href="/context.json" title="Compact entity and service context" />
    <link rel="alternate" type="application/json" href="/knowledge-manifest.json" title="Knowledge artifact manifest" />
    <link rel="alternate" type="application/ld+json" href="/graph/core.jsonld" title="Canonical physician and clinic entity graph" />
    <link rel="alternate" type="application/json" href="/graph-summary.json" title="Knowledge graph summary" />
    <link rel="alternate" type="application/ld+json" href="/research.jsonld" title="Research identity and scholarly works" />
    <link rel="preload" as="image" href="/images/responsive/doctor-portrait-768.avif" type="image/avif" imagesrcset="/images/responsive/doctor-portrait-480.avif 480w, /images/responsive/doctor-portrait-768.avif 768w, /images/responsive/doctor-portrait-1200.avif 1200w, /images/responsive/doctor-portrait-1600.avif 1600w" imagesizes="(min-width: 900px) 34vw, 100vw" fetchpriority="high" />
    <meta name="generator" content={Astro.generator} />
    <meta name="geo.region" content="IR-05" />
    <meta name="geo.placename" content={site.city} />
    <meta name="geo.position" content={`${site.latitude};${site.longitude}`} />
    <meta name="ICBM" content={`${site.latitude}, ${site.longitude}`} />
    <meta name="DC.title" content={title} />
    <meta name="DC.creator" content={site.legalName} />
    <meta name="DC.publisher" content={site.clinicName} />
    <meta name="DC.language" content="fa-IR" />
    <meta name="DC.coverage" content="کرمانشاه، ایران" />
    <meta name="DC.type" content="Text" />
    <meta name="DC.identifier" content={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:site_name" content={site.clinicName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absolute(site.ogImage)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="دکتر سعید قزلباش؛ پزشکی زیبایی در کرمانشاه" />
    {ogType === 'article' && (
      <>
        <meta property="article:author" content={`${site.url}#person`} />
        <meta property="article:publisher" content={`${site.url}#clinic`} />
        <meta property="article:published_time" content={`${site.datePublished}T00:00:00+03:30`} />
        <meta property="article:modified_time" content={`${site.dateModified}T00:00:00+03:30`} />
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absolute(site.ogImage)} />
  </head>
  <body>
    <slot />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(graph)} />
  </body>
</html>
