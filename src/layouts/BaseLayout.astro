---
import { site } from '../data/site.mjs';
import { navRoutes } from '../lib/routes.mjs';
import { buildSeoMeta } from '../lib/seo.mjs';
import GlobalJsonLd from '../components/GlobalJsonLd.astro';
import PageJsonLd from '../components/PageJsonLd.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PersonSeoAeoEnhancements from '../components/PersonSeoAeoEnhancements.astro';
import PersonIranMedLabsInterview from '../components/PersonIranMedLabsInterview.astro';
import PersonProfileContent from '../components/PersonProfileContent.astro';
import StickyMobileCTA from '../components/ui/StickyMobileCTA.astro';

const {
  title = site.nameFa,
  description = 'Canonical public website and knowledge graph for Dr. Saeed Ghezelbash.',
  canonicalPath = '/',
  robots,
  breadcrumbs,
  pageType = 'WebPage',
  extraGraph = [],
  personEnhancements = 'auto'
} = Astro.props;

const seo = buildSeoMeta({ title, description, canonicalPath, robots });
const showPersonEnhancements = personEnhancements === 'auto'
  ? canonicalPath === '/dr-saeed-ghezelbash/'
  : Boolean(personEnhancements);
---
<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="robots" content={seo.robots} />
    <meta name="theme-color" content="#8b0000" />
    <meta name="format-detection" content="telephone=yes" />
    <link rel="canonical" href={seo.canonical} />
    <link rel="alternate" hreflang="fa-IR" href={seo.canonical} />
    <link rel="alternate" hreflang="x-default" href={seo.canonical} />
    <link rel="icon" href="/logo.png" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:site_name" content={site.nameFa} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.image} />
    <meta property="og:image:alt" content={site.personFa} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.image} />
    <GlobalJsonLd />
    <PageJsonLd title={seo.title} description={seo.description} canonicalPath={canonicalPath} pageType={pageType} breadcrumbs={breadcrumbs} extraGraph={extraGraph} />
    <style>
      :root{--brand:#8b0000;--brand-2:#5f0000;--brand-3:#b52a2a;--ink:#141414;--muted:#626262;--line:#ead7d7;--soft:#fff7f7;--soft-2:#fffdfb;--bg:#fff;--shadow:0 12px 34px rgba(139,0,0,.07);--shadow-2:0 6px 18px rgba(0,0,0,.035);--radius:18px}
      *{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:radial-gradient(circle at top left,rgba(139,0,0,.055),transparent 28rem),var(--bg);color:var(--ink);font-family:Tahoma,Arial,sans-serif;line-height:1.95;text-rendering:optimizeLegibility}
      a{color:var(--brand);text-underline-offset:.18em}.wrap{max-width:1080px;margin:auto;padding:18px}.top{border-bottom:1px solid var(--line);background:rgba(255,255,255,.94);position:sticky;top:0;z-index:5;box-shadow:0 1px 0 rgba(139,0,0,.03);backdrop-filter:blur(10px)}
      nav.wrap{display:flex;gap:.35rem;overflow-x:auto;white-space:nowrap;padding-block:12px}nav a{display:inline-block;padding:.32rem .7rem;border:1px solid var(--line);border-radius:999px;text-decoration:none;color:var(--brand);font-size:.92rem;background:#fff;transition:transform .18s ease,border-color .18s ease}nav a:hover{transform:translateY(-1px);border-color:#d9aaaa}
      h1,h2,h3{color:var(--brand);line-height:1.55;letter-spacing:-.015em}h1{font-size:clamp(1.55rem,3vw,2.18rem);margin:.35rem 0 .8rem}h2{font-size:clamp(1.25rem,2vw,1.55rem);margin-top:2.25rem}h3{font-size:1.07rem}.lead{font-size:1.08rem;color:#252525}.muted{color:var(--muted)}
      .box{border:1px solid var(--line);background:linear-gradient(135deg,var(--soft),#fff);border-radius:var(--radius);padding:1.1rem;margin:1.05rem 0;box-shadow:var(--shadow)}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:.9rem}
      .card{border:1px solid var(--line);border-radius:var(--radius);padding:1rem;background:rgba(255,255,255,.96);box-shadow:var(--shadow-2);transition:transform .18s ease,box-shadow .18s ease}.card:hover{transform:translateY(-2px);box-shadow:var(--shadow)}.card h3{margin-top:0}.card a{text-decoration:none}
      .section-block{margin:1.6rem 0}.section-block--emphasis{padding:1.15rem}.section-block > p{max-width:76ch}.small{font-size:.92rem;color:var(--muted)}.ltr{direction:ltr;text-align:left}
      .cta,.cta-secondary{display:inline-block;text-decoration:none;border-radius:12px;padding:.68rem 1rem;font-weight:bold;margin:.16rem 0}.cta{background:linear-gradient(135deg,var(--brand),var(--brand-2));color:#fff;box-shadow:0 8px 20px rgba(139,0,0,.16)}.cta-secondary{border:1px solid var(--line);color:var(--brand);background:#fff}.cta-cluster{margin:1rem 0}.hero-actions{display:flex;gap:.45rem;flex-wrap:wrap;margin-top:1rem}
      .hero-panel{position:relative;display:grid;grid-template-columns:minmax(0,1.45fr) minmax(240px,.55fr);gap:1rem;align-items:stretch;border:1px solid var(--line);background:linear-gradient(135deg,#fff7f7,#fff 52%,#fffdfb);border-radius:24px;padding:1.25rem;margin:1rem 0 1.15rem;box-shadow:var(--shadow);overflow:hidden}.hero-panel::before{content:'';position:absolute;inset:auto -3rem -4rem auto;width:12rem;height:12rem;background:radial-gradient(circle,rgba(139,0,0,.12),transparent 70%);pointer-events:none}.hero-copy{position:relative;z-index:1}.hero-eyebrow{display:inline-block;border:1px solid var(--line);border-radius:999px;background:#fff;padding:.15rem .65rem}.hero-aside{position:relative;z-index:1;margin:0}.hero-aside h2{margin-top:0;font-size:1.05rem}.hero-panel--service{background:linear-gradient(135deg,#fff7f7,#fff 58%,#fffaf4)}.hero-panel--person{background:linear-gradient(135deg,#fff6f6,#fff 54%,#fdf7f1)}
      .trust-strip{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:.65rem;margin:1rem 0}.trust-item{border:1px solid var(--line);border-radius:16px;background:#fff;padding:.85rem;box-shadow:var(--shadow-2)}.trust-kicker{display:block;color:var(--muted);font-size:.85rem;margin-bottom:.2rem}.trust-item strong{color:var(--brand)}
      .evidence-panel{display:grid;grid-template-columns:minmax(0,.8fr) minmax(0,1.2fr);gap:1rem;align-items:start;border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(135deg,#fff,#fff7f7);padding:1rem;margin:1.4rem 0;box-shadow:var(--shadow)}.evidence-panel h2{margin-top:.15rem}.evidence-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:.75rem}.evidence-link{display:block;text-decoration:none;border:1px solid var(--line);border-radius:14px;background:#fff;padding:.85rem}.evidence-link span{display:block;color:var(--muted);font-size:.9rem;margin-top:.25rem}
      .hero-grid{display:grid;grid-template-columns:minmax(0,1.4fr) minmax(220px,.6fr);gap:1rem;align-items:start}.fact-list{display:grid;gap:.55rem}.fact-item{border-bottom:1px solid var(--line);padding:.45rem 0}.fact-item:last-child{border-bottom:0}
      .breadcrumbs{margin:.5rem 0 1rem;color:var(--muted);font-size:.9rem}.breadcrumbs ol{display:flex;flex-wrap:wrap;gap:.35rem;list-style:none;padding:0;margin:0}.breadcrumbs li::after{content:'›';padding-inline:.35rem;color:var(--muted)}.breadcrumbs li:last-child::after{content:''}.breadcrumbs a{color:var(--brand);text-decoration:none;border:0;margin:0;padding:0}.breadcrumbs span{color:var(--muted)}
      footer{border-top:1px solid var(--line);margin-top:2rem;padding:1.2rem 0 4.2rem;color:var(--muted)}ul{padding-right:1.2rem}.sticky-mobile-cta{display:none}
      @media(max-width:760px){.wrap{padding:14px}.hero-panel,.hero-grid,.evidence-panel{grid-template-columns:1fr}.grid{grid-template-columns:1fr}nav.wrap{padding-inline:14px}.top{position:sticky}.sticky-mobile-cta{position:fixed;display:flex;gap:.5rem;align-items:center;justify-content:center;left:.75rem;right:.75rem;bottom:.75rem;background:rgba(255,255,255,.95);border:1px solid var(--line);border-radius:18px;padding:.55rem;z-index:9;box-shadow:0 16px 40px rgba(0,0,0,.12);backdrop-filter:blur(10px)}.sticky-mobile-cta .cta,.sticky-mobile-cta .cta-secondary{flex:1;text-align:center;margin:0;padding:.55rem .65rem;font-size:.92rem}}
    </style>
    <slot name="head" />
  </head>
  <body>
    <header class="top">
      <nav class="wrap" aria-label="ناوبری اصلی">
        {navRoutes.map((route) => <a href={route.path}>{route.label}</a>)}
      </nav>
    </header>
    <main class="wrap">
      <Breadcrumbs canonicalPath={canonicalPath} items={breadcrumbs} />
      <slot />
      {showPersonEnhancements && <PersonProfileContent />}
      {showPersonEnhancements && <PersonIranMedLabsInterview />}
      {showPersonEnhancements && <PersonSeoAeoEnhancements />}
    </main>
    <StickyMobileCTA primaryHref="/contact/" primaryLabel="تماس و آدرس" secondaryHref={site.instagram} secondaryLabel="اینستاگرام" />
    <footer class="wrap">
      <p>{site.nameFa} — {site.phoneDisplay} — <a href={site.instagram}>Instagram</a></p>
    </footer>
  </body>
</html>
