---
import type { AssetManifest } from '../utils/graph';
import type { CanonicalGraph } from '../utils/schema';
import { escapeJsonForHtml, seo } from '../utils/seo';
interface Props { graph: CanonicalGraph; assets: AssetManifest; }
const { graph, assets } = Astro.props;
const jsonLd = escapeJsonForHtml(graph);
const hero = assets.images['doctor-portrait'];
const heroSizes = '(max-width: 62rem) 100vw, 48vw';
const srcset = (variants: Array<{ src: string; width: number }> | undefined) =>
  variants?.map((variant) => `${variant.src} ${variant.width}w`).join(', ');
const heroPreload = hero?.avif
  ? { href: hero.avif, type: 'image/avif', srcset: srcset(hero.avifSrcset) }
  : hero?.webp
    ? { href: hero.webp, type: 'image/webp', srcset: srcset(hero.webpSrcset) }
    : hero?.fallback
      ? { href: hero.fallback, type: 'image/jpeg', srcset: srcset(hero.fallbackSrcset) }
      : null;
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    <meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
    <link rel="alternate" hreflang="fa-IR" href={seo.canonical} />
    <link rel="alternate" type="application/ld+json" href="https://www.ghezelbaash.ir/knowledge-graph.jsonld" />
    <link rel="describedby" type="application/ld+json" href="https://www.ghezelbaash.ir/knowledge-graph.jsonld" />
    <link rel="describedby" href="https://www.ghezelbaash.ir/llms.txt" />
    <meta name="theme-color" content="#0a211a" />
    <meta name="color-scheme" content="light" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:site_name" content={seo.siteName} />
    <meta property="og:image" content={seo.ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="نشان رسمی دکتر سعید قزلباش" />
    <meta property="og:locale" content={seo.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.ogImage} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {assets.font && <link rel="preload" href={assets.font} as="font" type="font/woff2" crossorigin />}
    {heroPreload && <link rel="preload" href={heroPreload.href} as="image" type={heroPreload.type} imagesrcset={heroPreload.srcset} imagesizes={heroSizes} fetchpriority="high" />}
    {assets.css && <link rel="stylesheet" href={assets.css} />}
    <script is:inline type="application/ld+json" set:html={jsonLd} />
    {assets.scripts?.navigation && <script is:inline src={assets.scripts.navigation} defer></script>}
  </head>
  <body id="top">
    <a class="skip-link" href="#main-content">رفتن به محتوای اصلی</a>
    <slot />
  </body>
</html>
