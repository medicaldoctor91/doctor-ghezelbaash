---
import { site } from '../data/site.mjs';
import { services } from '../data/services.mjs';
import { navRoutes } from '../lib/routes.mjs';
import { buildSeoMeta } from '../lib/seo.mjs';
import GlobalJsonLd from '../components/GlobalJsonLd.astro';
import PageJsonLd from '../components/PageJsonLd.astro';

const {
  title = site.nameFa,
  description = 'وب‌سایت رسمی دکتر سعید قزلباش و کلینیک زیبایی در کرمانشاه.',
  canonicalPath = '/',
  robots,
  breadcrumbs,
  pageType = 'WebPage',
  extraGraph = []
} = Astro.props;

const seo = buildSeoMeta({ title, description, canonicalPath, robots });
---
<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="robots" content={seo.robots} />
    <meta name="theme-color" content="#0f766e" />
    <link rel="canonical" href={seo.canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:site_name" content={site.nameFa} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.image} />
    <meta name="twitter:card" content="summary_large_image" />
    <GlobalJsonLd />
    <PageJsonLd title={seo.title} description={seo.description} canonicalPath={canonicalPath} pageType={pageType} breadcrumbs={breadcrumbs} extraGraph={extraGraph} />
    <style>
      body{margin:0;background:#f8fafc;color:#0f172a;font-family:Tahoma,Arial,sans-serif;line-height:1.9}a{color:#0f766e}.wrap{max-width:1120px;margin:auto;padding:18px}.top{position:sticky;top:0;background:#fff;border-bottom:1px solid #e2e8f0;z-index:10}nav{display:flex;gap:.5rem;overflow-x:auto}nav a{padding:.35rem .75rem;border:1px solid #e2e8f0;border-radius:999px;text-decoration:none;background:#fff}.box,.card{border:1px solid #e2e8f0;border-radius:22px;background:#fff;padding:1rem;box-shadow:0 10px 30px rgba(15,23,42,.05)}.box{background:linear-gradient(135deg,#f0fdfa,#fff);margin:1rem 0}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem}.cta,.cta-secondary{display:inline-block;border-radius:14px;padding:.65rem 1rem;font-weight:bold;text-decoration:none}.cta{background:#0f766e;color:#fff}.cta-secondary{border:1px solid #e2e8f0}.small,.muted{color:#64748b}.ltr{direction:ltr;text-align:left}footer{margin-top:3rem;border-top:1px solid #e2e8f0;background:#fff}
    </style>
    <slot name="head" />
  </head>
  <body>
    <header class="top"><nav class="wrap" aria-label="ناوبری اصلی">{navRoutes.map((route) => <a href={route.path}>{route.label}</a>)}</nav></header>
    <main class="wrap"><slot /></main>
    <footer><div class="wrap"><strong>{site.personFa}</strong><p class="muted">AstroWind + Astro 7 shell</p><p>{services.map((service) => <a class="cta-secondary" href={`/${service.slug}/`}>{service.shortTitle || service.title}</a>)}</p></div></footer>
  </body>
</html>
