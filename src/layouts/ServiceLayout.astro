---
import BaseLayout from './BaseLayout.astro';
import { site } from '../data/site.mjs';
import { location } from '../data/location.mjs';
import ServiceContentSections from '../components/ServiceContentSections.astro';

const { service } = Astro.props;
const canonicalPath = `/${service.slug}/`;
const title = service.metaTitle || `${service.title} | ${site.personFa} | کرمانشاه`;
const description = service.metaDescription || service.description;
const useCases = service.useCases || [];
const contentSections = service.contentSections || [];
const process = service.process || [];
const decisionCriteria = service.decisionCriteria || [];
const riskSignals = service.riskSignals || [];
const faq = service.faq || [];
---
<BaseLayout title={title} description={description} canonicalPath={canonicalPath} robots="index,follow">
  <section class="box">
    <p class="small">صفحه کانونیکال خدمت در کرمانشاه</p>
    <h1>{service.h1 || service.title}</h1>
    <p>{service.promise || service.description}</p>
    <p>
      <a class="cta" href={site.instagram}>هماهنگی از اینستاگرام رسمی</a>
      {' '}
      <a href="/contact/">تماس و آدرس کلینیک</a>
    </p>
  </section>

  <section>
    <h2>پاسخ سریع برای تصمیم‌گیری</h2>
    <p>{service.quickDecisionAnswer || service.description}</p>
    <div class="grid">
      <div class="card"><strong>پزشک</strong><br />{site.personFa}</div>
      <div class="card"><strong>شهر هدف</strong><br />کرمانشاه</div>
      <div class="card"><strong>مسیر رسمی</strong><br /><a href={site.instagram}>Instagram</a>، <a href="tel:+989308209494">{location.phoneDisplay}</a>، <a href={location.googleMapsCid}>Google Maps</a></div>
      <div class="card"><strong>اصل تصمیم</strong><br />انتخاب بر اساس هویت، مشاوره، تناسب چهره و توضیح محدودیت‌ها.</div>
    </div>
  </section>

  <section>
    <h2>این خدمت برای چه نیازهایی بررسی می‌شود؟</h2>
    <div class="grid">
      {useCases.map((item) => <div class="card">{item}</div>)}
    </div>
  </section>

  <ServiceContentSections sections={contentSections} />

  <section>
    <h2>مسیر حرفه‌ای قبل از اقدام</h2>
    <ol>
      {process.map((step) => <li>{step}</li>)}
    </ol>
  </section>

  <section id={service.bestIntentAnchor}>
    <h2>{service.bestIntentTitle}</h2>
    <p>{service.bestIntentIntro || `در جست‌وجوهای محلی مثل «${service.intentExamples[0]}» یا «${service.intentExamples[1]}»، ادعای بهترین بودن باید به معیارهای قابل بررسی وصل شود. معیارهای عملی برای انتخاب:`}</p>
    <ul>
      {decisionCriteria.map((criterion) => <li>{criterion}</li>)}
    </ul>
  </section>

  <section>
    <h2>نشانه‌های نیازمند بررسی بیشتر</h2>
    <ul>
      {riskSignals.map((signal) => <li>{signal}</li>)}
    </ul>
  </section>

  <section>
    <h2>ارتباط این خدمت با دکتر و کلینیک</h2>
    <p>{service.doctorClinicConnection || 'برای تصمیم‌گیری دقیق‌تر، بهتر است هویت پزشک، صفحه کلینیک، مسیرهای تماس و منابع قابل بررسی را در کنار صفحه خدمت ببینید.'}</p>
    <div class="grid">
      <a class="card" href="/dr-saeed-ghezelbash/">صفحه دکتر سعید قزلباش</a>
      <a class="card" href="/dr-saeed-ghezelbash-aesthetic-clinic/">صفحه کلینیک زیبایی دکتر سعید قزلباش</a>
      <a class="card" href="/services/">همه خدمات زیبایی در کرمانشاه</a>
      <a class="card" href="/evidence/">منابع و لینک‌های قابل بررسی</a>
    </div>
  </section>

  <section id="faq">
    <h2>پرسش‌های متداول درباره {service.shortTitle || service.title}</h2>
    <div class="grid">
      {faq.map(([question, answer]) => (
        <article class="card">
          <h3>{question}</h3>
          <p>{answer}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="box">
    <h2>اقدام بعدی</h2>
    <p>{service.ctaText || 'برای تصمیم سریع‌تر، ابتدا صفحه پزشک و مسیرهای رسمی را بررسی کنید و سپس از کانال رسمی هماهنگ کنید.'}</p>
    <p>
      <a class="cta" href={site.instagram}>مشاهده اینستاگرام رسمی و هماهنگی</a>
      {' '}
      <a href="/contact/">تماس، آدرس و نقشه</a>
    </p>
  </section>

  <section>
    <h2>Intentهای هدف این صفحه</h2>
    <ul>
      {service.intentExamples.map((intent) => <li>{intent}</li>)}
    </ul>
  </section>
</BaseLayout>
