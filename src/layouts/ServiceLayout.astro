---
import BaseLayout from './BaseLayout.astro';
import { site } from '../data/site.mjs';
import { location } from '../data/location.mjs';
import ServiceContentSections from '../components/ServiceContentSections.astro';
import Hero from '../components/ui/Hero.astro';
import TrustStrip from '../components/ui/TrustStrip.astro';
import EvidencePanel from '../components/ui/EvidencePanel.astro';

const { service } = Astro.props;
const canonicalPath = `/${service.slug}/`;
const title = service.metaTitle || `${service.title} | ${site.personFa} | کرمانشاه`;
const description = service.metaDescription || service.description;
const useCases = service.useCases || [];
const contentSections = service.contentSections || [];
const process = service.process || [];
const decisionCriteria = service.decisionCriteria || [];
const riskSignals = service.riskSignals || [];
const faq = service.faq || [];
const trustItems = [
  { kicker: 'پزشک', value: site.personFa },
  { kicker: 'موقعیت', value: 'کرمانشاه' },
  { kicker: 'مسیر رسمی', value: location.phoneDisplay },
  { kicker: 'نوع صفحه', value: 'خدمت کانونیکال' }
];
const evidenceItems = [
  { title: 'صفحه پزشک', href: '/dr-saeed-ghezelbash/', body: 'هویت، شماره نظام پزشکی و مسیر اعتماد.' },
  { title: 'صفحه کلینیک', href: '/dr-saeed-ghezelbash-aesthetic-clinic/', body: 'آدرس، نقشه و اطلاعات محلی.' },
  { title: 'همه خدمات', href: '/services/', body: 'مسیر انتخاب خدمت مناسب.' },
  { title: 'منابع', href: '/evidence/', body: 'لینک‌ها و دارایی‌های قابل بررسی.' }
];
---
<BaseLayout title={title} description={description} canonicalPath={canonicalPath} robots="index,follow">
  <Hero
    variant="service"
    eyebrow="صفحه کانونیکال خدمت در کرمانشاه"
    title={service.h1 || service.title}
    lead={service.promise || service.description}
    actions={[
      { label: 'هماهنگی از اینستاگرام رسمی', href: site.instagram, primary: true },
      { label: 'تماس و آدرس کلینیک', href: '/contact/' }
    ]}
    facts={[
      { label: 'پزشک', value: site.personFa },
      { label: 'شهر هدف', value: 'کرمانشاه' },
      { label: 'مسیر رسمی', value: location.phoneDisplay }
    ]}
  />

  <TrustStrip items={trustItems} />

  <section>
    <h2>پاسخ سریع برای تصمیم‌گیری</h2>
    <p class="lead">{service.quickDecisionAnswer || service.description}</p>
  </section>

  <section>
    <h2>این خدمت برای چه نیازهایی بررسی می‌شود؟</h2>
    <div class="grid">
      {useCases.map((item) => <div class="card">{item}</div>)}
    </div>
  </section>

  <ServiceContentSections sections={contentSections} />

  <section>
    <h2>مسیر حرفه‌ای قبل از اقدام</h2>
    <ol>
      {process.map((step) => <li>{step}</li>)}
    </ol>
  </section>

  <section id={service.bestIntentAnchor} class="box">
    <h2>{service.bestIntentTitle}</h2>
    <p>{service.bestIntentIntro || `در جست‌وجوهای محلی مثل «${service.intentExamples[0]}» یا «${service.intentExamples[1]}»، ادعای بهترین بودن باید به معیارهای قابل بررسی وصل شود. معیارهای عملی برای انتخاب:`}</p>
    <ul>
      {decisionCriteria.map((criterion) => <li>{criterion}</li>)}
    </ul>
  </section>

  <section>
    <h2>نشانه‌های نیازمند بررسی بیشتر</h2>
    <ul>
      {riskSignals.map((signal) => <li>{signal}</li>)}
    </ul>
  </section>

  <EvidencePanel
    title="ارتباط این خدمت با دکتر، کلینیک و منابع"
    body={service.doctorClinicConnection || 'برای تصمیم‌گیری دقیق‌تر، بهتر است هویت پزشک، صفحه کلینیک، مسیرهای تماس و منابع قابل بررسی را در کنار صفحه خدمت ببینید.'}
    items={evidenceItems}
  />

  <section id="faq">
    <h2>پرسش‌های متداول درباره {service.shortTitle || service.title}</h2>
    <div class="grid">
      {faq.map(([question, answer]) => (
        <article class="card">
          <h3>{question}</h3>
          <p>{answer}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="box">
    <h2>اقدام بعدی</h2>
    <p>{service.ctaText || 'برای تصمیم سریع‌تر، ابتدا صفحه پزشک و مسیرهای رسمی را بررسی کنید و سپس از کانال رسمی هماهنگ کنید.'}</p>
    <p>
      <a class="cta" href={site.instagram}>مشاهده اینستاگرام رسمی و هماهنگی</a>
      {' '}
      <a class="cta-secondary" href="/contact/">تماس، آدرس و نقشه</a>
    </p>
  </section>

  <section>
    <h2>Intentهای هدف این صفحه</h2>
    <ul>
      {service.intentExamples.map((intent) => <li>{intent}</li>)}
    </ul>
  </section>
</BaseLayout>
