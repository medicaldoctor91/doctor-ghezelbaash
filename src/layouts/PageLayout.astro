---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import MobileStickyCta from '~/components/common/MobileStickyCta.astro';

import { getNavigationData } from '~/utils/contentData';
import { getUiCopy } from '~/utils/uiCopy';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
  pagefindBody?: boolean;
}

const { metadata, pagefindBody = true } = Astro.props;
const { headerData, footerData } = await getNavigationData();
const uiCopy = await getUiCopy<{ skipLink: string }>();
---

<Layout metadata={metadata}>
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:right-4 focus:top-4 focus:z-50 focus:rounded-xl focus:bg-white focus:px-4 focus:py-3 focus:text-black focus:shadow-lg"
  >
    {uiCopy.skipLink}
  </a>
  <slot name="header">
    <Header {...headerData} isSticky />
  </slot>
  <main
    id="main-content"
    data-pagefind-body={pagefindBody ? true : undefined}
    data-pagefind-ignore={pagefindBody ? undefined : true}
  >
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>
  <MobileStickyCta />
</Layout>
