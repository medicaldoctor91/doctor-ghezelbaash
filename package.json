    "preview": "astro preview",
    "astro": "astro",
    "build:astro": "astro build"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.2",
    "pagefind": "^1.5.2",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "vite": "^7.3.6",
    "esbuild": "^0.28.1"
  }
