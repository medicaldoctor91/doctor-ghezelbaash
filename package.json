{
  "name": "doctor-ghezelbaash-astro",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/prepare-public.mjs && astro build",
    "dev": "astro dev",
    "preview": "astro preview",
    "validate": "node scripts/run-validation-phase.mjs",
    "validate:source": "node scripts/run-validation-phase.mjs source",
    "validate:schema": "node scripts/run-validation-phase.mjs schema",
    "validate:authority": "node scripts/run-validation-phase.mjs authority",
    "validate:primary-graph": "node scripts/run-validation-phase.mjs primary-graph",
    "validate:dist": "node scripts/run-validation-phase.mjs dist",
    "astro:check": "npx --yes --package @astrojs/check --package typescript astro check",
    "validate:html": "npx --yes html-validate \"dist/**/*.html\"",
    "format:check": "npx --yes prettier --check \"**/*.{js,mjs,json,md,yml,yaml,css}\"",
    "format:fix": "npx --yes prettier --write \"**/*.{js,mjs,json,md,yml,yaml,css}\"",
    "quality:ci": "npm run astro:check && npm run build && npm run validate:html && npm run validate:dist",
    "check": "npm run validate && npm run quality:ci"
  },
  "dependencies": {
    "astro": "^4.16.0"
  }
}
