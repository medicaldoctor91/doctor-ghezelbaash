{
  "name": "ghezelbaash-astro-megalanding",
  "type": "module",
  "version": "9.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate:stage2 && ASTRO_TELEMETRY_DISABLED=1 astro build && npm run validate:stage3 && npm run validate:stage4 && npm run validate:stage5 && npm run validate:stage6 && npm run validate:stage7 && npm run validate:stage8 && npm run validate:stage9 && npm run validate:stage10 && npm run validate:stage11 && npm run validate:release",
    "build:astro": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "reputation:update": "node scripts/update-clinic-reputation.mjs",
    "quality:summarize": "node scripts/summarize-lighthouse.mjs quality-reports --enforce",
    "validate:stage2": "node scripts/validate-stage-2-architecture.mjs",
    "validate:stage3": "node scripts/validate-stage-3-hero.mjs",
    "validate:stage4": "node scripts/validate-stage-4-outline-mission.mjs",
    "validate:stage5": "node scripts/validate-stage-5-medical-content.mjs",
    "validate:stage6": "node scripts/run-validator-with-deferred-posters.mjs scripts/validate-stage-6-video-placement.mjs",
    "validate:stage7": "node scripts/validate-stage-7-clinic-footer.mjs",
    "validate:stage8": "node scripts/run-validator-with-deferred-posters.mjs scripts/validate-stage-8-graph-sync.mjs",
    "validate:stage9": "node scripts/run-validator-with-deferred-posters.mjs scripts/validate-stage-9-production-readiness.mjs",
    "validate:stage10": "node scripts/validate-stage-10-mission-lock.mjs",
    "validate:stage11": "node scripts/validate-stage-11-cloudflare-quality.mjs && node scripts/validate-deferred-video-posters.mjs",
    "validate:release": "node scripts/validate-release.mjs && node scripts/validate-visible-contract.mjs && node scripts/validate-schema-semantics.mjs && node scripts/validate-nine-stage-audit.mjs && node scripts/validate-passage-depth.mjs"
  },
  "dependencies": {
    "@lucide/astro": "^1.23.0",
    "astro": "^7.0.2",
    "github-slugger": "^2.0.0"
  },
  "devDependencies": {
    "@astrojs/markdown-remark": "^7.2.1"
  }
}
