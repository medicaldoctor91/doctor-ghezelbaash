{
  "name": "doctor-ghezelbaash-static-entity-page",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "preview": "astro preview",
    "astro": "astro",
    "media:verify": "node scripts/check-media-integrity.mjs",
    "prebuild": "npm run validate:inputs && npm run generate",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build && npm run finalize && npm run validate",
    "build:scaffold": "node --experimental-strip-types scripts/generate-static-artifacts.mjs --allow-placeholders && ASTRO_TELEMETRY_DISABLED=1 astro build && node --experimental-strip-types scripts/finalize-build.mjs --allow-placeholders && npm run validate:structure",
    "generate": "node --experimental-strip-types scripts/generate-static-artifacts.mjs",
    "finalize": "node --experimental-strip-types scripts/finalize-build.mjs",
    "validate": "node --experimental-strip-types scripts/validate.mjs all",
    "validate:inputs": "node --experimental-strip-types scripts/validate.mjs inputs",
    "validate:structure": "node --experimental-strip-types scripts/validate.mjs structure",
    "validate:html": "node --experimental-strip-types scripts/validate.mjs html",
    "validate:schema": "node --experimental-strip-types scripts/validate.mjs schema",
    "validate:graph": "node --experimental-strip-types scripts/validate.mjs graph",
    "validate:links": "node --experimental-strip-types scripts/validate.mjs links",
    "validate:anchors": "node --experimental-strip-types scripts/validate.mjs anchors",
    "validate:canonical": "node --experimental-strip-types scripts/validate.mjs canonical",
    "validate:budgets": "node --experimental-strip-types scripts/validate.mjs budgets",
    "validate:persian": "node --experimental-strip-types scripts/validate.mjs persian",
    "validate:llms": "node --experimental-strip-types scripts/validate.mjs llms",
    "validate:no-pages-dev": "node --experimental-strip-types scripts/validate.mjs no-pages-dev",
    "validate:no-service-flags": "node --experimental-strip-types scripts/validate.mjs no-service-flags",
    "validate:headers": "node --experimental-strip-types scripts/validate.mjs headers",
    "validate:sitemap": "node --experimental-strip-types scripts/validate.mjs sitemap",
    "validate:robots": "node --experimental-strip-types scripts/validate.mjs robots",
    "validate:media": "node --experimental-strip-types scripts/validate.mjs media",
    "validate:video": "node --experimental-strip-types scripts/validate.mjs video",
    "validate:video-schema": "node --experimental-strip-types scripts/validate.mjs video-schema",
    "validate:datasets": "node --experimental-strip-types scripts/validate.mjs datasets",
    "validate:release": "node --experimental-strip-types scripts/validate.mjs release"
  },
  "dependencies": {
    "astro": "^7.0.2"
  },
  "devDependencies": {
    "@astrojs/markdown-remark": "^7.2.1"
  }
}
