{
  "name": "ghezelbaash-authority-site",
  "version": "12.0.0",
  "description": "Entity-first SEO/AEO authority site for Dr. Saeed Ghezelbash clinic with registry-consistent JSON-LD graph, datasets, and service catalog.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist --force-language fa --root-selector \"[data-pagefind-body]\" --exclude-selectors \"[data-pagefind-ignore]\"",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "sync:google-rating": "node scripts/sync-google-maps-rating.mjs",
    "build:with-google-rating": "npm run sync:google-rating && npm run build",
    "build:astro": "astro build"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "vite": "^7.3.6",
    "esbuild": "^0.28.1"
  }
}
