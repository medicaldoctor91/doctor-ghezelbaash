{
  "name": "doctor-ghezelbaash-static-entity-page",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "preview": "astro preview",
    "astro": "astro",
    "check:astro": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "media:verify": "node scripts/check-media-integrity.mjs",
    "content:validate": "node scripts/validate-content-package.mjs",
    "content:stage": "node scripts/stage-content-package.mjs",
    "content:test": "node scripts/test-content-package-validator.mjs",
    "prebuild": "npm run check:astro && npm run content:test && node --experimental-strip-types scripts/validate-production-v2.mjs inputs && npm run generate",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build && npm run finalize && node --experimental-strip-types scripts/validate-production-v2.mjs all",
    "generate": "node --experimental-strip-types scripts/generate-production.mjs && node scripts/copy-static-icons.mjs",
    "finalize": "node --experimental-strip-types scripts/finalize-build.mjs",
    "validate": "node --experimental-strip-types scripts/validate-production-v2.mjs all",
    "validate:inputs": "node --experimental-strip-types scripts/validate-production-v2.mjs inputs"
  },
  "dependencies": {
    "astro": "^7.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  }
}
