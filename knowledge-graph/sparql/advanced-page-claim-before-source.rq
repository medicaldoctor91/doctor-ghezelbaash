PREFIX schema: <https://schema.org/>

SELECT ?page ?term WHERE {
  ?term a schema:DefinedTerm .
  FILTER(STRSTARTS(STR(?term), "https://www.ghezelbaash.ir/kg/advanced-knowledge-scope#"))
  ?term schema:subjectOf ?page .
  ?page a schema:MedicalWebPage .
  FILTER NOT EXISTS { ?term schema:citation ?citation . }
}
