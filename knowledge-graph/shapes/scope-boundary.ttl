@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .

<#KnowledgeTermShape>
  a sh:NodeShape ;
  sh:targetClass schema:DefinedTerm ;
  sh:property [ sh:path schema:inDefinedTermSet ; sh:minCount 1 ] .

<#ServiceShape>
  a sh:NodeShape ;
  sh:targetClass schema:Service ;
  sh:property [ sh:path schema:provider ; sh:minCount 1 ] .

<#OfferShape>
  a sh:NodeShape ;
  sh:targetClass schema:Offer ;
  sh:property [ sh:path schema:itemOffered ; sh:minCount 1 ] .
