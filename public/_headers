/*
  Content-Language: fa-IR
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  X-Permitted-Cross-Domain-Policies: none
  Cross-Origin-Resource-Policy: same-origin
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Origin-Agent-Cluster: ?1
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'none'; img-src 'self' data:; media-src 'self'; style-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; font-src 'self' data:; connect-src 'self' https://cloudflareinsights.com; manifest-src 'self'; worker-src 'none'; upgrade-insecure-requests

/
  Cache-Control: public, max-age=0, must-revalidate
  Link: </knowledge-graph.jsonld>; rel="describedby"; type="application/ld+json"

/404.html
  X-Robots-Tag: noindex, follow
  Cache-Control: public, max-age=300

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable

/og/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/videos/*.mp4
  Content-Type: video/mp4
  Cache-Control: public, max-age=31536000, immutable
  Accept-Ranges: bytes

/videos/chapters/*.vtt
  Content-Type: text/vtt; charset=utf-8
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=604800

/favicon-32x32.png
  Cache-Control: public, max-age=604800

/apple-touch-icon.png
  Cache-Control: public, max-age=604800

/knowledge-graph.jsonld
  Content-Type: application/ld+json; charset=utf-8
  X-Robots-Tag: noindex, follow
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/llms.txt
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: noindex, follow
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/*.xml
  Content-Type: application/xml; charset=utf-8
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/site.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

/.well-known/ai.txt
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: noindex, follow
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
